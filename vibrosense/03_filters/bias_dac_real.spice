XM2b_cas sw2b  gate_c mid2b vss sky130_fd_pr__nfet_01v8 W=2u L=4u nf=1
XM2b_sw  iout  b2     sw2b  vss sky130_fd_pr__nfet_01v8 W=1u L=0.15u nf=1
