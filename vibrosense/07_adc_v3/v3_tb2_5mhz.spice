.meas tran v9_b6 FIND v(d6) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b5 FIND v(d5) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b4 FIND v(d4) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b3 FIND v(d3) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b2 FIND v(d2) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b1 FIND v(d1) WHEN v(valid)=0.9 RISE=9
.meas tran v9_b0 FIND v(d0) WHEN v(valid)=0.9 RISE=9

.meas tran v10_b7 FIND v(d7) WHEN v(valid)=0.9 RISE=10
.meas tran v10_b6 FIND v(d6) WHEN v(valid)=0.9 RISE=10
.meas tran v10_b5 FIND v(d5) WHEN v(valid)=0.9 RISE=10
