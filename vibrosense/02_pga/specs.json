{
  "name": "VibroSense Programmable Gain Amplifier",
  "description": "Capacitive-feedback PGA using the OTA from 01_ota. 4 gain settings: 1x/4x/16x/64x via switchable Cin. First verify with behavioral OTA, then with real OTA netlist.",
  "supply_v": 1.8,
  "margin_rule": "All 4 gain settings must pass independently in all 5 corners",
  "measurements": {
    "gain_accuracy_db": {
      "target": "-0.5 to +0.5",
      "weight": 25,
      "unit": "dB",
      "description": "Gain error at each setting (1x/4x/16x/64x)"
    },
    "bandwidth_hz": {
      "target": ">25000",
      "weight": 20,
      "unit": "Hz",
      "description": "-3dB bandwidth at all gain settings with 10pF load"
    },
    "thd_dbc": {
      "target": "<-40",
      "weight": 20,
      "unit": "dBc",
      "description": "THD at 1Vpp output, 1kHz"
    },
    "input_noise_nv_sqrthz": {
      "target": "<200",
      "weight": 15,
      "unit": "nV/sqrt(Hz)",
      "description": "Input-referred noise at 10kHz (1x gain)"
    },
    "gain_switching_glitch_mv": {
      "target": "<50",
      "weight": 10,
      "unit": "mV",
      "description": "Output glitch when switching gain"
    },
    "power_uw": {
      "target": "<5",
      "weight": 10,
      "unit": "uW",
      "description": "Total PGA power"
    }
  }
}
