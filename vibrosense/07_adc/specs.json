{
  "name": "VibroSense 8-bit SAR ADC (on-demand)",
  "description": "8-bit SAR ADC adapted from JKU 12-bit design. NOT always-on — activated by digital control when MCU requests data. Digitizes feature voltages and broadband signal for kurtosis computation.",
  "supply_v": 1.8,
  "margin_rule": "DNL/INL must pass at all 5 corners. ENOB >7 bits mandatory.",
  "measurements": {
    "enob_bits": {
      "target": ">7",
      "weight": 30,
      "unit": "bits",
      "description": "Effective number of bits from SINAD"
    },
    "dnl_lsb": {
      "target": "<0.5",
      "weight": 20,
      "unit": "LSB",
      "description": "Differential non-linearity (max across all codes)"
    },
    "inl_lsb": {
      "target": "<0.5",
      "weight": 20,
      "unit": "LSB",
      "description": "Integral non-linearity"
    },
    "sample_rate_ksps": {
      "target": ">10",
      "weight": 15,
      "unit": "kSPS",
      "description": "Maximum sample rate"
    },
    "power_active_uw": {
      "target": "<100",
      "weight": 10,
      "unit": "uW",
      "description": "Power when actively converting"
    },
    "power_sleep_uw": {
      "target": "<0.5",
      "weight": 5,
      "unit": "uW",
      "description": "Leakage power in sleep mode"
    }
  }
}
