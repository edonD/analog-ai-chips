{
  "name": "gearbox",
  "description": "Gearbox Fault Detection — 4-class (Normal, Tooth Crack, Tooth Wear, Shaft Misalignment)",
  "sensor": "MEMS accelerometer on gearbox housing",
  "sample_rate_hz": 12000,
  "window_seconds": 0.5,
  "classes": ["Normal", "Tooth Crack", "Tooth Wear", "Shaft Misalignment"],
  "n_classes": 4,
  "bands_hz": [
    [20, 300],
    [300, 1000],
    [1000, 2500],
    [2500, 4500],
    [4500, 5900]
  ],
  "band_labels": [
    "Shaft speed and low-order gear mesh sidebands",
    "Gear mesh frequency fundamental",
    "Gear mesh 2nd/3rd harmonics",
    "High-order mesh harmonics (crack indicator)",
    "Broadband impulse energy (tooth breakage)"
  ],
  "envelope_lpf_hz": 8,
  "rms_window_ms": 10,
  "pga_gain": "16x",
  "pga_gain_notes": "Gearbox vibration can be low amplitude at early fault stages",
  "quantization_bits": 4,
  "c_unit_fF": 10,
  "regularization_C_grid": [0.01, 0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 100.0],
  "targets": {
    "float_accuracy_pct": 85,
    "quantized_accuracy_pct": 80,
    "max_quantization_loss_pp": 5,
    "noisy_accuracy_pct_2sigma": 75,
    "min_per_class_recall_pct": 70
  }
}
