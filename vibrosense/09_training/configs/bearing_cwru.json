    "Near-Nyquist impulse energy"
  ],
  "envelope_lpf_hz": 10,
  "rms_window_ms": 10,
  "pga_gain": "16x",
  "pga_gain_notes": "ADXL355 at +/-2g: 660mV full-scale, x16 -> 10.6Vpp clipped to 1.8V rail, good SNR for moderate vibration",
  "quantization_bits": 4,
  "c_unit_fF": 10,
  "regularization_C_grid": [0.01, 0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 100.0],
  "targets": {
    "float_accuracy_pct": 88,
    "quantized_accuracy_pct": 85,
    "max_quantization_loss_pp": 5,
