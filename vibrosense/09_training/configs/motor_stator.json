{
  "name": "motor_stator",
  "description": "Induction Motor Stator Fault Detection — 4-class (Normal, Inter-turn Short, Broken Bar, Eccentricity)",
  "sensor": "MEMS accelerometer or current transformer",
  "sample_rate_hz": 12000,
  "window_seconds": 0.5,
  "classes": ["Normal", "Inter-turn Short", "Broken Bar", "Eccentricity"],
  "n_classes": 4,
  "bands_hz": [
    [25, 150],
    [150, 500],
    [500, 1500],
    [1500, 3500],
    [3500, 5900]
  ],
  "band_labels": [
    "Line frequency sidebands (50/60Hz +/- slip)",
    "Rotor bar pass frequency and harmonics",
    "Stator slot harmonics",
    "High-order winding harmonics",
    "Broadband fault noise"
  ],
  "envelope_lpf_hz": 5,
  "rms_window_ms": 20,
  "pga_gain": "4x",
  "pga_gain_notes": "Motor vibration typically higher amplitude than bearing, lower gain needed",
  "quantization_bits": 4,
  "c_unit_fF": 10,
  "regularization_C_grid": [0.01, 0.1, 0.5, 1.0, 2.0, 5.0, 10.0, 100.0],
  "targets": {
    "float_accuracy_pct": 85,
    "quantized_accuracy_pct": 80,
    "max_quantization_loss_pp": 5,
    "noisy_accuracy_pct_2sigma": 75,
    "min_per_class_recall_pct": 70
  }
}
