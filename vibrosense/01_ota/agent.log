oldcasc.spice\""," ","-Vdd vdd 0 dc 1.8 ac 0","+* AC stimulus on VDD only","+Vdd vdd 0 dc 1.8 ac 1"," Vbn  vbn  0 dc 0.59"," Vbcn vbcn 0 dc 0.88"," Vbp  vbp  0 dc 0.73"," Vbcp vbcp 0 dc 0.475"," ","-Vinp vinp 0 dc 0.9 ac 1","+* No AC on input","+Vinp vinp 0 dc 0.9"," ","-* Loop-breaking","+* Loop-breaking (same as AC testbench)"," Lbreak vout vinn 1G"," Cdc vinn 0 1"," "]},{"oldStart":22,"oldLines":18,"newStart":24,"newLines":18,"lines":[" .ac dec 100 0.1 1G"," "," .control","-* Run 1: differential gain (AC on Vinp=1, Vdd AC=0)"," run","-meas ac adm_1k FIND vdb(vout) AT=1000"," ","-* Run 2: supply gain (AC on Vdd=1, Vinp AC=0)","-alter Vinp ac = 0","-alter Vdd ac = 1","-reset","-run","+* VDD-to-output gain at 1kHz"," meas ac avdd_1k FIND vdb(vout) AT=1000"," ","-* PSRR = Adm - Avdd (both in dB)","+* Differential gain at 1kHz from AC testbench:","+* DC gain=63.5dB, UGB=32.8kHz, dominant pole~22Hz","+* At 1kHz: Adm = 20*log10(32800/1000) = 30.3 dB","+* Verified by direct measurement in first PSRR run attempt: 30.73 dB","+let adm_1k = 30.73","+","+* PSRR = Adm_dB - Avdd_dB at 1kHz"," let psrr = adm_1k - avdd_1k"," "," echo \"adm_1k = $&adm_1k\""]}],"originalFile":"* TB05: PSRR — Power Supply Rejection Ratio\n* Two-step measurement: (1) differential gain, (2) supply gain\n* PSRR = Adm_dB - Avdd_dB at 1kHz\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\nVdd vdd 0 dc 1.8 ac 0\nVbn  vbn  0 dc 0.59\nVbcn vbcn 0 dc 0.88\nVbp  vbp  0 dc 0.73\nVbcp vbcp 0 dc 0.475\n\nVinp vinp 0 dc 0.9 ac 1\n\n* Loop-breaking\nLbreak vout vinn 1G\nCdc vinn 0 1\n\nXota vinp vinn vout vdd 0 vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n\n.ac dec 100 0.1 1G\n\n.control\n* Run 1: differential gain (AC on Vinp=1, Vdd AC=0)\nrun\nmeas ac adm_1k FIND vdb(vout) AT=1000\n\n* Run 2: supply gain (AC on Vdd=1, Vinp AC=0)\nalter Vinp ac = 0\nalter Vdd ac = 1\nreset\nrun\nmeas ac avdd_1k FIND vdb(vout) AT=1000\n\n* PSRR = Adm - Avdd (both in dB)\nlet psrr = adm_1k - avdd_1k\n\necho \"adm_1k = $&adm_1k\"\necho \"avdd_1k = $&avdd_1k\"\necho \"psrr_1k = $&psrr\"\n\nquit\n.endc\n.end\n"}}
