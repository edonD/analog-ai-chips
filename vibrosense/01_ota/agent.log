\n.param W5  =  8u   L5  = 0.5u  nf5  = 2\n.param W6  =  8u   L6  = 0.5u  nf6  = 2\n.param W7  =  4u   L7  = 0.5u  nf7  = 2\n.param W8  =  4u   L8  = 0.5u  nf8  = 2\n.param W9  =  4u   L9  = 2.0u  nf9  = 1\n.param W10 =  4u   L10 = 2.0u  nf10 = 1\n.param W11 =  4u   L11 = 4.0u  nf11 = 1\n.param W12 =  8u   L12 = 2.0u  nf12 = 1\n.param W13 =  8u   L13 = 2.0u  nf13 = 1\n\n.subckt ota_foldcasc vinp vinn vout vdd vss vbn vbcn vbp vbcp\n\n* --- Input Differential Pair ---\nXM1 fold_p vinp tail vss sky130_fd_pr__nfet_01v8 W={W1} L={L1} nf={nf1}\nXM2 vout   vinn tail vss sky130_fd_pr__nfet_01v8 W={W2} L={L2} nf={nf2}\n\n* --- Tail Current Source ---\nXM11 tail vbn vss vss sky130_fd_pr__nfet_01v8 W={W11} L={L11} nf={nf11}\n\n* --- PMOS Fold Transistors (current sources from VDD) ---\nXM3 mid_p vbp vdd vdd sky130_fd_pr__pfet_01v8 W={W3} L={L3} nf={nf3}\nXM4 mid_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W={W4} L={L4} nf={nf4}\n\n* --- PMOS Bias Mirror Transistors (parallel with M3/M4) ---\nXM12 mid_p vbp vdd vdd sky130_fd_pr__pfet_01v8 W={W12} L={L12} nf={nf12}\nXM13 mid_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W={W13} L={L13} nf={nf13}\n\n* --- PMOS Cascode Transistors ---\nXM5 fold_p vbcp mid_p vdd sky130_fd_pr__pfet_01v8 W={W5} L={L5} nf={nf5}\nXM6 vout   vbcp mid_n vdd sky130_fd_pr__pfet_01v8 W={W6} L={L6} nf={nf6}\n\n* --- NMOS Cascode Transistors ---\nXM7 fold_p vbcn src_n7 vss sky130_fd_pr__nfet_01v8 W={W7} L={L7} nf={nf7}\nXM8 vout   vbcn src_n8 vss sky130_fd_pr__nfet_01v8 W={W8} L={L8} nf={nf8}\n\n* --- NMOS Current Source Transistors ---\nXM9  src_n7 vbn vss vss sky130_fd_pr__nfet_01v8 W={W9} L={L9} nf={nf9}\nXM10 src_n8 vbn vss vss sky130_fd_pr__nfet_01v8 W={W10} L={L10} nf={nf10}\n\n.ends ota_foldcasc\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1804,"cache_read_input_tokens":76244,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1804},"output_tokens":8,"service