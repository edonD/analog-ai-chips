e_at_ugb + 180\n  print pm\n\n  * Gain at -180 degrees\n  meas ac freq_180 WHEN vp(vout)=-180 FALL=1\n  meas ac gain_180 FIND vdb(vout) AT=freq_180\n  let gm_db = -gain_180\n  print gm_db\n\n  * Some spot frequencies\n  meas ac gain_1hz FIND vdb(vout) AT=1\n  meas ac gain_100hz FIND vdb(vout) AT=100\n  meas ac gain_1k FIND vdb(vout) AT=1000\n  meas ac gain_10k FIND vdb(vout) AT=10000\n  meas ac gain_100k FIND vdb(vout) AT=100000\n  echo \"\"\n  echo \"Gain at 1Hz: $&gain_1hz dB\"\n  echo \"Gain at 100Hz: $&gain_100hz dB\"\n  echo \"Gain at 1kHz: $&gain_1k dB\"\n  echo \"Gain at 10kHz: $&gain_10k dB\"\n  echo \"Gain at 100kHz: $&gain_100k dB\"\n\n  * Phase at spot frequencies\n  meas ac ph_1hz FIND vp(vout) AT=1\n  meas ac ph_1k FIND vp(vout) AT=1000\n  meas ac ph_10k FIND vp(vout) AT=10000\n  echo \"Phase at 1Hz: $&ph_1hz deg\"\n  echo \"Phase at 1kHz: $&ph_1k deg\"\n  echo \"Phase at 10kHz: $&ph_10k deg\"\n\n  echo \"======================================================\"\n\n  wrdata bode_data vdb(vout) vp(vout)\n\n  quit\n.endc\n\n.end\n","structuredPatch":[{"oldStart":1,"oldLines":11,"newStart":1,"newLines":7,"lines":[" * ============================================================","-* TB01: AC Open-Loop Analysis — VibroSense OTA","+* TB01: AC Analysis — VibroSense OTA","+* Method: Unity-gain with AC injection for loop gain"," * ============================================================","-* Method: DC feedback via inductor, AC open-loop","-* Lfb (1GH) passes DC from vout to vinn for bias","-* At AC, Lfb is high-Z so loop is open","-* Vinn is AC-grounded through Vcm source","-* ============================================================"," "," .lib \"sky130_minimal.lib.spice\" tt"," .include \"ota_foldcasc.spice\""]},{"oldStart":24,"oldLines":18,"newStart":20,"newLines":14,"lines":[" Ibp vbp 0 dc 500n"," Vbcp vbcp 0 dc 0.85"," ","-* Common-mode voltage","-Vcm cm 0 dc {vcm_val}","+* Input common-mode","+Vinp vinp 0 dc {vcm_val} ac 1"," ","-* AC stimulus on positive input","-Vac vinp cm dc 0 ac 1","+* DC feedback through large resistor, AC open loop","+* Rfb provides DC feedback: vout→vinn at DC, but negligible AC feedback","+* since Rfb >> Zout of OTA","+Rfb vout vinn 100G"," ","-* DC feedback loop (sets operating point)","-Lfb vout fb_node 1G","-Rfb fb_node vinn 1","-* Tie vinn to cm through large resistor (DC path + AC ground)","-Rbias vinn cm 1G","-"," * Instantiate OTA"," Xota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc"," CL vout 0 10p"]},{"oldStart":47,"oldLines":17,"newStart":39,"newLines":16,"lines":[" ","   echo \"\"","   echo \"======================================================\"","-  echo \"  AC ANALYSIS — VibroSense OTA (Open-Loop)\"","+  echo \"  AC OPEN-LOOP — VibroSense OTA\"","   echo \"======================================================\""," ","-  * DC gain","+  * DC operating point","+  echo \"--- DC Point ---\"","+  * Gain","   meas ac gain_db MAX vdb(vout)","   print gain_db"," ","-  * 3dB bandwidth","-  meas ac freq_3db WHEN vdb(vout)='gain_db-3' FALL=1","-","-  * Unity-gain bandwidth","+  * UGB","   meas ac ugb WHEN vdb(vout)=0 FALL=1","   print ugb"," "]},{"oldStart":65,"oldLines":21,"newStart":56,"newLines":39,"lines":["   meas ac phase_at_ugb FIND vp(vout) AT=ugb","   print phase_at_ugb"," ","-  * Phase margin = phase_at_ugb + 180","-  echo \"Phase Margin:\"","+  * Phase margin","   let pm = phase_at_ugb + 180","   print pm"," ","-  * Gain at -180 degrees phase","-  meas ac freq_neg180 WHEN vp(vout)=-180 FALL=1","-  meas ac gain_at_neg180 FIND vdb(vout) AT=freq_neg180","-  echo \"Gain Margin (dB):\"","-  let gm_db = -gain_at_neg180","+  * Gain at -180 degrees","+  meas ac freq_180 WHEN vp(vout)=-180 FALL=1","+  meas ac gain_180 FIND vdb(vout) AT=freq_180","+  let gm_db = -gain_180","   print gm_db"," ","+  * Some spot frequencies","+  meas ac gain_1hz FIND vdb(vout) AT=1","+  meas ac gain_100hz FIND vdb(vout) AT=100","+  meas ac gain_1k FIND vdb(vout) AT=1000","+  meas ac gain_10k FIND vdb(vout) AT=10000","+  meas ac gain_100k FIND vdb(vout) AT=100000","+  echo \"\"","+  echo \"Gain at 1Hz: $&gain_1hz dB\"","+  echo \"Gain at 100Hz: $&gain_100hz dB\"","+  echo \"Gain at 1kHz: $&gain_1k dB\"","+  echo \"Gain at 10kHz: $&gain_10k dB\"","+  echo \"Gain at 100kHz: $&gain_100k dB\"","+","+  * Phase at spot frequencies","+  meas ac ph_1hz FIND vp(vout) AT=1","+  meas ac ph_1k FIND vp(vout) AT=1000","+  meas ac ph_10k FIND vp(vout) AT=10000","+  echo \"Phase at 1Hz: $&ph_1hz deg\"","+  echo \"Phase at 1kHz: $&ph_1k deg\"","+  echo \"Phase at 10kHz: $&ph_10k deg\"","+","   echo \"======================================================\""," ","-  * Save plot data","   wrdata bode_data vdb(vout) vp(vout)"," ","   quit"]}],"originalFile":"* ============================================================\n* TB01: AC Open-Loop Analysis — VibroSense OTA\n* ============================================================\n* Method: DC feedback via inductor, AC open-loop\n* Lfb (1GH) passes DC from vout to vinn for bias\n* At AC, Lfb is high-Z so loop is open\n* Vinn is AC-grounded through Vcm source\n* ============================================================\n\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\n.param vdd_val = 1.8\n.param vcm_val = 0.9\n\nVdd vdd 0 dc {vdd_val}\nVss vss 0 dc 0\n\n* Bias generation\nMbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1\nIbias vdd vbn dc 500n\nVbcn vbcn 0 dc 0.80\nMbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8__model W=8u L=1u nf=2\nIbp vbp 0 dc 500n\nVbcp vbcp 0 dc 0.85\n\n* Common-mode voltage\nVcm cm 0 dc {vcm_val}\n\n* AC stimulus on positive input\nVac vinp cm dc 0 ac 1\n\n* DC feedback loop (sets operating point)\nLfb vout fb_node 1G\nRfb fb_node vinn 1\n* Tie vinn to cm through large resistor (DC path + AC ground)\nRbias vinn cm 1G\n\n* Instantiate OTA\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n\n.ac dec 100 1 100Meg\n\n.control\n  run\n\n  echo \"\"\n  echo \"======================================================\"\n  echo \"  AC ANALYSIS — VibroSense OTA (Open-Loop)\"\n  echo \"======================================================\"\n\n  * DC gain\n  meas ac gain_db MAX vdb(vout)\n  print gain_db\n\n  * 3dB bandwidth\n  meas ac freq_3db WHEN vdb(vout)='gain_db-3' FALL=1\n\n  * Unity-gain bandwidth\n  meas ac ugb WHEN vdb(vout)=0 FALL=1\n  print ugb\n\n  * Phase at UGB\n  meas ac phase_at_ugb FIND vp(vout) AT=ugb\n  print phase_at_ugb\n\n  * Phase margin = phase_at_ugb + 180\n  echo \"Phase Margin:\"\n  let pm = phase_at_ugb + 180\n  print pm\n\n  * Gain at -180 degrees phase\n  meas ac freq_neg180 WHEN vp(vout)=-180 FALL=1\n  meas ac gain_at_neg180 FIND vdb(vout) AT=freq_neg180\n  echo \"Gain Margin (dB):\"\n  let gm_db = -gain_at_neg180\n  print gm_db\n\n  echo \"======================================================\"\n\n  * Save plot data\n  wrdata bode_data vdb(vout) vp(vout)\n\n  quit\n.endc\n\n.end\n"}}
