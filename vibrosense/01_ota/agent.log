{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G8mRAefMck9AJaNuJc4keR","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→OBJECTIVE OTA DESIGN VERIFIER\n     4→==============================\n     5→This script is the SINGLE SOURCE OF TRUTH for pass/fail.\n     6→It runs ngspice, parses raw output, and checks every spec from program.md.\n     7→The agent CANNOT modify this file. Results are machine-verified.\n     8→\n     9→Exit codes:\n    10→  0 = ALL gates pass\n    11→  1 = Gate 1 (operating point) failed\n    12→  2 = Gate 2 (AC performance) failed\n    13→  3 = Gate 3 (DC/transient) failed\n    14→  4 = Gate 4 (noise/rejection) failed\n    15→  5 = Gate 5 (corners/temperature) failed\n    16→  99 = simulation crashed or files missing\n    17→\n    18→Output: verification_report.txt (append-only log of every run)\n    19→\"\"\"\n    20→\n    21→import subprocess\n    22→import sys\n    23→import os\n    24→import re\n    25→import json\n    26→import datetime\n    27→\n    28→WORK_DIR = \"/home/ubuntu/analog-ai-chips/vibrosense/01_ota\"\n    29→REPORT_FILE = os.path.join(WORK_DIR, \"verification_report.txt\")\n    30→ATTEMPT_COUNT_FILE = os.path.join(WORK_DIR, \".attempt_count\")\n    31→\n    32→# Specs from program.md Section 5 and Section 7\n    33→SPECS = {\n    34→    # Operating point (Section 7.1) — MANDATORY, NO EXCEPTIONS\n    35→    \"pmos_vov_min_mV\": 150,        # Vsg - |Vth| > 150mV for ALL PMOS\n    36→    \"nmos_signal_vov_min_mV\": 50,  # Vgs - Vth > 50mV for M1,M2,M7,M8\n    37→    \"cascode_headroom_mV\": 50,     # Vds > Vdsat + 50mV for cascodes\n    38→    \"tail_current_nA\": 500,        # Id_M11 target\n    39→    \"tail_current_tol_nA\": 50,     # |Id_M11 - 500nA| < 50nA\n    40→    \"current_balance_nA\": 10,      # |Id_M1 - Id_M2| < 10nA\n    41→    \"vout_min_V\": 0.6,             # Output voltage range\n    42→    \"vout_max_V\": 1.2,\n    43→\n    44→    # AC (Section 5.1)\n    45→    \"dc_gain_min_dB\": 60,\n    46→    \"dc_gain_target_dB\": 65,\n    47→    \"ugb_min_Hz\": 30000,\n    48→    \"ugb_max_Hz\": 150000,\n    49→    \"pm_min_deg\": 55,\n    50→    \"gm_min_dB\": 10,\n    51→\n    52→    # Noise (Section 5.2)\n    53→    \"noise_1k_max_nVrtHz\": 200,\n    54→    \"noise_10k_max_nVrtHz\": 100,\n    55→\n    56→    # Transient (Section 5.3)\n    57→    \"slew_rate_min_mVus\": 10,\n    58→\n    59→    # DC (Section 5.4)\n    60→    \"output_swing_min_Vpp\": 1.0,\n    61→    \"input_cm_range_min_V\": 0.6,\n    62→\n    63→    # Rejection (Section 5.5)\n    64→    \"cmrr_dc_min_dB\": 60,\n    65→    \"psrr_1k_min_dB\": 50,\n    66→\n    67→    # Power (Section 5.6)\n    68→    \"total_current_max_uA\": 2.0,\n    69→}\n    70→\n    71→\n    72→def log(msg, report_lines):\n    73→    \"\"\"Print and record.\"\"\"\n    74→    print(msg)\n    75→    report_lines.append(msg)\n    76→\n    77→\n    78→def run_ngspice(spice_file, work_dir=WORK_DIR):\n    79→    \"\"\"Run ngspice in batch mode, return stdout+stderr.\"\"\"\n    80→    if not os.path.exists(os.path.join(work_dir, spice_file)):\n    81→        return None, f\"FILE NOT FOUND: {spice_file}\"\n    82→    try:\n    83→        result = subprocess.run(\n    84→            [\"/usr/bin/ngspice\", \"-b\", spice_file],\n    85→            cwd=work_dir,\n    86→            capture_output=True, text=True, timeout=120\n    87→        )\n    88→        return result.stdout + result.stderr, None\n    89→    except subprocess.TimeoutExpired:\n    90→        return None, \"TIMEOUT: ngspice took > 120s\"\n    91→    except Exception as e:\n    92→        return None, f\"CRASH: {e}\"\n    93→\n    94→\n    95→def parse_op_param(output, device, param):\n    96→    \"\"\"Extract a parameter value like @m.xota.m1[vgs] from ngspice output.\"\"\"\n    97→    pattern = rf'@m\\.xota\\.{device}\\[{param}\\]\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    98→    match = re.search(pattern, output, re.IGNORECASE)\n    99→    if match:\n   100→        return float(match.group(1))\n   101→    return None\n   102→\n   103→\n   104→def parse_meas(output, name):\n   105→    \"\"\"Extract a .meas result by name.\"\"\"\n   106→    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n   107→    match = re.search(pattern, output, re.IGNORECASE)\n   108→    if match:\n   109→        return float(match.group(1))\n   110→    return None\n   111→\n   112→\n   113→def increment_attempt():\n   114→    \"\"\"Track how many verification attempts have been made.\"\"\"\n   115→    count = 0\n   116→    if os.path.exists(ATTEMPT_COUNT_FILE):\n   117→        with open(ATTEMPT_COUNT_FILE) as f:\n   118→            try:\n   119→                count = int(f.read().strip())\n   120→            except:\n   121→                count = 0\n   122→    count += 1\n   123→    with open(ATTEMPT_COUNT_FILE, \"w\") as f:\n   124→        f.write(str(count))\n   125→    return count\n   126→\n   127→\n   128→def gate1_operating_point(report):\n   129→    \"\"\"GATE 1: Operating point verification (Section 7).\"\"\"\n   130→    log(\"\\n\" + \"=\" * 70, report)\n   131→    log(\"GATE 1: OPERATING POINT VERIFICATION (Section 7 — MANDATORY)\", report)\n   132→    log(\"=\" * 70, report)\n   133→\n   134→    output, err = run_ngspice(\"tb_ota_op.spice\")\n   135→    if err:\n   136→        log(f\"  BLOCKED: {err}\", report)\n   137→        return False, {}\n   138→\n   139→    # Extract all 13 transistors\n   140→    devices = {\n   141→        \"m1\":  {\"type\": \"nmos\", \"role\": \"input+\",      \"signal\": True},\n   142→        \"m2\":  {\"type\": \"nmos\", \"role\": \"input-\",       \"signal\": True},\n   143→        \"m3\":  {\"type\": \"pmos\", \"role\": \"fold+\",        \"signal\": False},\n   144→        \"m4\":  {\"type\": \"pmos\", \"role\": \"fold-\",        \"signal\": False},\n   145→        \"m5\":  {\"type\": \"pmos\", \"role\": \"cascode+\",     \"signal\": False, \"cascode\": True},\n   146→        \"m6\":  {\"type\": \"pmos\", \"role\": \"cascode-\",     \"signal\": False, \"cascode\": True},\n   147→        \"m7\":  {\"type\": \"nmos\", \"role\": \"cascode+\",     \"signal\": True,  \"cascode\": True},\n   148→        \"m8\":  {\"type\": \"nmos\", \"role\": \"cascode-\",     \"signal\": True,  \"cascode\": True},\n   149→        \"m9\":  {\"type\": \"nmos\", \"role\": \"current_src+\", \"signal\": False},\n   150→        \"m10\": {\"type\": \"nmos\", \"role\": \"current_src-\", \"signal\": False},\n   151→        \"m11\": {\"type\": \"nmos\", \"role\": \"tail\",         \"signal\": False},\n   152→        \"m12\": {\"type\": \"pmos\", \"role\": \"bias_mirror+\", \"signal\": False},\n   153→        \"m13\": {\"type\": \"pmos\", \"role\": \"bias_mirror-\", \"signal\": False},\n   154→    }\n   155→\n   156→    params = [\"vgs\", \"vth\", \"vds\", \"vdsat\", \"id\", \"gm\", \"gds\"]\n   157→    op_data = {}\n   158→    all_ok = True\n   159→    fails = []\n   160→\n   161→    for dev_name, dev_info in devices.items():\n   162→        op_data[dev_name] = {}\n   163→        for p in params:\n   164→            val = parse_op_param(output, dev_name, p)\n   165→            op_data[dev_name][p] = val\n   166→\n   167→    # Extract Vout\n   168→    vout_match = re.search(r'v\\(vout\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)', output)\n   169→    vout = float(vout_match.group(1)) if vout_match else None\n   170→\n   171→    # Print operating point table\n   172→    log(\"\\n  Device  | Type | Role          | Id(nA)  | Vgs(V) | Vth(V) | Vov(mV) | Vds(V) | Vdsat(V) | gm(uS) | gds(nS) | Status\", report)\n   173→    log(\"  \" + \"-\" * 120, report)\n   174→\n   175→    for dev_name, dev_info in devices.items():\n   176→        d = op_data[dev_name]\n   177→        if d[\"vgs\"] is None:\n   178→            log(f\"  {dev_name:7s} | COULD NOT EXTRACT — ngspice output parse failed\", report)\n   179→            fails.append(f\"{dev_name}: no data extracted\")\n   180→            all_ok = False\n   181→            continue\n   182→\n   183→        vgs = d[\"vgs\"]\n   184→        vth = d[\"vth\"]\n   185→        vds = d[\"vds\"]\n   186→        vdsat = d[\"vdsat\"]\n   187→        id_val = d[\"id\"]\n   188→        gm = d[\"gm\"]\n   189→        gds_val = d[\"gds\"]\n   190→\n   191→        # Compute Vov\n   192→        if dev_info[\"type\"] == \"pmos\":\n   193→            vov_mV = (abs(vgs) - abs(vth)) * 1000  # Vsg - |Vth|\n   194→        else:\n   195→            vov_mV = (vgs - vth) * 1000  # Vgs - Vth\n   196→\n   197→        status = \"OK\"\n   198→        issues = []\n   199→\n   200→        # Check 1: PMOS Vov > 150mV\n   201→        if dev_info[\"type\"] == \"pmos\":\n   202→            if vov_mV < SPECS[\"pmos_vov_min_mV\"]:\n   203→                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['pmos_vov_min_mV']}mV\")\n   204→\n   205→        # Check 2: NMOS signal path Vov > 50mV\n   206→        if dev_info[\"type\"] == \"nmos\" and dev_info.get(\"signal\", False):\n   207→            if vov_mV < SPECS[\"nmos_signal_vov_min_mV\"]:\n   208→                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['nmos_signal_vov_min_mV']}mV\")\n   209→\n   210→        # Check 3: Cascode headroom\n   211→        if dev_info.get(\"cascode\", False):\n   212→            headroom_mV = (abs(vds) - abs(vdsat)) * 1000\n   213→            if headroom_mV < SPECS[\"cascode_headroom_mV\"]:\n   214→                issues.append(f\"headroom={headroom_mV:.0f}mV < {SPECS['cascode_headroom_mV']}mV\")\n   215→\n   216→        # Check 4: Triode detection (|Vds| < |Vdsat|)\n   217→        if abs(vds) < abs(vdsat):\n   218→            issues.append(f\"TRIODE: |Vds|={abs(vds)*1000:.0f}mV < |Vdsat|={abs(vdsat)*1000:.0f}mV\")\n   219→\n   220→        if issues:\n   221→            status = \"FAIL: \" + \"; \".join(issues)\n   222→            fails.append(f\"{dev_name}: {'; '.join(issues)}\")\n   223→            all_ok = False\n   224→\n   225→        log(f\"  {dev_name:7s} | {dev_info['type']:4s} | {dev_info['role']:13s} | {abs(id_val)*1e9:7.1f} | {vgs:+.4f} | {vth:+.4f} | {vov_mV:+7.1f} | {vds:+.4f} | {vdsat:+.5f} | {gm*1e6:6.3f}  | {gds_val*1e9:7.1f}  | {status}\", report)\n   226→\n   227→    # Check 5: Tail current accuracy\n   228→    id_m11 = op_data[\"m11\"][\"id\"]\n   229→    if id_m11 is not None:\n   230→        tail_err = abs(abs(id_m11) * 1e9 - SPECS[\"tail_current_nA\"])\n   231→        if tail_err > SPECS[\"tail_current_tol_nA\"]:\n   232→            fails.append(f\"M11 tail current: {abs(id_m11)*1e9:.1f}nA, error={tail_err:.1f}nA > {SPECS['tail_current_tol_nA']}nA\")\n   233→            all_ok = False\n   234→        log(f\"\\n  Tail current M11: {abs(id_m11)*1e9:.1f} nA (target: {SPECS['tail_current_nA']} ± {SPECS['tail_current_tol_nA']} nA) — {'OK' if tail_err <= SPECS['tail_current_tol_nA'] else 'FAIL'}\", report)\n   235→\n   236→    # Check 6: Current balance M1/M2\n   237→    id_m1 = op_data[\"m1\"][\"id\"]\n   238→    id_m2 = op_data[\"m2\"][\"id\"]\n   239→    if id_m1 is not None and id_m2 is not None:\n   240→        balance = abs(abs(id_m1) - abs(id_m2)) * 1e9\n   241→        if balance > SPECS[\"current_balance_nA\"]:\n   242→            fails.append(f\"M1/M2 balance: {balance:.1f}nA > {SPECS['current_balance_nA']}nA\")\n   243→            all_ok = False\n   244→        log(f\"  Current balance |Id_M1 - Id_M2|: {balance:.1f} nA (max: {SPECS['current_balance_nA']} nA) — {'OK' if balance <= SPECS['current_balance_nA'] else 'FAIL'}\", report)\n   245→\n   246→    # Check 7: Output voltage\n   247→    if vout is not None:\n   248→        vout_ok = SPECS[\"vout_min_V\"] <= vout <= SPECS[\"vout_max_V\"]\n   249→        if not vout_ok:\n   250→            fails.append(f\"Vout={vout:.3f}V outside [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]\")\n   251→            all_ok = False\n   252→        log(f\"  Output voltage: {vout:.4f} V (range: [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]) — {'OK' if vout_ok else 'FAIL'}\", report)\n   253→\n   254→    # Supply current\n   255→    supply_match = re.search(r'-i\\(vdd\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+)', output)\n   256→    if supply_match:\n   257→        i_supply = float(supply_match.group(1))\n   258→        log(f\"  Supply current: {abs(i_supply)*1e6:.3f} uA (max: {SPECS['total_current_max_uA']} uA) — {'OK' if abs(i_supply)*1e6 <= SPECS['total_current_max_uA'] else 'FAIL'}\", report)\n   259→\n   260→    log(f\"\\n  GATE 1 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n   261→    if fails:\n   262→        log(f\"  FAILURES ({len(fails)}):\", report)\n   263→        for f in fails:\n   264→            log(f\"    - {f}\", report)\n   265→    log(\"  \" + \"=\" * 70, report)\n   266→\n   267→    return all_ok, op_data\n   268→\n   269→\n   270→def gate2_ac_performance(report):\n   271→    \"\"\"GATE 2: AC open-loop performance.\"\"\"\n   272→    log(\"\\n\" + \"=\" * 70, report)\n   273→    log(\"GATE 2: AC OPEN-LOOP PERFORMANCE (Section 5.1)\", report)\n   274→    log(\"=\" * 70, report)\n   275→\n   276→    output, err = run_ngspice(\"tb_ota_ac.spice\")\n   277→    if err:\n   278→        log(f\"  BLOCKED: {err}\", report)\n   279→        return False\n   280→\n   281→    all_ok = True\n   282→    fails = []\n   283→\n   284→    # Sanity check: gain at DC (low freq) should be close to peak\n   285→    # If gain at 1Hz << peak gain, the measurement is broken\n   286→    g_peak = parse_meas(output, \"gain_peak\")\n   287→    g_1hz = parse_meas(output, \"g1\")\n   288→    g_10hz = parse_meas(output, \"g10\")\n   289→    g_100hz = parse_meas(output, \"g100\")\n   290→    ugb = parse_meas(output, \"ugb\")\n   291→    phase_ugb = parse_meas(output, \"phase_ugb\")\n   292→\n   293→    log(f\"\\n  Raw ngspice measurements:\", report)\n   294→    log(f\"    Peak gain:    {g_peak:.2f} dB\" if g_peak else \"    Peak gain:    NOT FOUND\", report)\n   295→    log(f\"    Gain @ 1 Hz:  {g_1hz:.2f} dB\" if g_1hz else \"    Gain @ 1 Hz:  NOT FOUND\", report)\n   296→    log(f\"    Gain @ 10 Hz: {g_10hz:.2f} dB\" if g_10hz else \"    Gain @ 10 Hz: NOT FOUND\", report)\n   297→    log(f\"    Gain @ 100 Hz:{g_100hz:.2f} dB\" if g_100hz else \"    Gain @ 100 Hz:NOT FOUND\", report)\n   298→    log(f\"    UGB:          {ugb:.1f} Hz\" if ugb else \"    UGB:          NOT FOUND\", report)\n   299→    log(f\"    Phase @ UGB:  {phase_ugb:.2f} deg\" if phase_ugb else \"    Phase @ UGB:  NOT FOUND\", report)\n   300→\n   301→    # SANITY CHECK: Is this really open-loop?\n   302→    # Open-loop gain should be flat from DC up to the dominant pole.\n   303→    # If gain at 10 Hz is more than 6 dB below peak, the measurement is suspect.\n   304→    if g_peak is not None and g_10hz is not None:\n   305→        if g_peak - g_10hz > 6:\n   306→            log(f\"\\n  *** SANITY WARNING: Peak gain ({g_peak:.1f} dB) is {g_peak - g_10hz:.1f} dB above gain at 10 Hz ({g_10hz:.1f} dB).\", report)\n   307→            log(f\"  *** A proper open-loop response should be FLAT from DC to the dominant pole.\", report)\n   308→            log(f\"  *** This suggests the loop is NOT properly broken — measurement is INVALID.\", report)\n   309→            fails.append(f\"MEASUREMENT INVALID: gain not flat at low freq (peak={g_peak:.1f}dB, @10Hz={g_10hz:.1f}dB)\")\n   310→            all_ok = False\n   311→\n   312→    # SANITY CHECK: Phase margin should not be > 90 deg for a single-stage OTA\n   313→    # with a dominant pole. PM > 120 deg is extremely suspicious.\n   314→    if phase_ugb is not None:\n   315→        pm = phase_ugb + 180\n   316→        log(f\"    Phase margin: {pm:.1f} deg\", report)\n   317→        if pm > 120:\n   318→            log(f\"\\n  *** SANITY WARNING: Phase margin = {pm:.1f} deg is > 120 deg.\", report)\n   319→            log(f\"  *** A folded-cascode OTA should have PM ~ 55-75 deg with 10pF load.\", report)\n   320→            log(f\"  *** PM > 120 deg means the loop gain measurement is broken.\", report)\n   321→            fails.append(f\"MEASUREMENT INVALID: PM={pm:.1f} deg (expected 55-75 deg)\")\n   322→            all_ok = False\n   323→    else:\n   324→        fails.append(\"Phase margin could not be measured\")\n   325→        all_ok = False\n   326→\n   327→    # Actual spec checks (only meaningful if sanity checks pass)\n   328→    if all_ok:\n   329→        # DC gain (use gain at lowest reasonable frequency, e.g. 10 Hz)\n   330→        dc_gain = g_10hz if g_10hz is not None else g_peak\n   331→        if dc_gain is not None:\n   332→            if dc_gain < SPECS[\"dc_gain_min_dB\"]:\n   333→                fails.append(f\"DC gain {dc_gain:.1f} dB < {SPECS['dc_gain_min_dB']} dB min\")\n   334→                all_ok = False\n   335→            log(f\"\\n  DC gain: {dc_gain:.1f} dB (min: {SPECS['dc_gain_min_dB']}, target: {SPECS['dc_gain_target_dB']}) — {'OK' if dc_gain >= SPECS['dc_gain_min_dB'] else 'FAIL'}\", report)\n   336→\n   337→        # UGB\n   338→        if ugb is not None:\n   339→            ugb_ok = SPECS[\"ugb_min_Hz\"] <= ugb <= SPECS[\"ugb_max_Hz\"]\n   340→            if not ugb_ok:\n   341→                fails.append(f\"UGB {ugb:.0f} Hz outside [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]\")\n   342→                all_ok = False\n   343→            log(f\"  UGB: {ugb:.0f} Hz (range: [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]) — {'OK' if ugb_ok else 'FAIL'}\", report)\n   344→\n   345→        # PM\n   346→        if phase_ugb is not None:\n   347→            pm = phase_ugb + 180\n   348→            pm_ok = pm >= SPECS[\"pm_min_deg\"]\n   349→            if not pm_ok:\n   350→                fails.append(f\"PM {pm:.1f} deg < {SPECS['pm_min_deg']} deg\")\n   351→                all_ok = False\n   352→            log(f\"  Phase margin: {pm:.1f} deg (min: {SPECS['pm_min_deg']}) — {'OK' if pm_ok else 'FAIL'}\", report)\n   353→\n   354→    log(f\"\\n  GATE 2 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n   355→    if fails:\n   356→        log(f\"  FAILURES ({len(fails)}):\", report)\n   357→        for f in fails:\n   358→            log(f\"    - {f}\", report)\n   359→    log(\"  \" + \"=\" * 70, report)\n   360→\n   361→    return all_ok\n   362→\n   363→\n   364→def gate3_dc_transient(report):\n   365→    \"\"\"GATE 3: DC sweep and transient.\"\"\"\n   366→    log(\"\\n\" + \"=\" * 70, report)\n   367→    log(\"GATE 3: DC SWEEP & TRANSIENT (Sections 5.3, 5.4)\", report)\n   368→    log(\"=\" * 70, report)\n   369→\n   370→    all_ok = True\n   371→    fails = []\n   372→\n   373→    # DC sweep\n   374→    output_dc, err = run_ngspice(\"tb_ota_dc.spice\")\n   375→    if err:\n   376→        log(f\"  DC: BLOCKED: {err}\", report)\n   377→        all_ok = False\n   378→    else:\n   379→        vmax = parse_meas(output_dc, \"vout_max\")\n   380→        vmin = parse_meas(output_dc, \"vout_min\")\n   381→        if vmax is not None and vmin is not None:\n   382→            swing = vmax - vmin\n   383→            swing_ok = swing >= SPECS[\"output_swing_min_Vpp\"]\n   384→            if not swing_ok:\n   385→                fails.append(f\"Output swing {swing:.3f} Vpp < {SPECS['output_swing_min_Vpp']} Vpp\")\n   386→                all_ok = False\n   387→            log(f\"  Output swing: {swing:.3f} Vpp (min: {SPECS['output_swing_min_Vpp']}) — {'OK' if swing_ok else 'FAIL'}\", report)\n   388→            log(f\"    Vout_max: {vmax:.3f} V, Vout_min: {vmin:.3f} V\", report)\n   389→        else:\n   390→            fails.append(\"Could not measure output swing\")\n   391→            all_ok = False\n   392→\n   393→    # Transient\n   394→    output_tran, err = run_ngspice(\"tb_ota_tran.spice\")\n   395→    if err:\n   396→        log(f\"  Transient: BLOCKED: {err}\", report)\n   397→        all_ok = False\n   398→    else:\n   399→        t10 = parse_meas(output_tran, \"t10\")\n   400→        t90 = parse_meas(output_tran, \"t90\")\n   401→        if t10 is not None and t90 is not None and t90 > t10:\n   402→            sr_Vs = 0.08 / (t90 - t10)\n   403→            sr_mVus = sr_Vs * 1e-6 * 1e3\n   404→            sr_ok = sr_mVus >= SPECS[\"slew_rate_min_mVus\"]\n   405→            if not sr_ok:\n   406→                fails.append(f\"Slew rate {sr_mVus:.2f} mV/us < {SPECS['slew_rate_min_mVus']} mV/us\")\n   407→                all_ok = False\n   408→            log(f\"  Slew rate: {sr_mVus:.2f} mV/us (min: {SPECS['slew_rate_min_mVus']}) — {'OK' if sr_ok else 'FAIL'}\", report)\n   409→        else:\n   410→            log(f\"  Slew rate: could not measure (t10={t10}, t90={t90})\", report)\n   411→            fails.append(\"Could not measure slew rate\")\n   412→            all_ok = False\n   413→\n   414→    log(f\"\\n  GATE 3 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n   415→    if fails:\n   416→        log(f\"  FAILURES ({len(fails)}):\", report)\n   417→        for f in fails:\n   418→            log(f\"    - {f}\", report)\n   419→    log(\"  \" + \"=\" * 70, report)\n   420→    return all_ok\n   421→\n   422→\n   423→def main():\n   424→    attempt = increment_attempt()\n   425→    report = []\n   426→    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n   427→\n   428→    log(f\"\\n{'#' * 70}\", report)\n   429→    log(f\"# VERIFICATION RUN #{attempt} — {timestamp}\", report)\n   430→    log(f\"{'#' * 70}\", report)\n   431→\n   432→    # Check required files exist\n   433→    required = [\"ota_foldcasc.spice\", \"tb_ota_op.spice\", \"sky130_minimal.lib.spice\"]\n   434→    missing = [f for f in required if not os.path.exists(os.path.join(WORK_DIR, f))]\n   435→    if missing:\n   436→        log(f\"\\nMISSING FILES: {missing}\", report)\n   437→        log(\"Cannot verify. Create these files first.\", report)\n   438→        with open(REPORT_FILE, \"a\") as f:\n   439→            f.write(\"\\n\".join(report) + \"\\n\")\n   440→        sys.exit(99)\n   441→\n   442→    # ==================== GATE 1 ====================\n   443→    gate1_pass, op_data = gate1_operating_point(report)\n   444→\n   445→    if not gate1_pass:\n   446→        log(f\"\\n{'!' * 70}\", report)\n   447→        log(f\"! GATE 1 FAILED — DO NOT PROCEED\", report)\n   448→        log(f\"! Fix the operating point before running any other testbench.\", report)\n   449→        log(f\"! See program.md Section 7 and Section 9 for troubleshooting.\", report)\n   450→        log(f\"! This is attempt #{attempt}.\", report)\n   451→        log(f\"{'!' * 70}\", report)\n   452→        with open(REPORT_FILE, \"a\") as f:\n   453→            f.write(\"\\n\".join(report) + \"\\n\")\n   454→        sys.exit(1)\n   455→\n   456→    # ==================== GATE 2 ====================\n   457→    tb_ac_exists = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_ac.spice\"))\n   458→    if tb_ac_exists:\n   459→        gate2_pass = gate2_ac_performance(report)\n   460→        if not gate2_pass:\n   461→            log(f\"\\n{'!' * 70}\", report)\n   462→            log(f\"! GATE 2 FAILED — AC measurement broken or specs not met.\", report)\n   463→            log(f\"! Check: is the loop properly broken? Is gain flat at low freq?\", report)\n   464→            log(f\"! This is attempt #{attempt}.\", report)\n   465→            log(f\"{'!' * 70}\", report)\n   466→            with open(REPORT_FILE, \"a\") as f:\n   467→                f.write(\"\\n\".join(report) + \"\\n\")\n   468→            sys.exit(2)\n   469→    else:\n   470→        log(\"\\n  GATE 2: SKIPPED (tb_ota_ac.spice not found)\", report)\n   471→\n   472→    # ==================== GATE 3 ====================\n   473→    tb_dc = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_dc.spice\"))\n   474→    tb_tran = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_tran.spice\"))\n   475→    if tb_dc or tb_tran:\n   476→        gate3_pass = gate3_dc_transient(report)\n   477→        if not gate3_pass:\n   478→            log(f\"\\n  GATE 3 FAILED — attempt #{attempt}\", report)\n   479→            with open(REPORT_FILE, \"a\") as f:\n   480→                f.write(\"\\n\".join(report) + \"\\n\")\n   481→            sys.exit(3)\n   482→    else:\n   483→        log(\"\\n  GATE 3: SKIPPED (testbench files not found)\", report)\n   484→\n   485→    # ==================== ALL PASSED ====================\n   486→    log(f\"\\n{'*' * 70}\", report)\n   487→    log(f\"* ALL GATES PASSED — attempt #{attempt}\", report)\n   488→    log(f\"{'*' * 70}\", report)\n   489→\n   490→    with open(REPORT_FILE, \"a\") as f:\n   491→        f.write(\"\\n\".join(report) + \"\\n\")\n   492→    sys.exit(0)\n   493→\n   494→\n   495→if __name__ == \"__main__\":\n   496→    main()\n   497→"}]},"parent_tool_use_id":null,"session_id":"37d800be-0a8d-4fa4-9160-013da436175b","uuid":"8a39bdf1-c49c-44b2-adc7-5e8404b96e05","timestamp":"2026-03-22T23:30:05.970Z","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/verify_design.py","content":"#!/usr/bin/env python3\n\"\"\"\nOBJECTIVE OTA DESIGN VERIFIER\n==============================\nThis script is the SINGLE SOURCE OF TRUTH for pass/fail.\nIt runs ngspice, parses raw output, and checks every spec from program.md.\nThe agent CANNOT modify this file. Results are machine-verified.\n\nExit codes:\n  0 = ALL gates pass\n  1 = Gate 1 (operating point) failed\n  2 = Gate 2 (AC performance) failed\n  3 = Gate 3 (DC/transient) failed\n  4 = Gate 4 (noise/rejection) failed\n  5 = Gate 5 (corners/temperature) failed\n  99 = simulation crashed or files missing\n\nOutput: verification_report.txt (append-only log of every run)\n\"\"\"\n\nimport subprocess\nimport sys\nimport os\nimport re\nimport json\nimport datetime\n\nWORK_DIR = \"/home/ubuntu/analog-ai-chips/vibrosense/01_ota\"\nREPORT_FILE = os.path.join(WORK_DIR, \"verification_report.txt\")\nATTEMPT_COUNT_FILE = os.path.join(WORK_DIR, \".attempt_count\")\n\n# Specs from program.md Section 5 and Section 7\nSPECS = {\n    # Operating point (Section 7.1) — MANDATORY, NO EXCEPTIONS\n    \"pmos_vov_min_mV\": 150,        # Vsg - |Vth| > 150mV for ALL PMOS\n    \"nmos_signal_vov_min_mV\": 50,  # Vgs - Vth > 50mV for M1,M2,M7,M8\n    \"cascode_headroom_mV\": 50,     # Vds > Vdsat + 50mV for cascodes\n    \"tail_current_nA\": 500,        # Id_M11 target\n    \"tail_current_tol_nA\": 50,     # |Id_M11 - 500nA| < 50nA\n    \"current_balance_nA\": 10,      # |Id_M1 - Id_M2| < 10nA\n    \"vout_min_V\": 0.6,             # Output voltage range\n    \"vout_max_V\": 1.2,\n\n    # AC (Section 5.1)\n    \"dc_gain_min_dB\": 60,\n    \"dc_gain_target_dB\": 65,\n    \"ugb_min_Hz\": 30000,\n    \"ugb_max_Hz\": 150000,\n    \"pm_min_deg\": 55,\n    \"gm_min_dB\": 10,\n\n    # Noise (Section 5.2)\n    \"noise_1k_max_nVrtHz\": 200,\n    \"noise_10k_max_nVrtHz\": 100,\n\n    # Transient (Section 5.3)\n    \"slew_rate_min_mVus\": 10,\n\n    # DC (Section 5.4)\n    \"output_swing_min_Vpp\": 1.0,\n    \"input_cm_range_min_V\": 0.6,\n\n    # Rejection (Section 5.5)\n    \"cmrr_dc_min_dB\": 60,\n    \"psrr_1k_min_dB\": 50,\n\n    # Power (Section 5.6)\n    \"total_current_max_uA\": 2.0,\n}\n\n\ndef log(msg, report_lines):\n    \"\"\"Print and record.\"\"\"\n    print(msg)\n    report_lines.append(msg)\n\n\ndef run_ngspice(spice_file, work_dir=WORK_DIR):\n    \"\"\"Run ngspice in batch mode, return stdout+stderr.\"\"\"\n    if not os.path.exists(os.path.join(work_dir, spice_file)):\n        return None, f\"FILE NOT FOUND: {spice_file}\"\n    try:\n        result = subprocess.run(\n            [\"/usr/bin/ngspice\", \"-b\", spice_file],\n            cwd=work_dir,\n            capture_output=True, text=True, timeout=120\n        )\n        return result.stdout + result.stderr, None\n    except subprocess.TimeoutExpired:\n        return None, \"TIMEOUT: ngspice took > 120s\"\n    except Exception as e:\n        return None, f\"CRASH: {e}\"\n\n\ndef parse_op_param(output, device, param):\n    \"\"\"Extract a parameter value like @m.xota.m1[vgs] from ngspice output.\"\"\"\n    pattern = rf'@m\\.xota\\.{device}\\[{param}\\]\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    match = re.search(pattern, output, re.IGNORECASE)\n    if match:\n        return float(match.group(1))\n    return None\n\n\ndef parse_meas(output, name):\n    \"\"\"Extract a .meas result by name.\"\"\"\n    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    match = re.search(pattern, output, re.IGNORECASE)\n    if match:\n        return float(match.group(1))\n    return None\n\n\ndef increment_attempt():\n    \"\"\"Track how many verification attempts have been made.\"\"\"\n    count = 0\n    if os.path.exists(ATTEMPT_COUNT_FILE):\n        with open(ATTEMPT_COUNT_FILE) as f:\n            try:\n                count = int(f.read().strip())\n            except:\n                count = 0\n    count += 1\n    with open(ATTEMPT_COUNT_FILE, \"w\") as f:\n        f.write(str(count))\n    return count\n\n\ndef gate1_operating_point(report):\n    \"\"\"GATE 1: Operating point verification (Section 7).\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 1: OPERATING POINT VERIFICATION (Section 7 — MANDATORY)\", report)\n    log(\"=\" * 70, report)\n\n    output, err = run_ngspice(\"tb_ota_op.spice\")\n    if err:\n        log(f\"  BLOCKED: {err}\", report)\n        return False, {}\n\n    # Extract all 13 transistors\n    devices = {\n        \"m1\":  {\"type\": \"nmos\", \"role\": \"input+\",      \"signal\": True},\n        \"m2\":  {\"type\": \"nmos\", \"role\": \"input-\",       \"signal\": True},\n        \"m3\":  {\"type\": \"pmos\", \"role\": \"fold+\",        \"signal\": False},\n        \"m4\":  {\"type\": \"pmos\", \"role\": \"fold-\",        \"signal\": False},\n        \"m5\":  {\"type\": \"pmos\", \"role\": \"cascode+\",     \"signal\": False, \"cascode\": True},\n        \"m6\":  {\"type\": \"pmos\", \"role\": \"cascode-\",     \"signal\": False, \"cascode\": True},\n        \"m7\":  {\"type\": \"nmos\", \"role\": \"cascode+\",     \"signal\": True,  \"cascode\": True},\n        \"m8\":  {\"type\": \"nmos\", \"role\": \"cascode-\",     \"signal\": True,  \"cascode\": True},\n        \"m9\":  {\"type\": \"nmos\", \"role\": \"current_src+\", \"signal\": False},\n        \"m10\": {\"type\": \"nmos\", \"role\": \"current_src-\", \"signal\": False},\n        \"m11\": {\"type\": \"nmos\", \"role\": \"tail\",         \"signal\": False},\n        \"m12\": {\"type\": \"pmos\", \"role\": \"bias_mirror+\", \"signal\": False},\n        \"m13\": {\"type\": \"pmos\", \"role\": \"bias_mirror-\", \"signal\": False},\n    }\n\n    params = [\"vgs\", \"vth\", \"vds\", \"vdsat\", \"id\", \"gm\", \"gds\"]\n    op_data = {}\n    all_ok = True\n    fails = []\n\n    for dev_name, dev_info in devices.items():\n        op_data[dev_name] = {}\n        for p in params:\n            val = parse_op_param(output, dev_name, p)\n            op_data[dev_name][p] = val\n\n    # Extract Vout\n    vout_match = re.search(r'v\\(vout\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)', output)\n    vout = float(vout_match.group(1)) if vout_match else None\n\n    # Print operating point table\n    log(\"\\n  Device  | Type | Role          | Id(nA)  | Vgs(V) | Vth(V) | Vov(mV) | Vds(V) | Vdsat(V) | gm(uS) | gds(nS) | Status\", report)\n    log(\"  \" + \"-\" * 120, report)\n\n    for dev_name, dev_info in devices.items():\n        d = op_data[dev_name]\n        if d[\"vgs\"] is None:\n            log(f\"  {dev_name:7s} | COULD NOT EXTRACT — ngspice output parse failed\", report)\n            fails.append(f\"{dev_name}: no data extracted\")\n            all_ok = False\n            continue\n\n        vgs = d[\"vgs\"]\n        vth = d[\"vth\"]\n        vds = d[\"vds\"]\n        vdsat = d[\"vdsat\"]\n        id_val = d[\"id\"]\n        gm = d[\"gm\"]\n        gds_val = d[\"gds\"]\n\n        # Compute Vov\n        if dev_info[\"type\"] == \"pmos\":\n            vov_mV = (abs(vgs) - abs(vth)) * 1000  # Vsg - |Vth|\n        else:\n            vov_mV = (vgs - vth) * 1000  # Vgs - Vth\n\n        status = \"OK\"\n        issues = []\n\n        # Check 1: PMOS Vov > 150mV\n        if dev_info[\"type\"] == \"pmos\":\n            if vov_mV < SPECS[\"pmos_vov_min_mV\"]:\n                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['pmos_vov_min_mV']}mV\")\n\n        # Check 2: NMOS signal path Vov > 50mV\n        if dev_info[\"type\"] == \"nmos\" and dev_info.get(\"signal\", False):\n            if vov_mV < SPECS[\"nmos_signal_vov_min_mV\"]:\n                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['nmos_signal_vov_min_mV']}mV\")\n\n        # Check 3: Cascode headroom\n        if dev_info.get(\"cascode\", False):\n            headroom_mV = (abs(vds) - abs(vdsat)) * 1000\n            if headroom_mV < SPECS[\"cascode_headroom_mV\"]:\n                issues.append(f\"headroom={headroom_mV:.0f}mV < {SPECS['cascode_headroom_mV']}mV\")\n\n        # Check 4: Triode detection (|Vds| < |Vdsat|)\n        if abs(vds) < abs(vdsat):\n            issues.append(f\"TRIODE: |Vds|={abs(vds)*1000:.0f}mV < |Vdsat|={abs(vdsat)*1000:.0f}mV\")\n\n        if issues:\n            status = \"FAIL: \" + \"; \".join(issues)\n            fails.append(f\"{dev_name}: {'; '.join(issues)}\")\n            all_ok = False\n\n        log(f\"  {dev_name:7s} | {dev_info['type']:4s} | {dev_info['role']:13s} | {abs(id_val)*1e9:7.1f} | {vgs:+.4f} | {vth:+.4f} | {vov_mV:+7.1f} | {vds:+.4f} | {vdsat:+.5f} | {gm*1e6:6.3f}  | {gds_val*1e9:7.1f}  | {status}\", report)\n\n    # Check 5: Tail current accuracy\n    id_m11 = op_data[\"m11\"][\"id\"]\n    if id_m11 is not None:\n        tail_err = abs(abs(id_m11) * 1e9 - SPECS[\"tail_current_nA\"])\n        if tail_err > SPECS[\"tail_current_tol_nA\"]:\n            fails.append(f\"M11 tail current: {abs(id_m11)*1e9:.1f}nA, error={tail_err:.1f}nA > {SPECS['tail_current_tol_nA']}nA\")\n            all_ok = False\n        log(f\"\\n  Tail current M11: {abs(id_m11)*1e9:.1f} nA (target: {SPECS['tail_current_nA']} ± {SPECS['tail_current_tol_nA']} nA) — {'OK' if tail_err <= SPECS['tail_current_tol_nA'] else 'FAIL'}\", report)\n\n    # Check 6: Current balance M1/M2\n    id_m1 = op_data[\"m1\"][\"id\"]\n    id_m2 = op_data[\"m2\"][\"id\"]\n    if id_m1 is not None and id_m2 is not None:\n        balance = abs(abs(id_m1) - abs(id_m2)) * 1e9\n        if balance > SPECS[\"current_balance_nA\"]:\n            fails.append(f\"M1/M2 balance: {balance:.1f}nA > {SPECS['current_balance_nA']}nA\")\n            all_ok = False\n        log(f\"  Current balance |Id_M1 - Id_M2|: {balance:.1f} nA (max: {SPECS['current_balance_nA']} nA) — {'OK' if balance <= SPECS['current_balance_nA'] else 'FAIL'}\", report)\n\n    # Check 7: Output voltage\n    if vout is not None:\n        vout_ok = SPECS[\"vout_min_V\"] <= vout <= SPECS[\"vout_max_V\"]\n        if not vout_ok:\n            fails.append(f\"Vout={vout:.3f}V outside [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]\")\n            all_ok = False\n        log(f\"  Output voltage: {vout:.4f} V (range: [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]) — {'OK' if vout_ok else 'FAIL'}\", report)\n\n    # Supply current\n    supply_match = re.search(r'-i\\(vdd\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+)', output)\n    if supply_match:\n        i_supply = float(supply_match.group(1))\n        log(f\"  Supply current: {abs(i_supply)*1e6:.3f} uA (max: {SPECS['total_current_max_uA']} uA) — {'OK' if abs(i_supply)*1e6 <= SPECS['total_current_max_uA'] else 'FAIL'}\", report)\n\n    log(f\"\\n  GATE 1 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n    if fails:\n        log(f\"  FAILURES ({len(fails)}):\", report)\n        for f in fails:\n            log(f\"    - {f}\", report)\n    log(\"  \" + \"=\" * 70, report)\n\n    return all_ok, op_data\n\n\ndef gate2_ac_performance(report):\n    \"\"\"GATE 2: AC open-loop performance.\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 2: AC OPEN-LOOP PERFORMANCE (Section 5.1)\", report)\n    log(\"=\" * 70, report)\n\n    output, err = run_ngspice(\"tb_ota_ac.spice\")\n    if err:\n        log(f\"  BLOCKED: {err}\", report)\n        return False\n\n    all_ok = True\n    fails = []\n\n    # Sanity check: gain at DC (low freq) should be close to peak\n    # If gain at 1Hz << peak gain, the measurement is broken\n    g_peak = parse_meas(output, \"gain_peak\")\n    g_1hz = parse_meas(output, \"g1\")\n    g_10hz = parse_meas(output, \"g10\")\n    g_100hz = parse_meas(output, \"g100\")\n    ugb = parse_meas(output, \"ugb\")\n    phase_ugb = parse_meas(output, \"phase_ugb\")\n\n    log(f\"\\n  Raw ngspice measurements:\", report)\n    log(f\"    Peak gain:    {g_peak:.2f} dB\" if g_peak else \"    Peak gain:    NOT FOUND\", report)\n    log(f\"    Gain @ 1 Hz:  {g_1hz:.2f} dB\" if g_1hz else \"    Gain @ 1 Hz:  NOT FOUND\", report)\n    log(f\"    Gain @ 10 Hz: {g_10hz:.2f} dB\" if g_10hz else \"    Gain @ 10 Hz: NOT FOUND\", report)\n    log(f\"    Gain @ 100 Hz:{g_100hz:.2f} dB\" if g_100hz else \"    Gain @ 100 Hz:NOT FOUND\", report)\n    log(f\"    UGB:          {ugb:.1f} Hz\" if ugb else \"    UGB:          NOT FOUND\", report)\n    log(f\"    Phase @ UGB:  {phase_ugb:.2f} deg\" if phase_ugb else \"    Phase @ UGB:  NOT FOUND\", report)\n\n    # SANITY CHECK: Is this really open-loop?\n    # Open-loop gain should be flat from DC up to the dominant pole.\n    # If gain at 10 Hz is more than 6 dB below peak, the measurement is suspect.\n    if g_peak is not None and g_10hz is not None:\n        if g_peak - g_10hz > 6:\n            log(f\"\\n  *** SANITY WARNING: Peak gain ({g_peak:.1f} dB) is {g_peak - g_10hz:.1f} dB above gain at 10 Hz ({g_10hz:.1f} dB).\", report)\n            log(f\"  *** A proper open-loop response should be FLAT from DC to the dominant pole.\", report)\n            log(f\"  *** This suggests the loop is NOT properly broken — measurement is INVALID.\", report)\n            fails.append(f\"MEASUREMENT INVALID: gain not flat at low freq (peak={g_peak:.1f}dB, @10Hz={g_10hz:.1f}dB)\")\n            all_ok = False\n\n    # SANITY CHECK: Phase margin should not be > 90 deg for a single-stage OTA\n    # with a dominant pole. PM > 120 deg is extremely suspicious.\n    if phase_ugb is not None:\n        pm = phase_ugb + 180\n        log(f\"    Phase margin: {pm:.1f} deg\", report)\n        if pm > 120:\n            log(f\"\\n  *** SANITY WARNING: Phase margin = {pm:.1f} deg is > 120 deg.\", report)\n            log(f\"  *** A folded-cascode OTA should have PM ~ 55-75 deg with 10pF load.\", report)\n            log(f\"  *** PM > 120 deg means the loop gain measurement is broken.\", report)\n            fails.append(f\"MEASUREMENT INVALID: PM={pm:.1f} deg (expected 55-75 deg)\")\n            all_ok = False\n    else:\n        fails.append(\"Phase margin could not be measured\")\n        all_ok = False\n\n    # Actual spec checks (only meaningful if sanity checks pass)\n    if all_ok:\n        # DC gain (use gain at lowest reasonable frequency, e.g. 10 Hz)\n        dc_gain = g_10hz if g_10hz is not None else g_peak\n        if dc_gain is not None:\n            if dc_gain < SPECS[\"dc_gain_min_dB\"]:\n                fails.append(f\"DC gain {dc_gain:.1f} dB < {SPECS['dc_gain_min_dB']} dB min\")\n                all_ok = False\n            log(f\"\\n  DC gain: {dc_gain:.1f} dB (min: {SPECS['dc_gain_min_dB']}, target: {SPECS['dc_gain_target_dB']}) — {'OK' if dc_gain >= SPECS['dc_gain_min_dB'] else 'FAIL'}\", report)\n\n        # UGB\n        if ugb is not None:\n            ugb_ok = SPECS[\"ugb_min_Hz\"] <= ugb <= SPECS[\"ugb_max_Hz\"]\n            if not ugb_ok:\n                fails.append(f\"UGB {ugb:.0f} Hz outside [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]\")\n                all_ok = False\n            log(f\"  UGB: {ugb:.0f} Hz (range: [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]) — {'OK' if ugb_ok else 'FAIL'}\", report)\n\n        # PM\n        if phase_ugb is not None:\n            pm = phase_ugb + 180\n            pm_ok = pm >= SPECS[\"pm_min_deg\"]\n            if not pm_ok:\n                fails.append(f\"PM {pm:.1f} deg < {SPECS['pm_min_deg']} deg\")\n                all_ok = False\n            log(f\"  Phase margin: {pm:.1f} deg (min: {SPECS['pm_min_deg']}) — {'OK' if pm_ok else 'FAIL'}\", report)\n\n    log(f\"\\n  GATE 2 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n    if fails:\n        log(f\"  FAILURES ({len(fails)}):\", report)\n        for f in fails:\n            log(f\"    - {f}\", report)\n    log(\"  \" + \"=\" * 70, report)\n\n    return all_ok\n\n\ndef gate3_dc_transient(report):\n    \"\"\"GATE 3: DC sweep and transient.\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 3: DC SWEEP & TRANSIENT (Sections 5.3, 5.4)\", report)\n    log(\"=\" * 70, report)\n\n    all_ok = True\n    fails = []\n\n    # DC sweep\n    output_dc, err = run_ngspice(\"tb_ota_dc.spice\")\n    if err:\n        log(f\"  DC: BLOCKED: {err}\", report)\n        all_ok = False\n    else:\n        vmax = parse_meas(output_dc, \"vout_max\")\n        vmin = parse_meas(output_dc, \"vout_min\")\n        if vmax is not None and vmin is not None:\n            swing = vmax - vmin\n            swing_ok = swing >= SPECS[\"output_swing_min_Vpp\"]\n            if not swing_ok:\n                fails.append(f\"Output swing {swing:.3f} Vpp < {SPECS['output_swing_min_Vpp']} Vpp\")\n                all_ok = False\n            log(f\"  Output swing: {swing:.3f} Vpp (min: {SPECS['output_swing_min_Vpp']}) — {'OK' if swing_ok else 'FAIL'}\", report)\n            log(f\"    Vout_max: {vmax:.3f} V, Vout_min: {vmin:.3f} V\", report)\n        else:\n            fails.append(\"Could not measure output swing\")\n            all_ok = False\n\n    # Transient\n    output_tran, err = run_ngspice(\"tb_ota_tran.spice\")\n    if err:\n        log(f\"  Transient: BLOCKED: {err}\", report)\n        all_ok = False\n    else:\n        t10 = parse_meas(output_tran, \"t10\")\n        t90 = parse_meas(output_tran, \"t90\")\n        if t10 is not None and t90 is not None and t90 > t10:\n            sr_Vs = 0.08 / (t90 - t10)\n            sr_mVus = sr_Vs * 1e-6 * 1e3\n            sr_ok = sr_mVus >= SPECS[\"slew_rate_min_mVus\"]\n            if not sr_ok:\n                fails.append(f\"Slew rate {sr_mVus:.2f} mV/us < {SPECS['slew_rate_min_mVus']} mV/us\")\n                all_ok = False\n            log(f\"  Slew rate: {sr_mVus:.2f} mV/us (min: {SPECS['slew_rate_min_mVus']}) — {'OK' if sr_ok else 'FAIL'}\", report)\n        else:\n            log(f\"  Slew rate: could not measure (t10={t10}, t90={t90})\", report)\n            fails.append(\"Could not measure slew rate\")\n            all_ok = False\n\n    log(f\"\\n  GATE 3 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n    if fails:\n        log(f\"  FAILURES ({len(fails)}):\", report)\n        for f in fails:\n            log(f\"    - {f}\", report)\n    log(\"  \" + \"=\" * 70, report)\n    return all_ok\n\n\ndef main():\n    attempt = increment_attempt()\n    report = []\n    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n    log(f\"\\n{'#' * 70}\", report)\n    log(f\"# VERIFICATION RUN #{attempt} — {timestamp}\", report)\n    log(f\"{'#' * 70}\", report)\n\n    # Check required files exist\n    required = [\"ota_foldcasc.spice\", \"tb_ota_op.spice\", \"sky130_minimal.lib.spice\"]\n    missing = [f for f in required if not os.path.exists(os.path.join(WORK_DIR, f))]\n    if missing:\n        log(f\"\\nMISSING FILES: {missing}\", report)\n        log(\"Cannot verify. Create these files first.\", report)\n        with open(REPORT_FILE, \"a\") as f:\n            f.write(\"\\n\".join(report) + \"\\n\")\n        sys.exit(99)\n\n    # ==================== GATE 1 ====================\n    gate1_pass, op_data = gate1_operating_point(report)\n\n    if not gate1_pass:\n        log(f\"\\n{'!' * 70}\", report)\n        log(f\"! GATE 1 FAILED — DO NOT PROCEED\", report)\n        log(f\"! Fix the operating point before running any other testbench.\", report)\n        log(f\"! See program.md Section 7 and Section 9 for troubleshooting.\", report)\n        log(f\"! This is attempt #{attempt}.\", report)\n        log(f\"{'!' * 70}\", report)\n        with open(REPORT_FILE, \"a\") as f:\n            f.write(\"\\n\".join(report) + \"\\n\")\n        sys.exit(1)\n\n    # ==================== GATE 2 ====================\n    tb_ac_exists = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_ac.spice\"))\n    if tb_ac_exists:\n        gate2_pass = gate2_ac_performance(report)\n        if not gate2_pass:\n            log(f\"\\n{'!' * 70}\", report)\n            log(f\"! GATE 2 FAILED — AC measurement broken or specs not met.\", report)\n            log(f\"! Check: is the loop properly broken? Is gain flat at low freq?\", report)\n            log(f\"! This is attempt #{attempt}.\", report)\n            log(f\"{'!' * 70}\", report)\n            with open(REPORT_FILE, \"a\") as f:\n                f.write(\"\\n\".join(report) + \"\\n\")\n            sys.exit(2)\n    else:\n        log(\"\\n  GATE 2: SKIPPED (tb_ota_ac.spice not found)\", report)\n\n    # ==================== GATE 3 ====================\n    tb_dc = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_dc.spice\"))\n    tb_tran = os.path.exists(os.path.join(WORK_DIR, \"tb_ota_tran.spice\"))\n    if tb_dc or tb_tran:\n        gate3_pass = gate3_dc_transient(report)\n        if not gate3_pass:\n            log(f\"\\n  GATE 3 FAILED — attempt #{attempt}\", report)\n            with open(REPORT_FILE, \"a\") as f:\n                f.write(\"\\n\".join(report) + \"\\n\")\n            sys.exit(3)\n    else:\n        log(\"\\n  GATE 3: SKIPPED (testbench files not found)\", report)\n\n    # ==================== ALL PASSED ====================\n    log(f\"\\n{'*' * 70}\", report)\n    log(f\"* ALL GATES PASSED — attempt #{attempt}\", report)\n    log(f\"{'*' * 70}\", report)\n\n    with open(REPORT_FILE, \"a\") as f:\n        f.write(\"\\n\".join(report) + \"\\n\")\n    sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":497,"startLine":1,"totalLines":497}}}
