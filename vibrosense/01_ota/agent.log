s ota_foldcasc\n\"\"\"\n\nTB = \"\"\"\\\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_opt.spice\"\nVdd vdd 0 dc 1.8\nVss vss 0 dc 0\nMbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1\nIbias vdd vbn dc 500n\nVbcn vbcn 0 dc 0.80\nMbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8__model W=8u L=2u nf=2\nIbp vbp 0 dc 500n\nVbcp vbcp 0 dc 0.70\nVinp vinp 0 dc 0.9\nLfb vout vinn 1T\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n.tf v(vout) Vinp\n.control\n  run\n  let cl = transfer_function\n  let A = cl / (1 - cl)\n  let A_db = 20*log(abs(A))/log(10)\n  echo \"A_db=$&A_db Vout=$&v(vout)\"\n  op\n  echo \"M2_gds=$&@m.xota.m2[gds] M4_Vds=$&@m.xota.m4[vds] M11_Id=$&@m.xota.m11[id]\"\n  quit\n.endc\n.end\n\"\"\"\n\nwith open('ota_opt.spice', 'w') as f:\n    f.write(OTA)\nwith open('opt_tb.spice', 'w') as f:\n    f.write(TB)\n\nresult = subprocess.run(['/usr/bin/ngspice', '-b', 'opt_tb.spice'],\n                      capture_output=True, text=True, timeout=60)\nfor line in (result.stdout + result.stderr).split('\\n'):\n    if 'A_db=' in line or 'M2_gds=' in line:\n        print(line)\nPYEOF","description":"Test optimizer with improved sizing","timeout":120000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":409,"cache_read_input_tokens":295858,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":409},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"01e4b3b1-6a11-48e6-b3e7-40758ef8985d","uuid":"fee3b740-ed53-4a1f-8c49-934d21fcfd97"}
