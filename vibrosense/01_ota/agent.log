ota.m10[gds]\n\n  echo \"--- M11 (NMOS tail) W=4u L=4u ---\"\n  print @m.xota.m11[id] @m.xota.m11[vgs] @m.xota.m11[vth] @m.xota.m11[vds] @m.xota.m11[vdsat] @m.xota.m11[gm] @m.xota.m11[gds]\n\n  echo \"--- M12 (PMOS bias mirror +) W=8u L=2u ---\"\n  print @m.xota.m12[id] @m.xota.m12[vgs] @m.xota.m12[vth] @m.xota.m12[vds] @m.xota.m12[vdsat] @m.xota.m12[gm] @m.xota.m12[gds]\n\n  echo \"--- M13 (PMOS bias mirror -) W=8u L=2u ---\"\n  print @m.xota.m13[id] @m.xota.m13[vgs] @m.xota.m13[vth] @m.xota.m13[vds] @m.xota.m13[vdsat] @m.xota.m13[gm] @m.xota.m13[gds]\n\n  echo \"======================================================\"\n  quit\n.endc\n\n.end\n","structuredPatch":[{"oldStart":13,"oldLines":22,"newStart":13,"newLines":25,"lines":[" Vdd vdd 0 dc {vdd_val}"," Vss vss 0 dc 0"," ","-* Bias generation for Vbn: diode-connected NMOS matching M11","-* Mbn: W=4u L=4u at 500nA sets Vbn, M11 mirrors 1:1","-Xbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8 W=4u L=4u nf=1","+* Bias generation for Vbn: diode-connected NMOS matching M11 (W=4u, L=4u)","+Mbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1"," Ibias vdd vbn dc {ibias_val}"," ","-* Vbcn: NMOS cascode bias — use ideal voltage source, tune later","-Vbcn vbcn 0 dc 0.75","+* Vbcn: NMOS cascode bias","+* Diode-connected cascode + current source mirror generates proper Vbcn","+Mbcn vbcn vbcn bcn_src 0 sky130_fd_pr__nfet_01v8__model W=4u L=0.5u nf=2","+Mbcn_src bcn_src vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=2u nf=1","+Ibcn vdd vbcn dc {ibias_val}"," ","-* Vbp: PMOS current source bias — use diode-connected PMOS matching M3","-* M3 is W=8u L=1u, M12 is W=8u L=2u. Effective parallel W/L at mid_p.","-* Use a diode ref matching M3 (W=8u L=1u)","-Xbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8 W=8u L=1u nf=2","+* Vbp: PMOS bias — diode-connected PMOS matching M3 (W=8u, L=1u)","+Mbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8__model W=8u L=1u nf=2"," Ibp vbp 0 dc 500n"," ","-* Vbcp: PMOS cascode bias — ideal voltage source","-Vbcp vb