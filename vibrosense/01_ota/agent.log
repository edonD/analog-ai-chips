voltage source\nVbcp vbcp 0 dc 1.05\n\n* Input bias at common-mode\nVinp vinp 0 dc {vcm_val}\nVinn vinn 0 dc {vcm_val}\n\n* Instantiate OTA\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\n\n* Load capacitor\nCL vout 0 10p\n\n.op\n.save all\n\n.control\n  run\n\n  echo \"\"\n  echo \"======================================================\"\n  echo \"  OPERATING POINT — VibroSense Folded-Cascode OTA\"\n  echo \"======================================================\"\n  echo \"\"\n\n  echo \"--- Bias Voltages ---\"\n  print v(vbn) v(vbcn) v(vbp) v(vbcp) v(vout)\n  echo \"\"\n\n  echo \"--- M1 (NMOS input +) W=10u L=1u ---\"\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[id]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[vgs]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[vth]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[vds]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[vdsat]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[gm]\n  print @m.xota.xm1.msky130_fd_pr__nfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M2 (NMOS input -) W=10u L=1u ---\"\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[id]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[vgs]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[vth]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[vds]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[vdsat]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[gm]\n  print @m.xota.xm2.msky130_fd_pr__nfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M3 (PMOS fold +) W=8u L=1u ---\"\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[id]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[vgs]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[vth]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[vds]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[vdsat]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[gm]\n  print @m.xota.xm3.msky130_fd_pr__pfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M4 (PMOS fold -) W=8u L=1u ---\"\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[id]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[vgs]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[vth]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[vds]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[vdsat]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[gm]\n  print @m.xota.xm4.msky130_fd_pr__pfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M5 (PMOS cascode +) W=8u L=0.5u ---\"\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[id]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[vgs]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[vth]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[vds]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[vdsat]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[gm]\n  print @m.xota.xm5.msky130_fd_pr__pfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M6 (PMOS cascode -) W=8u L=0.5u ---\"\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[id]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[vgs]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[vth]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[vds]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[vdsat]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[gm]\n  print @m.xota.xm6.msky130_fd_pr__pfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M7 (NMOS cascode +) W=4u L=0.5u ---\"\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[id]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[vgs]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[vth]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[vds]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[vdsat]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[gm]\n  print @m.xota.xm7.msky130_fd_pr__nfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M8 (NMOS cascode -) W=4u L=0.5u ---\"\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[id]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[vgs]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[vth]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[vds]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[vdsat]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[gm]\n  print @m.xota.xm8.msky130_fd_pr__nfet_01v8[gds]\n  echo \"\"\n\n  echo \"--- M9 (NMOS current