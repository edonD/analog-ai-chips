fet_01v8 W={W7} L={L7} nf={nf7}\n* M8: drain=vout, gate=vbcn, source=src_n8, body=vss\nM8 vout vbcn src_n8 vss sky130_fd_pr__nfet_01v8 W={W8} L={L8} nf={nf8}\n\n* --- NMOS Current Source Transistors ---\n* M9: drain=src_n7, gate=vbn, source=vss, body=vss\nM9 src_n7 vbn vss vss sky130_fd_pr__nfet_01v8 W={W9} L={L9} nf={nf9}\n* M10: drain=src_n8, gate=vbn, source=vss, body=vss\nM10 src_n8 vbn vss vss sky130_fd_pr__nfet_01v8 W={W10} L={L10} nf={nf10}\n\n.ends ota_foldcasc\n"}}
