at] @m.xota.m12[gm] @m.xota.m12[gds]","-  print @m.xota.m12[region]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[id]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[vgs]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[vth]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[vds]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[vdsat]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[gm]","+  print @m.xota.xm12.msky130_fd_pr__pfet_01v8[gds]","   echo \"\""," ","   echo \"--- M13 (PMOS bias mirror -) W=8u L=2u ---\"","-  print @m.xota.m13[id] @m.xota.m13[vgs] @m.xota.m13[vth]","-  print @m.xota.m13[vds] @m.xota.m13[vdsat] @m.xota.m13[gm] @m.xota.m13[gds]","-  print @m.xota.m13[region]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[id]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[vgs]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[vth]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[vds]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[vdsat]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[gm]","+  print @m.xota.xm13.msky130_fd_pr__pfet_01v8[gds]","   echo \"\""," ","   echo \"======================================================\""]}],"originalFile":"* ============================================================\n* TB07: Operating Point Verification — VibroSense OTA\n* ============================================================\n* Purpose: Print Vgs, Vth, Vds, Vdsat, Id, gm, gds, region\n*          for ALL 13 transistors and verify saturation.\n* ============================================================\n\n.lib \"/home/ubuntu/pdk/volare/sky130/versions/6d4d11780c40b20ee63cc98e645307a9bf2b2ab8/sky130A/libs.tech/ngspice/sky130.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\n.param vdd_val = 1.8\n.param ibias_val = 500n\n.param vcm_val = 0.9\n\n* Supply\nVdd vdd 0 dc {vdd_val}\nVss vss 0 dc 0\n\n* Bias generation: diode-connected NMOS sets Vbn from 500nA\n* Mbn matches M11 (W=4u, L=4u) for 1:1 mirror of tail current\nMbn vbn vbn vss vss sky130_fd_pr__nfet_01v8 W=4u L=4u nf=1\nIbias vdd vbn dc {ibias_val}\n\n* NMOS cascode bias: Vbcn\n* Use a diode-connected cascode stack to generate proper Vbcn\n* Vbcn should be ~ Vbn + Vgs_cascode to keep M7/M8 in saturation\nMbcn vbcn vbcn src_bcn vss sky130_fd_pr__nfet_01v8 W=4u L=0.5u nf=2\nMbcn_src src_bcn vbn vss vss sky130_fd_pr__nfet_01v8 W=4u L=2u nf=1\nIbcn vdd vbcn dc {ibias_val}\n\n* PMOS bias: diode-connected PMOS sets Vbp\n* Mbp matches M12/M13 (W=8u, L=2u) + M3/M4 self-cascode\nMbp2 src_bp vbp vdd vdd sky130_fd_pr__pfet_01v8 W=8u L=2u nf=1\nMbp src_bp2 vbp src_bp vdd sky130_fd_pr__pfet_01v8 W=8u L=1u nf=2\nIbp src_bp2 vss dc 500n\n\n* PMOS cascode bias: Vbcp\n* Diode-connected PMOS cascode to generate Vbcp\nMbcp vbcp vbcp src_bcp vdd sky130_fd_pr__pfet_01v8 W=8u L=0.5u nf=2\nMbcp_src src_bcp vbp src_bcp2 vdd sky130_fd_pr__pfet_01v8 W=8u L=2u nf=1\nMbcp_src2 src_bcp3 vbp src_bcp2 vdd sky130_fd_pr__pfet_01v8 W=8u L=1u nf=2\nIbcp src_bcp3 vss dc 500n\n\n* Input bias at common-mode voltage\nVinp vinp 0 dc {vcm_val}\nVinn vinn 0 dc {vcm_val}\n\n* Instantiate OTA\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\n\n* Load capacitor\nCL vout 0 10p\n\n.op\n.save all\n\n.control\n  run\n\n  echo \"======================================================\"\n  echo \"  OPERATING POINT RESULTS - VibroSense Folded-Cascode\"\n  echo \"======================================================\"\n  echo \"\"\n\n  echo \"--- Bias Voltages ---\"\n  print vbn vbcn vbp vbcp v(vout)\n  echo \"\"\n\n  echo \"--- M1 (NMOS input +) W=10u L=1u ---\"\n  print @m.xota.m1[id] @m.xota.m1[vgs] @m.xota.m1[vth]\n  print @m.xota.m1[vds] @m.xota.m1[vdsat] @m.xota.m1[gm] @m.xota.m1[gds]\n  print @m.xota.m1[region]\n  echo \"\"\n\n  echo \"--- M2 (NMOS input -) W=10u L=1u ---\"\n  print @m.xota.m2[id] @m.xota.m2[vgs] @m.xota.m2[vth]\n  print @m.xota.m2[vds] @m.xota.m2[vdsat] @m.xota.m2[gm] @m.xota.m2[gds]\n  print @m.xota.m2[region]\n  echo \"\"\n\n  echo \"--- M3 (PMOS fold +) W=8u L=1u ---\"\n  print @m.xota.m3[id] @m.xota.m3[vgs] @m.xota.m3[vth]\n  print @m.xota.m3[vds] @m.xota.m3[vdsat] @m.xota.m3[gm] @m.xota.m3[gds]\n  print @m.xota.m3[region]\n  echo \"\"\n\n  echo \"--- M4 (PMOS fold -) W=8u L=1u ---\"\n  print @m.xota.m4[id] @m.xota.m4[vgs] @m.xota.m4[vth]\n  print @m.xota.m4[vds] @m.xota.m4[vdsat] @m.xota.m4[gm] @m.xota.m4[gds]\n  print @m.xota.m4[region]\n  echo \"\"\n\n  echo \"--- M5 (PMOS cascode +) W=8u L=0.5u ---\"\n  print @m.xota.m5[id] @m.xota.m5[vgs] @m.xota.m5[vth]\n  print @m.xota.m5[vds] @m.xota.m5[vdsat] @m.xota.m5[gm] @m.xota.m5[gds]\n  print @m.xota.m5[region]\n  echo \"\"\n\n  echo \"--- M6 (PMOS cascode -) W=8u L=0.5u ---\"\n  print @m.xota.m6[id] @m.xota.m6[vgs] @m.xota.m6[vth]\n  print @m.xota.m6[vds] @m.xota.m6[vdsat] @m.xota.m6[gm] @m.xota.m6[gds]\n  print @m.xota.m6[region]\n  echo \"\"\n\n  echo \"--- M7 (NMOS cascode +) W=4u L=0.5u ---\"\n  print @m.xota.m7[id] @m.xota.m7[vgs] @m.xota.m7[vth]\n  print @m.xota.m7[vds] @m.xota.m7[vdsat] @m.xota.m7[gm] @m.xota.m7[gds]\n  print @m.xota.m7[region]\n  echo \"\"\n\n  echo \"--- M8 (NMOS cascode -) W=4u L=0.5u ---\"\n  print @m.xota.m8[id] @m.xota.m8[vgs] @m.xota.m8[vth]\n  print @m.xota.m8[vds] @m.xota.m8[vdsat] @m.xota.m8[gm] @m.xota.m8[gds]\n  print @m.xota.m8[region]\n  echo \"\"\n\n  echo \"--- M9 (NMOS current src +) W=4u L=2u ---\"\n  print @m.xota.m9[id] @m.xota.m9[vgs] @m.xota.m9[vth]\n  print @m.xota.m9[vds] @m.xota.m9[vdsat] @m.xota.m9[gm] @m.xota.m9[gds]\n  print @m.xota.m9[region]\n  echo \"\"\n\n  echo \"--- M10 (NMOS current src -) W=4u L=2u ---\"\n  print @m.xota.m10[id] @m.xota.m10[vgs] @m.xota.m10[vth]\n  print @m.xota.m10[vds] @m.xota.m10[vdsat] @m.xota.m10[gm] @m.xota.m10[gds]\n  print @m.xota.m10[region]\n  echo \"\"\n\n  echo \"--- M11 (NMOS tail) W=4u L=4u ---\"\n  print @m.xota.m11[id] @m.xota.m11[vgs] @m.xota.m11[vth]\n  print @m.xota.m11[vds] @m.xota.m11[vdsat] @m.xota.m11[gm] @m.xota.m11[gds]\n  print @m.xota.m11[region]\n  echo \"\"\n\n  echo \"--- M12