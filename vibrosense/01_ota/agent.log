vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\nXM4q  fold_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\nXM4r  fold_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\nXM4s  fold_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\nXM4t  fold_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\n\n* PMOS Bias Mirrors\nXM12 fold_p vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\nXM13 fold_n vbp vdd vdd sky130_fd_pr__pfet_01v8 W=0.42u L=20u nf=1\n\n* PMOS Cascode (W=0.42u L=2u)\nXM5  cas_p vbcp fold_p vdd sky130_fd_pr__pfet_01v8 W=0.42u L=2u nf=1\nXM6  vout  vbcp fold_n vdd sky130_fd_pr__pfet_01v8 W=0.42u L=2u nf=1\n\n* NMOS Cascode (W=2u L=14u for low 1/f noise)\nXM7  cas_p vbcn src7 vss sky130_fd_pr__nfet_01v8 W=2u L=14u nf=1\nXM8  vout  vbcn src8 vss sky130_fd_pr__nfet_01v8 W=2u L=14u nf=1\n\n* NMOS Current Sources (W=2.15u L=14u — matched L with tail)\nXM9  src7 vbn vss vss sky130_fd_pr__nfet_01v8 W=2.15u L=14u nf=1\nXM10 src8 vbn vss vss sky130_fd_pr__nfet_01v8 W=2.15u L=14u nf=1\n\n.ends ota_foldcasc\n","structuredPatch":[{"oldStart":4,"oldLines":9,"newStart":4,"newLines":9,"lines":[" "," .subckt ota_foldcasc vinp vinn vout vdd vss vbn vbcn vbp vbcp"," ","-* Input Pair (W=5u L=14u nf=4 — multi-finger for low gate resistance noise)","-XM1 fold_p vinp tail vss sky130_fd_pr__nfet_01v8 W=5u L=14u nf=4","-XM2 fold_n vinn tail vss sky130_fd_pr__nfet_01v8 W=5u L=14u nf=4","+* Input Pair (W=5u L=14u for low 1/f noise, Vov>50mV)","+XM1 fold_p vinp tail vss sky130_fd_pr__nfet_01v8 W=5u L=14u nf=1","+XM2 fold_n vinn tail vss sky130_fd_pr__nfet_01v8 W=5u L=14u nf=1"," "," * Tail (500nA) — long L for high output impedance"," XM11 tail vbn vss vss sky130_fd_pr__nfet_01v8 W=3.8u L=14u nf=1"]}],"userModified":false,"replaceAll":false}}
