anged else 'no changes'}\")","+            print(f\"{dev}__{corner}: {'MODIFIED' if changed else 'unchanged'}\")"," ","-        # Corner file","+        # Corner file (parameter values, no mismatch)","         src = f\"{PDK}/sky130_fd_pr__{dev}__{corner}.corner.spice\"","         dst = f\"{OUT}/sky130_fd_pr__{dev}__{corner}.corner.spice\"","         if os.path.exists(src):","             shutil.copy(src, dst)"," "," # Verify","-test_file = f\"{OUT}/sky130_fd_pr__nfet_01v8__tt.pm3.spice\"","-with open(test_file) as f:","-    content = f.read()","-mc_count = content.lower().count('mc_mm_switch')","-toxe_lines = [l for l in content.split('\\n') if 'toxe' in l.lower() and 'toxe_slope' not in l.lower() and 'toxe_mult' not in l.lower()]","-print(f\"\\nVerification:\")","-print(f\"MC_MM_SWITCH occurrences remaining: {mc_count}\")","-print(f\"toxe lines sample: {toxe_lines[:3]}\")","+print(\"\\nVerification:\")","+for dev in devices:","+    test_file = f\"{OUT}/sky130_fd_pr__{dev}__tt.pm3.spice\"","+    with open(test_file) as f:","+        content = f.read()","+    mc_count = content.upper().count('MC_MM_SWITCH')","+    # Show toxe lines","+    for line in content.split('\\n'):","+        if '+ toxe =' in line.lower():","+            print(f\"  {dev}: {line.strip()}\")","+            break","+    print(f\"  {dev}: MC_MM_SWITCH occurrences = {mc_count}\")"]}],"originalFile":"#!/usr/bin/env python3\n\"\"\"Preprocess SKY130 model files to remove MC mismatch expressions for ngspice.\"\"\"\nimport re\nimport os\nimport shutil\n\nPDK = \"/home/ubuntu/pdk/sky130A/libs.ref/sky130_fd_pr/spice\"\nOUT = \"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/models\"\nos.makedirs(OUT, exist_ok=True)\n\n# Pattern: +MC_MM_SWITCH*AGAUSS(0,1.0,1)*(expression with nested parens)\n# We need to match the entire mismatch term and replace with 0\nMC_PATTERN = re.compile(\n    r'\\+\\s*MC_MM_SWITCH\\s*\\*\\s*AGAUSS\\s*\\([^)]*\\)\\s*\\*\\s*\\([^)]*(?:\\([^)]*\\))*[^)]*\\)',\n    re.IGNORECASE\n)\n\ndef process_file(src, dst):\n    with open(src, 'r') as f:\n        content = f.read()\n    # Replace mismatch terms with +0\n    content_out = MC_PATTERN.sub('+0', content)\n    with open(dst, 'w') as f:\n        f.write(content_out)\n    changed = content != content_out\n    return changed\n\ncorners = ['tt', 'ss', 'ff', 'sf', 'fs']\ndevices = ['nfet_01v8', 'pfet_01v8']\n\nfor dev in devices:\n    # Base pm3 file\n    src = f\"{PDK}/sky130_fd_pr__{dev}.pm3.spice\"\n    dst = f\"{OUT}/sky130_fd_pr__{dev}.pm3.spice\"\n    shutil.copy(src, dst)\n    print(f\"Copied base: {dev}\")\n\n    for corner in corners:\n        # Corner pm3 file (has mismatch expressions)\n        src = f\"{PDK}/sky130_fd_pr__{dev}__{corner}.pm3.spice\"\n        dst = f\"{OUT}/sky130_fd_pr__{dev}__{corner}.pm3.spice\"\n        if os.path.exists(src):\n            changed = process_file(src, dst)\n            print(f\"Processed {dev}__{corner}: {'MODIFIED' if changed else 'no changes'}\")\n\n        # Corner file\n        src = f\"{PDK}/sky130_fd_pr__{dev}__{corner}.corner.spice\"\n        dst = f\"{OUT}/sky130_fd_pr__{dev}__{corner}.corner.spice\"\n        if os.path.exists(src):\n            shutil.copy(src, dst)\n\n# Verify\ntest_file = f\"{OUT}/sky130_fd_pr__nfet_01v8__tt.pm3.spice\"\nwith open(test_file) as f:\n    content = f.read()\nmc_count = content.lower().count('mc_mm_switch')\ntoxe_lines = [l for l in content.split('\\n') if 'toxe' in l.lower() and 'toxe_slope' not in l.lower() and 'toxe_mult' not in l.lower()]\nprint(f\"\\nVerification:\")\nprint(f\"MC_MM_SWITCH occurrences remaining: {mc_count}\")\nprint(f\"toxe lines sample: {toxe_lines[:3]}\")\n"}}
