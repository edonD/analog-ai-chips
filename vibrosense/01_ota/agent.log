&gain_10hz dB\"","   echo \"Gain at 100Hz: $&gain_100hz dB\"","   echo \"Gain at 1kHz: $&gain_1k dB\"","   echo \"Gain at 10kHz: $&gain_10k dB\"","   echo \"Gain at 100kHz: $&gain_100k dB\""," ","-  * Phase at spot frequencies","+  * Phase","   meas ac ph_1hz FIND vp(vout) AT=1","   meas ac ph_1k FIND vp(vout) AT=1000","-  meas ac ph_10k FIND vp(vout) AT=10000","+  meas ac ph_100k FIND vp(vout) AT=100000","   echo \"Phase at 1Hz: $&ph_1hz deg\"","   echo \"Phase at 1kHz: $&ph_1k deg\"","-  echo \"Phase at 10kHz: $&ph_10k deg\"","+  echo \"Phase at 100kHz: $&ph_100k deg\""," ","+  * Max gain and UGB","+  meas ac gain_db MAX vdb(vout)","+  meas ac ugb WHEN vdb(vout)=0 FALL=1","+","+  echo \"\"","+  echo \"MAX Gain: $&gain_db dB\"","+  echo \"UGB: $&ugb Hz\"","+","+  * Phase margin if UGB found","+  meas ac phase_ugb FIND vp(vout) AT=ugb","+  echo \"Phase at UGB: $&phase_ugb deg\"","+","   echo \"======================================================\""," ","   wrdata bode_data vdb(vout) vp(vout)"]}],"originalFile":"* ============================================================\n* TB01: AC Analysis — VibroSense OTA\n* Method: Unity-gain with AC injection for loop gain\n* ============================================================\n\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\n.param vdd_val = 1.8\n.param vcm_val = 0.9\n\nVdd vdd 0 dc {vdd_val}\nVss vss 0 dc 0\n\n* Bias generation\nMbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1\nIbias vdd vbn dc 500n\nVbcn vbcn 0 dc 0.80\nMbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8__model W=8u L=1u nf=2\nIbp vbp 0 dc 500n\nVbcp vbcp 0 dc 0.85\n\n* Input common-mode\nVinp vinp 0 dc {vcm_val} ac 1\n\n* DC feedback through large resistor, AC open loop\n* Rfb provides DC feedback: vout→vinn at DC, but negligible AC feedback\n* since Rfb >> Zout of OTA\nRfb vout vinn 100G\n\n* Instantiate OTA\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n\n.ac dec 100 1 100Meg\n\n.control\n  run\n\n  echo \"\"\n  echo \"======================================================\"\n  echo \"  AC OPEN-LOOP — VibroSense OTA\"\n  echo \"======================================================\"\n\n  * DC operating point\n  echo \"--- DC Point ---\"\n  * Gain\n  meas ac gain_db MAX vdb(vout)\n  print gain_db\n\n  * UGB\n  meas ac ugb WHEN vdb(vout)=0 FALL=1\n  print ugb\n\n  * Phase at UGB\n  meas ac phase_at_ugb FIND vp(vout) AT=ugb\n  print phase_at_ugb\n\n  * Phase margin\n  let pm = phase_at_ugb + 180\n  print pm\n\n  * Gain at -180 degrees\n  meas ac freq_180 WHEN vp(vout)=-180 FALL=1\n  meas ac gain_180 FIND vdb(vout) AT=freq_180\n  let gm_db = -gain_180\n  print gm_db\n\n  * Some spot frequencies\n  meas ac gain_1hz FIND vdb(vout) AT=1\n  meas ac gain_100hz FIND vdb(vout) AT=100\n  meas ac gain_1k FIND vdb(vout) AT=1000\n  meas ac gain_10k FIND vdb(vout) AT=10000\n  meas ac gain_100k FIND vdb(vout) AT=100000\n  echo \"\"\n  echo \"Gain at 1Hz: $&gain_1hz dB\"\n  echo \"Gain at 100Hz: $&gain_100hz dB\"\n  echo \"Gain at 1kHz: $&gain_1k dB\"\n  echo \"Gain at 10kHz: $&gain_10k dB\"\n  echo \"Gain at 100kHz: $&gain_100k dB\"\n\n  * Phase at spot frequencies\n  meas ac ph_1hz FIND vp(vout) AT=1\n  meas ac ph_1k FIND vp(vout) AT=1000\n  meas ac ph_10k FIND vp(vout) AT=10000\n  echo \"Phase at 1Hz: $&ph_1hz deg\"\n  echo \"Phase at 1kHz: $&ph_1k deg\"\n  echo \"Phase at 10kHz: $&ph_10k deg\"\n\n  echo \"======================================================\"\n\n  wrdata bode_data vdb(vout) vp(vout)\n\n  quit\n.endc\n\n.end\n"}}
