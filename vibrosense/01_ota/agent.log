{"type":"system","subtype":"task_progress","task_id":"a747190c2db75e60d","tool_use_id":"toolu_01EZLvWR7y8upt6isXr71TxJ","description":"Writing tb_ota_psrr.spice","usage":{"total_tokens":22031,"tool_uses":10,"duration_ms":101030},"last_tool_name":"Write","uuid":"52bdb661-d97c-4978-9bb8-fc40b0696a13","session_id":"01e4b3b1-6a11-48e6-b3e7-40758ef8985d"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01EzRobZuUPzuooPJ6HJ4YWU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CB44xP4PizkghCp3xpqy1M","name":"Write","input":{"file_path":"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/tb_ota_psrr.spice","content":"* PSRR Analysis - VibroSense OTA\n* Power Supply Rejection Ratio = A_diff(dB) - A_vdd_to_out(dB)\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\n* VDD with AC perturbation for PSRR measurement\nVdd vdd 0 dc 1.8 ac 1\nVss vss 0 dc 0\nMbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1\nIbias vdd vbn dc 500n\nVbcn vbcn 0 dc 0.80\nMbp vbp vbp vdd vdd sky130_fd_pr__pfet_01v8__model W=8u L=1u nf=2\nIbp vbp 0 dc 500n\nVbcp vbcp 0 dc 0.70\n\n* Both inputs at Vcm for DC bias; no differential AC signal\nVinp vinp 0 dc 0.9\n* Unity-gain feedback for DC operating point stability\nLfb vout vinn 1T\n\nXota vinp vinn vout vdd vss vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n\n* Sweep from 1Hz to 100MHz\n.ac dec 100 1 100Meg\n\n.control\n  run\n\n  * VDD-to-output gain in dB (this is what we want to reject)\n  * Lower is better: PSRR = open-loop gain - this number\n  let vdd_to_out_db = vdb(vout)\n\n  * Spot values of VDD-to-output rejection\n  meas ac rej_1hz   FIND vdb(vout) AT=1\n  meas ac rej_1k    FIND vdb(vout) AT=1000\n  meas ac rej_10k   FIND vdb(vout) AT=10000\n  meas ac rej_100k  FIND vdb(vout) AT=100000\n  meas ac rej_1meg  FIND vdb(vout) AT=1000000\n\n  * Peak (worst-case) rejection\n  meas ac rej_peak MAX vdb(vout)\n\n  echo \"\"\n  echo \"======================================================\"\n  echo \"  PSRR Analysis Results\"\n  echo \"  (VDD AC perturbation -> V(vout); lower = better rejection)\"\n  echo \"  PSRR(f) = A_diff(f) - Vout/Vdd(f) [dB]\"\n  echo \"======================================================\"\n  echo \"VDD-to-output gain (raw, not subtracted from diff gain):\"\n  echo \"  1 Hz:    $&rej_1hz dB\"\n  echo \"  1 kHz:   $&rej_1k dB\"\n  echo \"  10 kHz:  $&rej_10k dB\"\n  echo \"  100 kHz: $&rej_100k dB\"\n  echo \"  1 MHz:   $&rej_1meg dB\"\n  echo \"\"\n  echo \"Peak (worst-case) VDD-to-output gain: $&rej_peak dB\"\n  echo \"\"\n  echo \"Note: PSRR = diff_gain_dB - vdd_to_output_gain_dB\"\n  echo \"      Run tb_ota_ac.spice for diff gain, then subtract.\"\n  echo \"======================================================\"\n\n  wrdata psrr_data vdb(vout) vp(vout)\n  quit\n.endc\n.end\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":819,"cache_read_input_tokens":20966,"cache_creation":{"ephemeral_5m_input_tokens":819,"ephemeral_1h_input_tokens":0},"output_tokens":58,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01EZLvWR7y8upt6isXr71TxJ","session_id":"01e4b3b1-6a11-48e6-b3e7-40758ef8985d","uuid":"062953a1-1da9-44b4-b423-3201d4f2c5bb"}
