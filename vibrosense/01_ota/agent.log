ac gain_1k FIND vdb(vout) AT=1000\n  meas ac gain_10k FIND vdb(vout) AT=10000\n  meas ac gain_100k FIND vdb(vout) AT=100000\n\n  echo \"Gain at 0.1Hz: $&gain_01hz dB\"\n  echo \"Gain at 1Hz: $&gain_1hz dB\"\n  echo \"Gain at 10Hz: $&gain_10hz dB\"\n  echo \"Gain at 100Hz: $&gain_100hz dB\"\n  echo \"Gain at 1kHz: $&gain_1k dB\"\n  echo \"Gain at 10kHz: $&gain_10k dB\"\n  echo \"Gain at 100kHz: $&gain_100k dB\"\n\n  * Phase\n  meas ac ph_1hz FIND vp(vout) AT=1\n  meas ac ph_1k FIND vp(vout) AT=1000\n  meas ac ph_100k FIND vp(vout) AT=100000\n  echo \"Phase at 1Hz: $&ph_1hz deg\"\n  echo \"Phase at 1kHz: $&ph_1k deg\"\n  echo \"Phase at 100kHz: $&ph_100k deg\"\n\n  * Max gain and UGB\n  meas ac gain_db MAX vdb(vout)\n  meas ac ugb WHEN vdb(vout)=0 FALL=1\n\n  echo \"\"\n  echo \"MAX Gain: $&gain_db dB\"\n  echo \"UGB: $&ugb Hz\"\n\n  * Phase margin if UGB found\n  meas ac phase_ugb FIND vp(vout) AT=ugb\n  echo \"Phase at UGB: $&phase_ugb deg\"\n\n  echo \"======================================================\"\n\n  wrdata bode_data vdb(vout) vp(vout)\n\n  quit\n.endc\n\n.end\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":7,"lines":[" * ============================================================","-* TB01: AC Analysis — VibroSense OTA","-* Method: Unity-gain with AC injection for loop gain","+* TB01: AC Open-Loop Analysis — VibroSense OTA","+* Method: Lfb (1GH) sets DC OP via unity-gain feedback,","+*         AC open-loop (Lfb is high-Z at signal freqs)"," * ============================================================"," "," .lib \"sky130_minimal.lib.spice\" tt"]},{"oldStart":12,"oldLines":7,"newStart":13,"newLines":7,"lines":[" Vdd vdd 0 dc {vdd_val}"," Vss vss 0 dc 0"," ","-* Bias generation","+* Bias"," Mbn vbn vbn 0 0 sky130_fd_pr__nfet_01v8__model W=4u L=4u nf=1"," Ibias vdd vbn dc 500n"," Vbcn vbcn 0 dc 0.80"]},{"oldStart":20,"oldLines":73,"newStart":21,"newLines":66,"lines":[" Ibp vbp 0 dc 500n"," Vbcp vbcp 0 dc 0.85"," ","-* Input co