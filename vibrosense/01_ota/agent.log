{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015XiscsYV2QZdexZvDT3rAZ","type":"tool_result","content":"   100→        return None, \"TIMEOUT: ngspice took > 300s\"\n   101→    except Exception as e:\n   102→        return None, f\"CRASH: {e}\"\n   103→\n   104→\n   105→def parse_op_param(output, device, param):\n   106→    \"\"\"Extract a parameter value like @m.xota.m1[vgs] from ngspice output.\"\"\"\n   107→    pattern = rf'@m\\.xota\\.{device}\\[{param}\\]\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n   108→    match = re.search(pattern, output, re.IGNORECASE)\n   109→    if match:\n   110→        return float(match.group(1))\n   111→    return None\n   112→\n   113→\n   114→def parse_meas(output, name):\n   115→    \"\"\"Extract a .meas result by name.\"\"\"\n   116→    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n   117→    match = re.search(pattern, output, re.IGNORECASE)\n   118→    if match:\n   119→        return float(match.group(1))\n   120→    return None\n   121→\n   122→\n   123→def parse_all_meas(output, name):\n   124→    \"\"\"Extract ALL occurrences of a .meas result by name.\"\"\"\n   125→    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n   126→    return [float(m) for m in re.findall(pattern, output, re.IGNORECASE)]\n   127→\n   128→\n   129→def increment_attempt():\n   130→    \"\"\"Track how many verification attempts have been made.\"\"\"\n   131→    count = 0\n   132→    if os.path.exists(ATTEMPT_COUNT_FILE):\n   133→        with open(ATTEMPT_COUNT_FILE) as f:\n   134→            try:\n   135→                count = int(f.read().strip())\n   136→            except:\n   137→                count = 0\n   138→    count += 1\n   139→    with open(ATTEMPT_COUNT_FILE, \"w\") as f:\n   140→        f.write(str(count))\n   141→    return count\n   142→\n   143→\n   144→def gate1_operating_point(report):\n   145→    \"\"\"GATE 1: Operating point verification (Section 7).\"\"\"\n   146→    log(\"\\n\" + \"=\" * 70, report)\n   147→    log(\"GATE 1: OPERATING POINT VERIFICATION (Section 7 — MANDATORY)\", report)\n   148→    log(\"=\" * 70, report)\n   149→\n   150→    output, err = run_ngspice(\"tb_ota_op.spice\")\n   151→    if err:\n   152→        log(f\"  BLOCKED: {err}\", report)\n   153→        return False, {}\n   154→\n   155→    # Extract all 13 transistors\n   156→    devices = {\n   157→        \"m1\":  {\"type\": \"nmos\", \"role\": \"input+\",      \"signal\": True},\n   158→        \"m2\":  {\"type\": \"nmos\", \"role\": \"input-\",       \"signal\": True},\n   159→        \"m3\":  {\"type\": \"pmos\", \"role\": \"fold+\",        \"signal\": False},\n   160→        \"m4\":  {\"type\": \"pmos\", \"role\": \"fold-\",        \"signal\": False},\n   161→        \"m5\":  {\"type\": \"pmos\", \"role\": \"cascode+\",     \"signal\": False, \"cascode\": True},\n   162→        \"m6\":  {\"type\": \"pmos\", \"role\": \"cascode-\",     \"signal\": False, \"cascode\": True},\n   163→        \"m7\":  {\"type\": \"nmos\", \"role\": \"cascode+\",     \"signal\": True,  \"cascode\": True},\n   164→        \"m8\":  {\"type\": \"nmos\", \"role\": \"cascode-\",     \"signal\": True,  \"cascode\": True},\n   165→        \"m9\":  {\"type\": \"nmos\", \"role\": \"current_src+\", \"signal\": False},\n   166→        \"m10\": {\"type\": \"nmos\", \"role\": \"current_src-\", \"signal\": False},\n   167→        \"m11\": {\"type\": \"nmos\", \"role\": \"tail\",         \"signal\": False},\n   168→        \"m12\": {\"type\": \"pmos\", \"role\": \"bias_mirror+\", \"signal\": False},\n   169→        \"m13\": {\"type\": \"pmos\", \"role\": \"bias_mirror-\", \"signal\": False},\n   170→    }\n   171→\n   172→    params = [\"vgs\", \"vth\", \"vds\", \"vdsat\", \"id\", \"gm\", \"gds\"]\n   173→    op_data = {}\n   174→    all_ok = True\n   175→    fails = []\n   176→\n   177→    for dev_name, dev_info in devices.items():\n   178→        op_data[dev_name] = {}\n   179→        for p in params:\n   180→            val = parse_op_param(output, dev_name, p)\n   181→            op_data[dev_name][p] = val\n   182→\n   183→    # Extract Vout\n   184→    vout_match = re.search(r'v\\(vout\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)', output)\n   185→    vout = float(vout_match.group(1)) if vout_match else None\n   186→\n   187→    # Print operating point table\n   188→    log(\"\\n  Device  | Type | Role          | Id(nA)  | Vgs(V) | Vth(V) | Vov(mV) | Vds(V) | Vdsat(V) | gm(uS) | gds(nS) | Status\", report)\n   189→    log(\"  \" + \"-\" * 120, report)\n   190→\n   191→    for dev_name, dev_info in devices.items():\n   192→        d = op_data[dev_name]\n   193→        if d[\"vgs\"] is None:\n   194→            log(f\"  {dev_name:7s} | COULD NOT EXTRACT — ngspice output parse failed\", report)\n   195→            fails.append(f\"{dev_name}: no data extracted\")\n   196→            all_ok = False\n   197→            continue\n   198→\n   199→        vgs = d[\"vgs\"]\n   200→        vth = d[\"vth\"]\n   201→        vds = d[\"vds\"]\n   202→        vdsat = d[\"vdsat\"]\n   203→        id_val = d[\"id\"]\n   204→        gm = d[\"gm\"]\n   205→        gds_val = d[\"gds\"]\n   206→\n   207→        # Compute Vov\n   208→        if dev_info[\"type\"] == \"pmos\":\n   209→            vov_mV = (abs(vgs) - abs(vth)) * 1000  # Vsg - |Vth|\n   210→        else:\n   211→            vov_mV = (vgs - vth) * 1000  # Vgs - Vth\n   212→\n   213→        status = \"OK\"\n   214→        issues = []\n   215→\n   216→        # Check 1: PMOS Vov > 150mV\n   217→        if dev_info[\"type\"] == \"pmos\":\n   218→            if vov_mV < SPECS[\"pmos_vov_min_mV\"]:\n   219→                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['pmos_vov_min_mV']}mV\")\n   220→\n   221→        # Check 2: NMOS signal path Vov > 50mV\n   222→        if dev_info[\"type\"] == \"nmos\" and dev_info.get(\"signal\", False):\n   223→            if vov_mV < SPECS[\"nmos_signal_vov_min_mV\"]:\n   224→                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['nmos_signal_vov_min_mV']}mV\")\n   225→\n   226→        # Check 3: Cascode headroom\n   227→        if dev_info.get(\"cascode\", False):\n   228→            headroom_mV = (abs(vds) - abs(vdsat)) * 1000\n   229→            if headroom_mV < SPECS[\"cascode_headroom_mV\"]:\n   230→                issues.append(f\"headroom={headroom_mV:.0f}mV < {SPECS['cascode_headroom_mV']}mV\")\n   231→\n   232→        # Check 4: Triode detection (|Vds| < |Vdsat|)\n   233→        if abs(vds) < abs(vdsat):\n   234→            issues.append(f\"TRIODE: |Vds|={abs(vds)*1000:.0f}mV < |Vdsat|={abs(vdsat)*1000:.0f}mV\")\n   235→\n   236→        if issues:\n   237→            status = \"FAIL: \" + \"; \".join(issues)\n   238→            fails.append(f\"{dev_name}: {'; '.join(issues)}\")\n   239→            all_ok = False\n   240→\n   241→        log(f\"  {dev_name:7s} | {dev_info['type']:4s} | {dev_info['role']:13s} | {abs(id_val)*1e9:7.1f} | {vgs:+.4f} | {vth:+.4f} | {vov_mV:+7.1f} | {vds:+.4f} | {vdsat:+.5f} | {gm*1e6:6.3f}  | {gds_val*1e9:7.1f}  | {status}\", report)\n   242→\n   243→    # Check 5: Tail current accuracy\n   244→    id_m11 = op_data[\"m11\"][\"id\"]\n   245→    if id_m11 is not None:\n   246→        tail_err = abs(abs(id_m11) * 1e9 - SPECS[\"tail_current_nA\"])\n   247→        if tail_err > SPECS[\"tail_current_tol_nA\"]:\n   248→            fails.append(f\"M11 tail current: {abs(id_m11)*1e9:.1f}nA, error={tail_err:.1f}nA > {SPECS['tail_current_tol_nA']}nA\")\n   249→            all_ok = False"}]},"parent_tool_use_id":null,"session_id":"dc3cf414-60b5-4244-9a30-3b9794da6520","uuid":"1332ca91-b337-4a1c-b622-42762a218b64","timestamp":"2026-03-23T10:48:26.846Z","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/verify_design.py","content":"        return None, \"TIMEOUT: ngspice took > 300s\"\n    except Exception as e:\n        return None, f\"CRASH: {e}\"\n\n\ndef parse_op_param(output, device, param):\n    \"\"\"Extract a parameter value like @m.xota.m1[vgs] from ngspice output.\"\"\"\n    pattern = rf'@m\\.xota\\.{device}\\[{param}\\]\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    match = re.search(pattern, output, re.IGNORECASE)\n    if match:\n        return float(match.group(1))\n    return None\n\n\ndef parse_meas(output, name):\n    \"\"\"Extract a .meas result by name.\"\"\"\n    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    match = re.search(pattern, output, re.IGNORECASE)\n    if match:\n        return float(match.group(1))\n    return None\n\n\ndef parse_all_meas(output, name):\n    \"\"\"Extract ALL occurrences of a .meas result by name.\"\"\"\n    pattern = rf'{name}\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)'\n    return [float(m) for m in re.findall(pattern, output, re.IGNORECASE)]\n\n\ndef increment_attempt():\n    \"\"\"Track how many verification attempts have been made.\"\"\"\n    count = 0\n    if os.path.exists(ATTEMPT_COUNT_FILE):\n        with open(ATTEMPT_COUNT_FILE) as f:\n            try:\n                count = int(f.read().strip())\n            except:\n                count = 0\n    count += 1\n    with open(ATTEMPT_COUNT_FILE, \"w\") as f:\n        f.write(str(count))\n    return count\n\n\ndef gate1_operating_point(report):\n    \"\"\"GATE 1: Operating point verification (Section 7).\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 1: OPERATING POINT VERIFICATION (Section 7 — MANDATORY)\", report)\n    log(\"=\" * 70, report)\n\n    output, err = run_ngspice(\"tb_ota_op.spice\")\n    if err:\n        log(f\"  BLOCKED: {err}\", report)\n        return False, {}\n\n    # Extract all 13 transistors\n    devices = {\n        \"m1\":  {\"type\": \"nmos\", \"role\": \"input+\",      \"signal\": True},\n        \"m2\":  {\"type\": \"nmos\", \"role\": \"input-\",       \"signal\": True},\n        \"m3\":  {\"type\": \"pmos\", \"role\": \"fold+\",        \"signal\": False},\n        \"m4\":  {\"type\": \"pmos\", \"role\": \"fold-\",        \"signal\": False},\n        \"m5\":  {\"type\": \"pmos\", \"role\": \"cascode+\",     \"signal\": False, \"cascode\": True},\n        \"m6\":  {\"type\": \"pmos\", \"role\": \"cascode-\",     \"signal\": False, \"cascode\": True},\n        \"m7\":  {\"type\": \"nmos\", \"role\": \"cascode+\",     \"signal\": True,  \"cascode\": True},\n        \"m8\":  {\"type\": \"nmos\", \"role\": \"cascode-\",     \"signal\": True,  \"cascode\": True},\n        \"m9\":  {\"type\": \"nmos\", \"role\": \"current_src+\", \"signal\": False},\n        \"m10\": {\"type\": \"nmos\", \"role\": \"current_src-\", \"signal\": False},\n        \"m11\": {\"type\": \"nmos\", \"role\": \"tail\",         \"signal\": False},\n        \"m12\": {\"type\": \"pmos\", \"role\": \"bias_mirror+\", \"signal\": False},\n        \"m13\": {\"type\": \"pmos\", \"role\": \"bias_mirror-\", \"signal\": False},\n    }\n\n    params = [\"vgs\", \"vth\", \"vds\", \"vdsat\", \"id\", \"gm\", \"gds\"]\n    op_data = {}\n    all_ok = True\n    fails = []\n\n    for dev_name, dev_info in devices.items():\n        op_data[dev_name] = {}\n        for p in params:\n            val = parse_op_param(output, dev_name, p)\n            op_data[dev_name][p] = val\n\n    # Extract Vout\n    vout_match = re.search(r'v\\(vout\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+|[+-]?\\d+\\.?\\d*)', output)\n    vout = float(vout_match.group(1)) if vout_match else None\n\n    # Print operating point table\n    log(\"\\n  Device  | Type | Role          | Id(nA)  | Vgs(V) | Vth(V) | Vov(mV) | Vds(V) | Vdsat(V) | gm(uS) | gds(nS) | Status\", report)\n    log(\"  \" + \"-\" * 120, report)\n\n    for dev_name, dev_info in devices.items():\n        d = op_data[dev_name]\n        if d[\"vgs\"] is None:\n            log(f\"  {dev_name:7s} | COULD NOT EXTRACT — ngspice output parse failed\", report)\n            fails.append(f\"{dev_name}: no data extracted\")\n            all_ok = False\n            continue\n\n        vgs = d[\"vgs\"]\n        vth = d[\"vth\"]\n        vds = d[\"vds\"]\n        vdsat = d[\"vdsat\"]\n        id_val = d[\"id\"]\n        gm = d[\"gm\"]\n        gds_val = d[\"gds\"]\n\n        # Compute Vov\n        if dev_info[\"type\"] == \"pmos\":\n            vov_mV = (abs(vgs) - abs(vth)) * 1000  # Vsg - |Vth|\n        else:\n            vov_mV = (vgs - vth) * 1000  # Vgs - Vth\n\n        status = \"OK\"\n        issues = []\n\n        # Check 1: PMOS Vov > 150mV\n        if dev_info[\"type\"] == \"pmos\":\n            if vov_mV < SPECS[\"pmos_vov_min_mV\"]:\n                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['pmos_vov_min_mV']}mV\")\n\n        # Check 2: NMOS signal path Vov > 50mV\n        if dev_info[\"type\"] == \"nmos\" and dev_info.get(\"signal\", False):\n            if vov_mV < SPECS[\"nmos_signal_vov_min_mV\"]:\n                issues.append(f\"Vov={vov_mV:.0f}mV < {SPECS['nmos_signal_vov_min_mV']}mV\")\n\n        # Check 3: Cascode headroom\n        if dev_info.get(\"cascode\", False):\n            headroom_mV = (abs(vds) - abs(vdsat)) * 1000\n            if headroom_mV < SPECS[\"cascode_headroom_mV\"]:\n                issues.append(f\"headroom={headroom_mV:.0f}mV < {SPECS['cascode_headroom_mV']}mV\")\n\n        # Check 4: Triode detection (|Vds| < |Vdsat|)\n        if abs(vds) < abs(vdsat):\n            issues.append(f\"TRIODE: |Vds|={abs(vds)*1000:.0f}mV < |Vdsat|={abs(vdsat)*1000:.0f}mV\")\n\n        if issues:\n            status = \"FAIL: \" + \"; \".join(issues)\n            fails.append(f\"{dev_name}: {'; '.join(issues)}\")\n            all_ok = False\n\n        log(f\"  {dev_name:7s} | {dev_info['type']:4s} | {dev_info['role']:13s} | {abs(id_val)*1e9:7.1f} | {vgs:+.4f} | {vth:+.4f} | {vov_mV:+7.1f} | {vds:+.4f} | {vdsat:+.5f} | {gm*1e6:6.3f}  | {gds_val*1e9:7.1f}  | {status}\", report)\n\n    # Check 5: Tail current accuracy\n    id_m11 = op_data[\"m11\"][\"id\"]\n    if id_m11 is not None:\n        tail_err = abs(abs(id_m11) * 1e9 - SPECS[\"tail_current_nA\"])\n        if tail_err > SPECS[\"tail_current_tol_nA\"]:\n            fails.append(f\"M11 tail current: {abs(id_m11)*1e9:.1f}nA, error={tail_err:.1f}nA > {SPECS['tail_current_tol_nA']}nA\")\n            all_ok = False","numLines":150,"startLine":100,"totalLines":824}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014VKeEfEhJJ5Z16yqBjCs7F","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011TEGwH3YvMQt2nHfuorS1i","name":"Read","input":{"file_path":"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/verify_design.py","offset":250,"limit":200},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3045,"cache_read_input_tokens":28635,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3045},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dc3cf414-60b5-4244-9a30-3b9794da6520","uuid":"07d2dbbf-93c8-4555-80c5-ce5342a3595e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011TEGwH3YvMQt2nHfuorS1i","type":"tool_result","content":"   250→        log(f\"\\n  Tail current M11: {abs(id_m11)*1e9:.1f} nA (target: {SPECS['tail_current_nA']} ± {SPECS['tail_current_tol_nA']} nA) — {'OK' if tail_err <= SPECS['tail_current_tol_nA'] else 'FAIL'}\", report)\n   251→\n   252→    # Check 6: Current balance M1/M2\n   253→    id_m1 = op_data[\"m1\"][\"id\"]\n   254→    id_m2 = op_data[\"m2\"][\"id\"]\n   255→    if id_m1 is not None and id_m2 is not None:\n   256→        balance = abs(abs(id_m1) - abs(id_m2)) * 1e9\n   257→        if balance > SPECS[\"current_balance_nA\"]:\n   258→            fails.append(f\"M1/M2 balance: {balance:.1f}nA > {SPECS['current_balance_nA']}nA\")\n   259→            all_ok = False\n   260→        log(f\"  Current balance |Id_M1 - Id_M2|: {balance:.1f} nA (max: {SPECS['current_balance_nA']} nA) — {'OK' if balance <= SPECS['current_balance_nA'] else 'FAIL'}\", report)\n   261→\n   262→    # Check 7: Output voltage\n   263→    if vout is not None:\n   264→        vout_ok = SPECS[\"vout_min_V\"] <= vout <= SPECS[\"vout_max_V\"]\n   265→        if not vout_ok:\n   266→            fails.append(f\"Vout={vout:.3f}V outside [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]\")\n   267→            all_ok = False\n   268→        log(f\"  Output voltage: {vout:.4f} V (range: [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]) — {'OK' if vout_ok else 'FAIL'}\", report)\n   269→\n   270→    # Supply current\n   271→    supply_match = re.search(r'-i\\(vdd\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+)', output)\n   272→    if supply_match:\n   273→        i_supply = float(supply_match.group(1))\n   274→        i_ok = abs(i_supply) * 1e6 <= SPECS[\"total_current_max_uA\"]\n   275→        if not i_ok:\n   276→            fails.append(f\"Supply current {abs(i_supply)*1e6:.3f} uA > {SPECS['total_current_max_uA']} uA\")\n   277→            all_ok = False\n   278→        log(f\"  Supply current: {abs(i_supply)*1e6:.3f} uA (max: {SPECS['total_current_max_uA']} uA) — {'OK' if i_ok else 'FAIL'}\", report)\n   279→\n   280→    log(f\"\\n  GATE 1 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n   281→    if fails:\n   282→        log(f\"  FAILURES ({len(fails)}):\", report)\n   283→        for f in fails:\n   284→            log(f\"    - {f}\", report)\n   285→    log(\"  \" + \"=\" * 70, report)\n   286→\n   287→    return all_ok, op_data\n   288→\n   289→\n   290→def gate2_ac_performance(report):\n   291→    \"\"\"GATE 2: AC open-loop performance.\"\"\"\n   292→    log(\"\\n\" + \"=\" * 70, report)\n   293→    log(\"GATE 2: AC OPEN-LOOP PERFORMANCE (Section 5.1)\", report)\n   294→    log(\"=\" * 70, report)\n   295→\n   296→    output, err = run_ngspice(\"tb_ota_ac.spice\")\n   297→    if err:\n   298→        log(f\"  BLOCKED: {err}\", report)\n   299→        return False\n   300→\n   301→    all_ok = True\n   302→    fails = []\n   303→\n   304→    g_peak = parse_meas(output, \"gain_peak\")\n   305→    g_1hz = parse_meas(output, \"g1\")\n   306→    g_10hz = parse_meas(output, \"g10\")\n   307→    g_100hz = parse_meas(output, \"g100\")\n   308→    ugb = parse_meas(output, \"ugb\")\n   309→    phase_ugb = parse_meas(output, \"phase_ugb\")\n   310→\n   311→    log(f\"\\n  Raw ngspice measurements:\", report)\n   312→    log(f\"    Peak gain:    {g_peak:.2f} dB\" if g_peak else \"    Peak gain:    NOT FOUND\", report)\n   313→    log(f\"    Gain @ 1 Hz:  {g_1hz:.2f} dB\" if g_1hz else \"    Gain @ 1 Hz:  NOT FOUND\", report)\n   314→    log(f\"    Gain @ 10 Hz: {g_10hz:.2f} dB\" if g_10hz else \"    Gain @ 10 Hz: NOT FOUND\", report)\n   315→    log(f\"    Gain @ 100 Hz:{g_100hz:.2f} dB\" if g_100hz else \"    Gain @ 100 Hz:NOT FOUND\", report)\n   316→    log(f\"    UGB:          {ugb:.1f} Hz\" if ugb else \"    UGB:          NOT FOUND\", report)\n   317→    log(f\"    Phase @ UGB:  {phase_ugb:.2f} deg\" if phase_ugb else \"    Phase @ UGB:  NOT FOUND\", report)\n   318→\n   319→    # SANITY CHECK: Open-loop gain should be flat from DC to dominant pole.\n   320→    if g_peak is not None and g_10hz is not None:\n   321→        if g_peak - g_10hz > 6:\n   322→            log(f\"\\n  *** SANITY WARNING: Peak gain ({g_peak:.1f} dB) is {g_peak - g_10hz:.1f} dB above gain at 10 Hz ({g_10hz:.1f} dB).\", report)\n   323→            log(f\"  *** A proper open-loop response should be FLAT from DC to the dominant pole.\", report)\n   324→            log(f\"  *** This suggests the loop is NOT properly broken — measurement is INVALID.\", report)\n   325→            fails.append(f\"MEASUREMENT INVALID: gain not flat at low freq (peak={g_peak:.1f}dB, @10Hz={g_10hz:.1f}dB)\")\n   326→            all_ok = False\n   327→\n   328→    # SANITY CHECK: PM should not be > 120 for a single-stage OTA with 10pF load.\n   329→    if phase_ugb is not None:\n   330→        pm = phase_ugb + 180\n   331→        log(f\"    Phase margin: {pm:.1f} deg\", report)\n   332→        if pm > 120:\n   333→            log(f\"\\n  *** SANITY WARNING: Phase margin = {pm:.1f} deg is > 120 deg.\", report)\n   334→            log(f\"  *** A folded-cascode OTA should have PM ~ 55-75 deg with 10pF load.\", report)\n   335→            log(f\"  *** PM > 120 deg means the loop gain measurement is broken.\", report)\n   336→            fails.append(f\"MEASUREMENT INVALID: PM={pm:.1f} deg (expected 55-75 deg)\")\n   337→            all_ok = False\n   338→    else:\n   339→        fails.append(\"Phase margin could not be measured\")\n   340→        all_ok = False\n   341→\n   342→    # Actual spec checks (only meaningful if sanity checks pass)\n   343→    if all_ok:\n   344→        dc_gain = g_10hz if g_10hz is not None else g_peak\n   345→        if dc_gain is not None:\n   346→            if dc_gain < SPECS[\"dc_gain_min_dB\"]:\n   347→                fails.append(f\"DC gain {dc_gain:.1f} dB < {SPECS['dc_gain_min_dB']} dB min\")\n   348→                all_ok = False\n   349→            log(f\"\\n  DC gain: {dc_gain:.1f} dB (min: {SPECS['dc_gain_min_dB']}, target: {SPECS['dc_gain_target_dB']}) — {'OK' if dc_gain >= SPECS['dc_gain_min_dB'] else 'FAIL'}\", report)\n   350→\n   351→        if ugb is not None:\n   352→            ugb_ok = SPECS[\"ugb_min_Hz\"] <= ugb <= SPECS[\"ugb_max_Hz\"]\n   353→            if not ugb_ok:\n   354→                fails.append(f\"UGB {ugb:.0f} Hz outside [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]\")\n   355→                all_ok = False\n   356→            log(f\"  UGB: {ugb:.0f} Hz (range: [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]) — {'OK' if ugb_ok else 'FAIL'}\", report)\n   357→\n   358→        if phase_ugb is not None:\n   359→            pm = phase_ugb + 180\n   360→            pm_ok = pm >= SPECS[\"pm_min_deg\"]\n   361→            if not pm_ok:\n   362→                fails.append(f\"PM {pm:.1f} deg < {SPECS['pm_min_deg']} deg\")\n   363→                all_ok = False\n   364→            log(f\"  Phase margin: {pm:.1f} deg (min: {SPECS['pm_min_deg']}) — {'OK' if pm_ok else 'FAIL'}\", report)\n   365→\n   366→    log(f\"\\n  GATE 2 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n   367→    if fails:\n   368→        log(f\"  FAILURES ({len(fails)}):\", report)\n   369→        for f in fails:\n   370→            log(f\"    - {f}\", report)\n   371→    log(\"  \" + \"=\" * 70, report)\n   372→\n   373→    return all_ok\n   374→\n   375→\n   376→def gate3_dc_transient(report):\n   377→    \"\"\"GATE 3: DC sweep and transient (slew rate via large-signal derivative).\"\"\"\n   378→    log(\"\\n\" + \"=\" * 70, report)\n   379→    log(\"GATE 3: DC SWEEP & TRANSIENT (Sections 5.3, 5.4)\", report)\n   380→    log(\"=\" * 70, report)\n   381→\n   382→    all_ok = True\n   383→    fails = []\n   384→\n   385→    # DC sweep\n   386→    output_dc, err = run_ngspice(\"tb_ota_dc.spice\")\n   387→    if err:\n   388→        log(f\"  DC: BLOCKED: {err}\", report)\n   389→        all_ok = False\n   390→    else:\n   391→        vmax = parse_meas(output_dc, \"vout_max\")\n   392→        vmin = parse_meas(output_dc, \"vout_min\")\n   393→        if vmax is not None and vmin is not None:\n   394→            swing = vmax - vmin\n   395→            swing_ok = swing >= SPECS[\"output_swing_min_Vpp\"]\n   396→            if not swing_ok:\n   397→                fails.append(f\"Output swing {swing:.3f} Vpp < {SPECS['output_swing_min_Vpp']} Vpp\")\n   398→                all_ok = False\n   399→            log(f\"  Output swing: {swing:.3f} Vpp (min: {SPECS['output_swing_min_Vpp']}) — {'OK' if swing_ok else 'FAIL'}\", report)\n   400→            log(f\"    Vout_max: {vmax:.3f} V, Vout_min: {vmin:.3f} V\", report)\n   401→        else:\n   402→            fails.append(\"Could not measure output swing\")\n   403→            all_ok = False\n   404→\n   405→    # Transient — SLEW RATE\n   406→    # The correct method: apply a LARGE step (500mV) to force current-limited slewing,\n   407→    # then measure the max dV/dt (derivative at steepest point).\n   408→    # Alternative: measure time for output to cross two voltage thresholds during\n   409→    # the slewing phase (before settling begins).\n   410→    #\n   411→    # The testbench should export: sr_meas (slew rate in V/s)\n   412→    # OR: t_low and t_high for two voltage crossings during the slew.\n   413→    output_tran, err = run_ngspice(\"tb_ota_tran.spice\")\n   414→    if err:\n   415→        log(f\"  Transient: BLOCKED: {err}\", report)\n   416→        all_ok = False\n   417→    else:\n   418→        # Try to find sr_meas (direct derivative measurement from testbench)\n   419→        sr_direct = parse_meas(output_tran, \"sr_meas\")\n   420→        # Also try the two-crossing method\n   421→        t_low = parse_meas(output_tran, \"t_low\")\n   422→        t_high = parse_meas(output_tran, \"t_high\")\n   423→        # Also try the old t10/t90 method as fallback\n   424→        t10 = parse_meas(output_tran, \"t10\")\n   425→        t90 = parse_meas(output_tran, \"t90\")\n   426→\n   427→        sr_mVus = None\n   428→        method = None\n   429→\n   430→        if sr_direct is not None and sr_direct > 0:\n   431→            # Direct derivative measurement (best)\n   432→            sr_mVus = sr_direct * 1e-3  # V/s -> mV/us\n   433→            method = \"direct derivative\"\n   434→        elif t_low is not None and t_high is not None and t_high > t_low:\n   435→            # Two-crossing method: measure dV/dt during slewing phase\n   436→            # Expect testbench to define v_low and v_high as the crossing levels\n   437→            # Default: assume 200mV between crossings for a 500mV step\n   438→            v_low = parse_meas(output_tran, \"v_low\")\n   439→            v_high = parse_meas(output_tran, \"v_high\")\n   440→            if v_low is not None and v_high is not None:\n   441→                delta_v = v_high - v_low\n   442→            else:\n   443→                delta_v = 0.2  # default assumption\n   444→            sr_Vs = delta_v / (t_high - t_low)\n   445→            sr_mVus = sr_Vs * 1e-6 * 1e3\n   446→            method = \"two-crossing\"\n   447→        elif t10 is not None and t90 is not None and t90 > t10:\n   448→            # Old 10-90% method (fallback) — but apply to large-signal step\n   449→            # Read step size from testbench output if available"}]},"parent_tool_use_id":null,"session_id":"dc3cf414-60b5-4244-9a30-3b9794da6520","uuid":"a35823b2-eef2-414f-872e-b90400372c3b","timestamp":"2026-03-23T10:48:31.286Z","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/analog-ai-chips/vibrosense/01_ota/verify_design.py","content":"        log(f\"\\n  Tail current M11: {abs(id_m11)*1e9:.1f} nA (target: {SPECS['tail_current_nA']} ± {SPECS['tail_current_tol_nA']} nA) — {'OK' if tail_err <= SPECS['tail_current_tol_nA'] else 'FAIL'}\", report)\n\n    # Check 6: Current balance M1/M2\n    id_m1 = op_data[\"m1\"][\"id\"]\n    id_m2 = op_data[\"m2\"][\"id\"]\n    if id_m1 is not None and id_m2 is not None:\n        balance = abs(abs(id_m1) - abs(id_m2)) * 1e9\n        if balance > SPECS[\"current_balance_nA\"]:\n            fails.append(f\"M1/M2 balance: {balance:.1f}nA > {SPECS['current_balance_nA']}nA\")\n            all_ok = False\n        log(f\"  Current balance |Id_M1 - Id_M2|: {balance:.1f} nA (max: {SPECS['current_balance_nA']} nA) — {'OK' if balance <= SPECS['current_balance_nA'] else 'FAIL'}\", report)\n\n    # Check 7: Output voltage\n    if vout is not None:\n        vout_ok = SPECS[\"vout_min_V\"] <= vout <= SPECS[\"vout_max_V\"]\n        if not vout_ok:\n            fails.append(f\"Vout={vout:.3f}V outside [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]\")\n            all_ok = False\n        log(f\"  Output voltage: {vout:.4f} V (range: [{SPECS['vout_min_V']}, {SPECS['vout_max_V']}]) — {'OK' if vout_ok else 'FAIL'}\", report)\n\n    # Supply current\n    supply_match = re.search(r'-i\\(vdd\\)\\s*=\\s*([+-]?\\d+\\.?\\d*[eE][+-]?\\d+)', output)\n    if supply_match:\n        i_supply = float(supply_match.group(1))\n        i_ok = abs(i_supply) * 1e6 <= SPECS[\"total_current_max_uA\"]\n        if not i_ok:\n            fails.append(f\"Supply current {abs(i_supply)*1e6:.3f} uA > {SPECS['total_current_max_uA']} uA\")\n            all_ok = False\n        log(f\"  Supply current: {abs(i_supply)*1e6:.3f} uA (max: {SPECS['total_current_max_uA']} uA) — {'OK' if i_ok else 'FAIL'}\", report)\n\n    log(f\"\\n  GATE 1 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n    if fails:\n        log(f\"  FAILURES ({len(fails)}):\", report)\n        for f in fails:\n            log(f\"    - {f}\", report)\n    log(\"  \" + \"=\" * 70, report)\n\n    return all_ok, op_data\n\n\ndef gate2_ac_performance(report):\n    \"\"\"GATE 2: AC open-loop performance.\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 2: AC OPEN-LOOP PERFORMANCE (Section 5.1)\", report)\n    log(\"=\" * 70, report)\n\n    output, err = run_ngspice(\"tb_ota_ac.spice\")\n    if err:\n        log(f\"  BLOCKED: {err}\", report)\n        return False\n\n    all_ok = True\n    fails = []\n\n    g_peak = parse_meas(output, \"gain_peak\")\n    g_1hz = parse_meas(output, \"g1\")\n    g_10hz = parse_meas(output, \"g10\")\n    g_100hz = parse_meas(output, \"g100\")\n    ugb = parse_meas(output, \"ugb\")\n    phase_ugb = parse_meas(output, \"phase_ugb\")\n\n    log(f\"\\n  Raw ngspice measurements:\", report)\n    log(f\"    Peak gain:    {g_peak:.2f} dB\" if g_peak else \"    Peak gain:    NOT FOUND\", report)\n    log(f\"    Gain @ 1 Hz:  {g_1hz:.2f} dB\" if g_1hz else \"    Gain @ 1 Hz:  NOT FOUND\", report)\n    log(f\"    Gain @ 10 Hz: {g_10hz:.2f} dB\" if g_10hz else \"    Gain @ 10 Hz: NOT FOUND\", report)\n    log(f\"    Gain @ 100 Hz:{g_100hz:.2f} dB\" if g_100hz else \"    Gain @ 100 Hz:NOT FOUND\", report)\n    log(f\"    UGB:          {ugb:.1f} Hz\" if ugb else \"    UGB:          NOT FOUND\", report)\n    log(f\"    Phase @ UGB:  {phase_ugb:.2f} deg\" if phase_ugb else \"    Phase @ UGB:  NOT FOUND\", report)\n\n    # SANITY CHECK: Open-loop gain should be flat from DC to dominant pole.\n    if g_peak is not None and g_10hz is not None:\n        if g_peak - g_10hz > 6:\n            log(f\"\\n  *** SANITY WARNING: Peak gain ({g_peak:.1f} dB) is {g_peak - g_10hz:.1f} dB above gain at 10 Hz ({g_10hz:.1f} dB).\", report)\n            log(f\"  *** A proper open-loop response should be FLAT from DC to the dominant pole.\", report)\n            log(f\"  *** This suggests the loop is NOT properly broken — measurement is INVALID.\", report)\n            fails.append(f\"MEASUREMENT INVALID: gain not flat at low freq (peak={g_peak:.1f}dB, @10Hz={g_10hz:.1f}dB)\")\n            all_ok = False\n\n    # SANITY CHECK: PM should not be > 120 for a single-stage OTA with 10pF load.\n    if phase_ugb is not None:\n        pm = phase_ugb + 180\n        log(f\"    Phase margin: {pm:.1f} deg\", report)\n        if pm > 120:\n            log(f\"\\n  *** SANITY WARNING: Phase margin = {pm:.1f} deg is > 120 deg.\", report)\n            log(f\"  *** A folded-cascode OTA should have PM ~ 55-75 deg with 10pF load.\", report)\n            log(f\"  *** PM > 120 deg means the loop gain measurement is broken.\", report)\n            fails.append(f\"MEASUREMENT INVALID: PM={pm:.1f} deg (expected 55-75 deg)\")\n            all_ok = False\n    else:\n        fails.append(\"Phase margin could not be measured\")\n        all_ok = False\n\n    # Actual spec checks (only meaningful if sanity checks pass)\n    if all_ok:\n        dc_gain = g_10hz if g_10hz is not None else g_peak\n        if dc_gain is not None:\n            if dc_gain < SPECS[\"dc_gain_min_dB\"]:\n                fails.append(f\"DC gain {dc_gain:.1f} dB < {SPECS['dc_gain_min_dB']} dB min\")\n                all_ok = False\n            log(f\"\\n  DC gain: {dc_gain:.1f} dB (min: {SPECS['dc_gain_min_dB']}, target: {SPECS['dc_gain_target_dB']}) — {'OK' if dc_gain >= SPECS['dc_gain_min_dB'] else 'FAIL'}\", report)\n\n        if ugb is not None:\n            ugb_ok = SPECS[\"ugb_min_Hz\"] <= ugb <= SPECS[\"ugb_max_Hz\"]\n            if not ugb_ok:\n                fails.append(f\"UGB {ugb:.0f} Hz outside [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]\")\n                all_ok = False\n            log(f\"  UGB: {ugb:.0f} Hz (range: [{SPECS['ugb_min_Hz']}, {SPECS['ugb_max_Hz']}]) — {'OK' if ugb_ok else 'FAIL'}\", report)\n\n        if phase_ugb is not None:\n            pm = phase_ugb + 180\n            pm_ok = pm >= SPECS[\"pm_min_deg\"]\n            if not pm_ok:\n                fails.append(f\"PM {pm:.1f} deg < {SPECS['pm_min_deg']} deg\")\n                all_ok = False\n            log(f\"  Phase margin: {pm:.1f} deg (min: {SPECS['pm_min_deg']}) — {'OK' if pm_ok else 'FAIL'}\", report)\n\n    log(f\"\\n  GATE 2 RESULT: {'PASS' if all_ok else 'FAIL'}\", report)\n    if fails:\n        log(f\"  FAILURES ({len(fails)}):\", report)\n        for f in fails:\n            log(f\"    - {f}\", report)\n    log(\"  \" + \"=\" * 70, report)\n\n    return all_ok\n\n\ndef gate3_dc_transient(report):\n    \"\"\"GATE 3: DC sweep and transient (slew rate via large-signal derivative).\"\"\"\n    log(\"\\n\" + \"=\" * 70, report)\n    log(\"GATE 3: DC SWEEP & TRANSIENT (Sections 5.3, 5.4)\", report)\n    log(\"=\" * 70, report)\n\n    all_ok = True\n    fails = []\n\n    # DC sweep\n    output_dc, err = run_ngspice(\"tb_ota_dc.spice\")\n    if err:\n        log(f\"  DC: BLOCKED: {err}\", report)\n        all_ok = False\n    else:\n        vmax = parse_meas(output_dc, \"vout_max\")\n        vmin = parse_meas(output_dc, \"vout_min\")\n        if vmax is not None and vmin is not None:\n            swing = vmax - vmin\n            swing_ok = swing >= SPECS[\"output_swing_min_Vpp\"]\n            if not swing_ok:\n                fails.append(f\"Output swing {swing:.3f} Vpp < {SPECS['output_swing_min_Vpp']} Vpp\")\n                all_ok = False\n            log(f\"  Output swing: {swing:.3f} Vpp (min: {SPECS['output_swing_min_Vpp']}) — {'OK' if swing_ok else 'FAIL'}\", report)\n            log(f\"    Vout_max: {vmax:.3f} V, Vout_min: {vmin:.3f} V\", report)\n        else:\n            fails.append(\"Could not measure output swing\")\n            all_ok = False\n\n    # Transient — SLEW RATE\n    # The correct method: apply a LARGE step (500mV) to force current-limited slewing,\n    # then measure the max dV/dt (derivative at steepest point).\n    # Alternative: measure time for output to cross two voltage thresholds during\n    # the slewing phase (before settling begins).\n    #\n    # The testbench should export: sr_meas (slew rate in V/s)\n    # OR: t_low and t_high for two voltage crossings during the slew.\n    output_tran, err = run_ngspice(\"tb_ota_tran.spice\")\n    if err:\n        log(f\"  Transient: BLOCKED: {err}\", report)\n        all_ok = False\n    else:\n        # Try to find sr_meas (direct derivative measurement from testbench)\n        sr_direct = parse_meas(output_tran, \"sr_meas\")\n        # Also try the two-crossing method\n        t_low = parse_meas(output_tran, \"t_low\")\n        t_high = parse_meas(output_tran, \"t_high\")\n        # Also try the old t10/t90 method as fallback\n        t10 = parse_meas(output_tran, \"t10\")\n        t90 = parse_meas(output_tran, \"t90\")\n\n        sr_mVus = None\n        method = None\n\n        if sr_direct is not None and sr_direct > 0:\n            # Direct derivative measurement (best)\n            sr_mVus = sr_direct * 1e-3  # V/s -> mV/us\n            method = \"direct derivative\"\n        elif t_low is not None and t_high is not None and t_high > t_low:\n            # Two-crossing method: measure dV/dt during slewing phase\n            # Expect testbench to define v_low and v_high as the crossing levels\n            # Default: assume 200mV between crossings for a 500mV step\n            v_low = parse_meas(output_tran, \"v_low\")\n            v_high = parse_meas(output_tran, \"v_high\")\n            if v_low is not None and v_high is not None:\n                delta_v = v_high - v_low\n            else:\n                delta_v = 0.2  # default assumption\n            sr_Vs = delta_v / (t_high - t_low)\n            sr_mVus = sr_Vs * 1e-6 * 1e3\n            method = \"two-crossing\"\n        elif t10 is not None and t90 is not None and t90 > t10:\n            # Old 10-90% method (fallback) — but apply to large-signal step\n            # Read step size from testbench output if available","numLines":200,"startLine":250,"totalLines":824}}}
