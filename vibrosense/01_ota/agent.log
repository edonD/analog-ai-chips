mon-mode)","+* CMRR = Adm_dB - Acm_dB at DC"," .lib \"sky130_minimal.lib.spice\" tt"," .include \"ota_foldcasc.spice\""," "]},{"oldStart":9,"oldLines":31,"newStart":10,"newLines":38,"lines":[" Vbp  vbp  0 dc 0.73"," Vbcp vbcp 0 dc 0.475"," ","-* AC on vinp","-Vinp vinp 0 dc 0.9 ac 1","+* Common-mode AC source","+Vcm vcm 0 dc 0.9 ac 1"," ","-* Loop-breaking: inductor sets DC op point, Cdc blocks AC for vinn","-Lbreak vout vinn_dc 1G","-Cdc vinn_dc 0 1","+* vinp directly connected to vcm","+* vinn: DC from output via inductor, AC from vcm via coupling cap","+Lbreak vout vinn 1G","+Cac vcm vinn 1"," ","-* AC injection on vinn: voltage source in series adds AC=1","-* vinn = vinn_dc (DC from loop) + AC=1 (common-mode stimulus)","-Vinn_ac vinn_dc vinn dc 0 ac 1","-","-Xota vinp vinn vout vdd 0 vbn vbcn vbp vbcp ota_foldcasc","+Xota vcm vinn vout vdd 0 vbn vbcn vbp vbcp ota_foldcasc"," CL vout 0 10p"," ","-.ac dec 100 0.1 1Meg","+.ac dec 100 0.1 1G"," "," .control"," run"," ","-* Acm = common-mode gain at DC (use 1 Hz as proxy)","-meas ac acm_1hz FIND vdb(vout) AT=1","+* Common-mode gain at DC (1Hz proxy)","+meas ac acm_dc FIND vdb(vout) AT=1"," ","-* CMRR = Adm - Acm (in dB). Adm ≈ 63.5 dB from Gate 2","-let cmrr = 63.5 - acm_1hz","+* Need differential gain for CMRR computation","+* Run second sim with differential stimulus","+alter Vcm ac = 0","+* Create differential stimulus: need AC on vinp only","+* But vinp is tied to vcm node. Use alter to change.","+* Alternative: compute using known gain from Gate 2"," ","+* For now, use the DC gain measured in Gate 2 (~63.5 dB)","+* This is the low-freq differential gain","+let adm_dc = 63.5","+let cmrr = adm_dc - acm_dc","+","+echo \"acm_dc = $&acm_dc\""," echo \"cmrr_dc = $&cmrr\""," "," quit"]}],"originalFile":"* TB06: CMRR — Common-Mode Rejection Ratio (open-loop method)\n* Break loop, AC on both inputs. CMRR = Adm(dB) - Acm(dB)\n.lib \"sky130_minimal.lib.spice\" tt\n.include \"ota_foldcasc.spice\"\n\nVdd vdd 0 dc 1.8\nVbn  vbn  0 dc 0.59\nVbcn vbcn 0 dc 0.88\nVbp  vbp  0 dc 0.73\nVbcp vbcp 0 dc 0.475\n\n* AC on vinp\nVinp vinp 0 dc 0.9 ac 1\n\n* Loop-breaking: inductor sets DC op point, Cdc blocks AC for vinn\nLbreak vout vinn_dc 1G\nCdc vinn_dc 0 1\n\n* AC injection on vinn: voltage source in series adds AC=1\n* vinn = vinn_dc (DC from loop) + AC=1 (common-mode stimulus)\nVinn_ac vinn_dc vinn dc 0 ac 1\n\nXota vinp vinn vout vdd 0 vbn vbcn vbp vbcp ota_foldcasc\nCL vout 0 10p\n\n.ac dec 100 0.1 1Meg\n\n.control\nrun\n\n* Acm = common-mode gain at DC (use 1 Hz as proxy)\nmeas ac acm_1hz FIND vdb(vout) AT=1\n\n* CMRR = Adm - Acm (in dB). Adm ≈ 63.5 dB from Gate 2\nlet cmrr = 63.5 - acm_1hz\n\necho \"cmrr_dc = $&cmrr\"\n\nquit\n.endc\n.end\n"}}
