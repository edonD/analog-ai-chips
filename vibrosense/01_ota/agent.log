\n  print @m.xota.m4[gds]\n\n  echo \"\"\n  echo \"--- M5 (PMOS cascode, non-output side) ---\"\n  print @m.xota.m5[vgs]\n  print @m.xota.m5[vth]\n  print @m.xota.m5[vds]\n  print @m.xota.m5[vdsat]\n  print @m.xota.m5[id]\n  print @m.xota.m5[gm]\n  print @m.xota.m5[gds]\n\n  echo \"\"\n  echo \"--- M6 (PMOS cascode, output side) ---\"\n  print @m.xota.m6[vgs]\n  print @m.xota.m6[vth]\n  print @m.xota.m6[vds]\n  print @m.xota.m6[vdsat]\n  print @m.xota.m6[id]\n  print @m.xota.m6[gm]\n  print @m.xota.m6[gds]\n\n  echo \"\"\n  echo \"--- M7 (NMOS cascode, non-output side) ---\"\n  print @m.xota.m7[vgs]\n  print @m.xota.m7[vth]\n  print @m.xota.m7[vds]\n  print @m.xota.m7[vdsat]\n  print @m.xota.m7[id]\n  print @m.xota.m7[gm]\n  print @m.xota.m7[gds]\n\n  echo \"\"\n  echo \"--- M8 (NMOS cascode, output side) ---\"\n  print @m.xota.m8[vgs]\n  print @m.xota.m8[vth]\n  print @m.xota.m8[vds]\n  print @m.xota.m8[vdsat]\n  print @m.xota.m8[id]\n  print @m.xota.m8[gm]\n  print @m.xota.m8[gds]\n\n  echo \"\"\n  echo \"--- M9 (NMOS current source, non-output side) ---\"\n  print @m.xota.m9[vgs]\n  print @m.xota.m9[vth]\n  print @m.xota.m9[vds]\n  print @m.xota.m9[vdsat]\n  print @m.xota.m9[id]\n  print @m.xota.m9[gm]\n  print @m.xota.m9[gds]\n\n  echo \"\"\n  echo \"--- M10 (NMOS current source, output side) ---\"\n  print @m.xota.m10[vgs]\n  print @m.xota.m10[vth]\n  print @m.xota.m10[vds]\n  print @m.xota.m10[vdsat]\n  print @m.xota.m10[id]\n  print @m.xota.m10[gm]\n  print @m.xota.m10[gds]\n\n  echo \"\"\n  echo \"--- M11 (tail current source, NMOS) ---\"\n  print @m.xota.m11[vgs]\n  print @m.xota.m11[vth]\n  print @m.xota.m11[vds]\n  print @m.xota.m11[vdsat]\n  print @m.xota.m11[id]\n  print @m.xota.m11[gm]\n  print @m.xota.m11[gds]\n\n  echo \"\"\n  echo \"--- M12 (PMOS bias mirror, non-output side) ---\"\n  print @m.xota.m12[vgs]\n  print @m.xota.m12[vth]\n  print @m.xota.m12[vds]\n  print @m.xota.m12[vdsat]\n  print @m.xota.m12[id]\n  print @m.xota.m12[gm]\n  print @m.xo