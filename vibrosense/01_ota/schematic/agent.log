pend(f\"Missing PFET devices: found {pfet_count}, expected 6\")\n    72→\n    73→    # Check for port pins\n    74→    for port in EXPECTED_PORTS:\n    75→        if port.lower() not in content.lower():\n    76→            results[\"warnings\"].append(f\"Port '{port}' not found in schematic\")\n    77→\n    78→    return results\n    79→\n    80→\n    81→def export_png(sch_path, png_path):\n    82→    \"\"\"Export schematic to PNG using xschem + Xvfb.\"\"\"\n    83→    try:\n    84→        # Use xschem in batch mode with virtual display\n    85→        cmd = [\n    86→            \"xvfb-run\", \"--auto-servernum\", \"--server-args=-screen 0 1920x1080x24\",\n    87→            \"xschem\", \"--netlist\", \"--svg\", \"--quit\", sch_path\n    88→        ]\n    89→        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30, cwd=os.path.dirname(sch_path))\n    90→\n    91→        # Also try to get a screenshot via tcl scripting\n    92→        tcl_script = f\"\"\"\n    93→xschem load {sch_path}\n    94→xschem zoom_full\n    95→xschem print png {png_path}\n    96→xschem exit\n    97→\"\"\"\n    98→        tcl_path = os.path.join(os.path.dirname(sch_path), \"_export.tcl\")\n    99→        with open(tcl_path, \"w\") as f:\n   100→            f.write(tcl_script)\n   101→\n   102→        cmd2 = [\n   103→            \"xvfb-run\", \"--auto-servernum\", \"--server-args=-screen 0 1920x1080x24\",\n   104→            \"xschem\", \"--tcl\", tcl_path, \"--quit\"\n   105→        ]\n   106→        result2 = subprocess.run(cmd2, capture_output=True, text=True, timeout=30, cwd=os.path.dirname(sch_path))\n   107→\n   108→        if os.path.exists(png_path):\n   109→            return True, f\"Exported to {png_path}\"\n   110→        else:\n   111→            # Check for SVG as alternative\n   112→            svg_path = sch_path.replace(\".sch\", \".svg\")\n   113→            if os.path.exists(svg_path):\n   114→                return True, f\"Exported SVG to {svg_path}