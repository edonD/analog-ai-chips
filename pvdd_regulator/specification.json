          "max": 5e-3, "unit": "V/V",
          "condition": "Iload=10mA, BVDD 5.4-10.5V"
        },
        {
          "id": 3,
          "name": "load_regulation",
          "testbench": "tb_top_load_reg.spice",
          "param": "dvpvdd_diload",
          "max": 2e-3, "unit": "V/A",
          "condition": "BVDD=7V, Iload=0 to 50mA"
        },
        {
          "id": 4,
          "name": "load_transient_undershoot",
          "testbench": "tb_top_load_tran.spice",
          "param": "undershoot",
          "max": 150e-3, "unit": "V",
          "condition": "1mA->10mA in 1us"
        },
        {
          "id": 5,
          "name": "load_transient_overshoot",
          "testbench": "tb_top_load_tran.spice",
          "param": "overshoot",
