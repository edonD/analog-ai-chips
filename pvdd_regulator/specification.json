        {
          "id": 9,
          "name": "startup_fast",
          "testbench": "tb_top_startup_fast.spice",
          "param": "pvdd_overshoot_peak",
          "max": 5.5, "unit": "V",
          "condition": "BVDD ramp 0->10.5V at 10 V/us"
        },
        {
          "id": 10,
          "name": "dropout",
          "testbench": "tb_top_dropout.spice",
