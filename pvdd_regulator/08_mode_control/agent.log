0v5 w=20 l=20\nXM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\nXM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM2iv2p comp2 c2ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM2iv2n comp2 c2ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* =============================================\n* COMPARATOR 3: tap3 vs vref — TH3 = 4.5V\n* =============================================\nXM3p3 c3on c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM3p4 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM3n1 c3on tap3 c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM3n2 c3o  vref c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM3t c3tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\nXM3fb1 c3on c3o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM3fb2 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM3iv1p c3ob c3o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM3iv1n c3ob c3o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM3iv2p comp3 c3ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM3iv2n comp3 c3ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* =============================================\n* COMPARATOR 4: tap4 vs vref — TH4 = 5.6V\n* =============================================\nXM4p3 c4on c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM4p4 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM4n1 c4on tap4 c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM4n2 c4o  vref c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM4t c4tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\nXM4fb1 c4on c4o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM4fb2 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM4iv1p c4ob c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM4iv1n c4ob c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM4iv2p comp4 c4ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM4iv2n comp4 c4ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* =============================================\n* LOGIC DECODING\n* =============================================\n\n* Inverted comparator outputs\nXMinv1p comp1b comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMinv1n comp1b comp1 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMinv2p comp2b comp2 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMinv2n comp2b comp2 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMinv3p comp3b comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMinv3n comp3b comp3 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMinv4p comp4b comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMinv4n comp4b comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- pass_off = NOT(comp1) = comp1b ---\n* Pull-up resistor ensures pass_off HIGH when BVDD low (bootstrap for POR)\nXRpo_pu bvdd pass_off gnd sky130_fd_pr__res_xhigh_po w=1 l=50\nXMpo_bufp pass_off comp1b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- bypass_en = comp1·comp2b + comp3·comp4b ---\n* AOI gate: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)\n* NMOS pull-down: two series pairs in parallel\nXMby_n1a by_s1     comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMby_n1b bypass_enb comp2b by_s1 by_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMby_n2a by_s2     comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMby_n2b bypass_enb comp4b by_s2 by_s2 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n* PMOS pull-up: (comp1b||comp3b) in series with (comp2||comp4)\nXMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\n* Output inverter\nXMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- ea_en = comp2·comp3b + comp4 ---\n* AOI gate: ea_enb = NOT(comp2·comp3b + comp4)\nXMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n* PMOS: (comp2b||comp3) series comp4b\nXMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\n* Output inverter\nXMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- ref_sel = comp1·comp3b ---\n* NAND gate: ref_selb = NOT(comp1·comp3b) = NAND(comp1, comp3b)\nXMrs_n1 rs_s1    comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMrs_p2 ref_selb comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\n* Inverter\nXMrs_outp ref_sel ref_selb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMrs_outn ref_sel ref_selb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- uvov_en = comp4 (buffer) ---\nXMuv_p1 uvov_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMuv_n1 uvov_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMuv_p2 uvov_en uvov_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMuv_n2 uvov_en uvov_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* --- ilim_en = comp4 (buffer) ---\nXMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n.ends mode_control\n","structuredPatch":[{"oldStart":7,"oldLines":24,"newStart":7,"newLines":14,"lines":[" *   tap1 = highest voltage (trips at lowest BVDD = TH1 = 2.5V)"," *   tap4 = lowest voltage (trips at highest BVDD = TH4 = 5.6V)"," *","-* Each comparator: NMOS diff pair + PMOS mirror + cross-coupled PMOS positive feedback","-* Hysteresis via weak cross-coupled PMOS pair overlaid on the mirror load.","+* HV devices (sky130_fd_pr__nfet/pfet_g5v0d10v5): Lmin=20µm, Wmin=20µm","+* With ngbehavior=hs, W/L values in µm."," *","-* Logic decoding (monotonic thermometer code → control outputs):","-*   pass_off  = NOT(comp1)","-*   bypass_en = comp1·NOT(comp2) + comp3·NOT(comp4)","-*   ea_en     = comp2·NOT(comp3) + comp4","-*   ref_sel   = comp1·NOT(comp3)","-*   uvov_en   = comp4","-*   ilim_en   = comp4","-*","-* Subcircuit signature per specification:"," .subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off"," "," * ============================================="," * CONVERGENCE AIDS"," * =============================================","-* Small caps on high-impedance nodes for convergence"," C_tap1 tap1 gnd 50f"," C_tap2 tap2 gnd 50f"," C_tap3 tap3 gnd 50f"]},{"oldStart":33,"oldLines":10,"newStart":23,"newLines":10,"lines":[" * ============================================="," * RESISTOR LADDER: BVDD to GND"," * =============================================","-* sky130_fd_pr__res_xhigh_po: Rsh ≈ 2000 Ω/sq, w=1µm","-* R ≈ 2000 * (l - 0.06) / (1 - 0.056) ≈ 2119 * (l - 0.06)","+* sky130_fd_pr__res_xhigh_po: Rsh ≈ 2000 Ω/sq, w and l in µm","+* R ≈ 2119 * (l -