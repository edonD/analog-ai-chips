 XM4pt c4tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM4p1 c4on vref  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","-XM4p2 c4o  tap4  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","-XM4n3 c4on c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","-XM4n4 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","-XM4fb1 c4on c4o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-XM4fb2 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-XM4ivp comp4 c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM4ivn comp4 c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4p1 c4mi tap4 c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4p2 c4o  vref c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4n3 c4mi c4mi gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM4n4 c4o  c4mi gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM4iv1p c4ob c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XM4iv1n c4ob c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4iv2p comp4 c4ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XM4iv2n comp4 c4ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * ============================================="," * LOGIC DECODING"," * =============================================","-"," * Inverted comparator outputs"," XMinv1p comp1b comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMinv1n comp1b comp1 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"]},{"oldStart":135,"oldLines":22,"newStart":121,"newLines":27,"lines":[" XMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * --- bypass_en = comp1·comp2b + comp3·comp4b ---","-* AOI: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)","+* AOI22: bypass_enb = NOT(bypass_en) = (comp1b+comp2)·(comp3b+comp4)","+* NMOS pull-down: series pairs in parallel"," XMby_n1a by_s1     comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n1b bypass_enb comp2b by_s1 by_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n2a by_s2     comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n2b bypass_enb comp4b by_s2 by_s2 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+* PMOS pull-up: Group1=(comp1b+comp2)→gates comp1,comp2b; Group2=(comp3b+comp4)→gates comp3,comp4b","+XMby_p1a by_pmid comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMby_p1b by_pmid comp2b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMby_p2a bypass_enb comp3  by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+* Output inverter"," XMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * --- ea_en = comp2·comp3b + comp4 ---","+* AOI: ea_enb = (comp2b+comp3)·comp4b"," XMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+* PMOS: (comp2b+comp3)→gates comp2,comp3b; then comp4b→gate comp4"," XMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"]}],"originalFile":"* Block 08: Mode Control\n* PVDD 5V LDO Regulator — SkyWater SKY130A\n*\n* Architecture: Shared resistor ladder + 4 HV comparators + CMOS logic\n*\n* Key: PMOS diff pair comparators (work when inputs near GND/vref)\n* UNITS: MOSFETs = SI (meters), Resistors = µm (PDK convention)\n* HV model valid: L=[20,100)µm, W=[20,100)µm\n*\n.subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off\n\n* =============================================\n* CONVERGENCE AIDS\n* =============================================\nC_tap1 tap1 gnd 50f\nC_tap2 tap2 gnd 50f\nC_tap3 tap3 gnd 50f\nC_tap4 tap4 gnd 50f\n\n* =============================================\n* RESISTOR LADDER: BVDD to GND (w,l in µm)\n* =============================================\n* Tap arrangement: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND\n* tap1 = highest voltage (first to cross vref as BVDD rises)\n*\n.param rtop_l = 241\n.param r12_l  = 94\n.param r23_l  = 9.2\n.param r34_l  = 25\n.param rbot_l = 103\n\nXRtop bvdd tap1 gnd sky130_fd_pr__res_xhigh_po w=1 l=rtop_l\nXR12  tap1 tap2 gnd sky130_fd_pr__res_xhigh_po w=1 l=r12_l\nXR23  tap2 tap3 gnd sky130_fd_pr__res_xhigh_po w=1 l=r23_l\nXR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l\nXRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l\n\n* =============================================\n* BIAS GENERATOR\n* =============================================\n* N-type bias: resistor from BVDD + diode-connected NMOS\nXRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400\nXMnbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\n\n* P-type bias: NMOS drains PMOS diode → sets pbias voltage\nXMpb_n pbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXMpb_p pbias pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\n\n* =============================================\n* COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)\n* =============================================\n* PMOS diff pair (sources=tail, gates=inputs, drains=outputs)\n* When tap1 > vref: |Vgs_p1| < |Vgs_p2| → less current thru M_p1 → mirror pulls c1o LOW\n* After two inverters: comp1 = LOW when tap1 > vref... WRONG!\n* Fix: swap the mirror/output connections\n* M_p1 gate=vref (reference, + side → mirror input)\n* M_p2 gate=tap1 (signal, - side → output)\n* When tap1 > vref: I_p2 < I_p1 → mirror sinks more than M_p2 supplies → c1o drops → LOW\n* After 2 inverters: comp1 = LOW. Still wrong!\n*\n* Solution: use single inverter buffer (odd number of inversions)\n* c1o goes LOW when tap1 > vref → c1ob (inv1) goes HIGH → comp1 = HIGH ✓ (if buffer = 1 inv)\n*\n* PMOS tail current source (mirrors pbias)\nXM1pt c1tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\n* PMOS diff pair\nXM1p1 c1on vref  c1tail c1tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM1p2 c1o  tap1  c1tail c1tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\n* NMOS current mirror load\nXM1n3 c1on c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM1n4 c1o  c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\n* Positive feedback: weak cross-coupled NMOS for hysteresis\nXM1fb1 c1on c1o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM1fb2 c1o  c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\n* Output buffer: single inverter (c1o LOW when tap>vref → comp1 HIGH)\nXM1ivp comp1 c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM1ivn comp1 c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 2: tap2 vs vref — TH2 = 4.2V\n* =============================================\nXM2pt c2tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2p1 c2on vref  c2tail c2tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2p2 c2o  tap2  c2tail c2tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2n3 c2on c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2n4 c2o  c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2fb1 c2on c2o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM2fb2 c2o  c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM2ivp comp2 c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM2ivn comp2 c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 3: tap3 vs vref — TH3 = 4.5V\n* =============================================\nXM3pt c3tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM3p1 c3on vref  c3tail c3tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM3p2 c3o  tap3  c3tail c3tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM3n3 c3on c3on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM3n4 c3o  c3on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM3fb1 c3on c3o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM3fb2 c3o  c3on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM3ivp comp3 c3o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM3ivn comp3 c3o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 4: tap4 vs vref — TH4 = 5.6V\n* =============================================\nXM4pt c4tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM4p1 c4on vref  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM4p2 c4o  tap4  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\nXM4n3 c4on c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM4n4 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6\nXM4fb1 c4on c4o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM4fb2 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM4ivp comp4 c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM4ivn comp4 c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* LOGIC DECODING\n* =============================================\n\n* Inverted comparator outputs\nXMinv1p comp1b comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv1n comp1b comp1 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv2p comp2b comp2 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv2n comp2b comp2 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv3p comp3b comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv3n comp3b comp3 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv4p comp4b comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv4n comp4b comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- pass_off = NOT(comp1) = comp1b ---\nXRpo_pu bvdd pass_off gnd sky130_fd_pr__res_xhigh_po w=1 l=50\nXMpo_bufp pass_off comp1b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- bypass_en = comp1·comp2b + comp3·comp4b ---\n* AOI: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)\nXMby_n1a by_s1     comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n1b bypass_enb comp2b by_s1 by_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n2a by_s2     comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n2b bypass_enb comp4b by_s2 by_s2 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ea_en = comp2·comp3b + comp4 ---\nXMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ref_sel = comp1·comp3b ---\nXMrs_n1 rs_s1    comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMrs_p2 ref_selb comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMrs_outp ref_sel ref_selb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMrs_outn ref_sel ref_selb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- uvov_en = comp4 (double buffer) ---\nXMuv_p1 uvov_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMuv_n1 uvov_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMuv_p2 uvov_en uvov_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMuv_n2 uvov_en uvov_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ilim_en = comp4 (double buffer) ---\nXMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n.ends mode_control\n"}}
