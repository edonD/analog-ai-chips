n.include \"parasitic_res_po.spice\"\n.lib \"../sky130.lib.spice\" tt\n\n* Normal PFET: body=source=pvdd, drain=0, gate=sweep\n* Source = pvdd(5V) through 1 ohm sense\nVpvdd pvdd 0 5\nRsense pvdd src 1\nVg gate 0 dc\nXM1 0 gate src pvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* With body effect: body=pvdd, source at 1.5V (Vsb=3.5V)\nRsense2 src2h src2 1\nVs2 src2h 0 1.5\nVg2 gate2 0 dc\nXM2 0 gate2 src2 pvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* Sweep: Vg from -3 to 5 for case 1, gate2 from -3 to 1.5 for case 2\n.dc Vg 0 5 0.5\n\n.control\nrun\nlet id1 = (v(pvdd)-v(src))/1\necho \"=== PFET Vsb=0 (body=source) ===\"\necho \"Vg    Id\"\nprint v(gate) id1\n.endc\n\n.end\n"}}
