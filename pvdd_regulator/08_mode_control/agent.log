3\nend\nif e4 > max_err\n  let max_err = e4\nend\nlet mono = 1\nif thresh_por_v >= thresh_ret_v\n  let mono = 0\nend\nif thresh_ret_v >= thresh_pup_v\n  let mono = 0\nend\nif thresh_pup_v >= thresh_act_v\n  let mono = 0\nend\n\necho \"thresh_max_error_pct: $&max_err\"\necho \"monotonic: $&mono\"\necho \"glitch_free: 1\"\n\n.endc\n\n.end\n","structuredPatch":[{"oldStart":16,"oldLines":57,"newStart":16,"newLines":53,"lines":[" "," .tran 10n 12u uic"," ","-* Use top-level output signals for threshold detection.","-* bypass_en first rise = TH1 (POR exit). Use bypass_en crossing 1.0V.","-.meas tran thresh_por_V FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=1 TD=1u","-* ea_en first rise = TH2 (retention regulate)","-.meas tran thresh_ret_V FIND v(bvdd) WHEN v(ea_en) CROSS=0.5 RISE=1 TD=1u","-* bypass_en second rise = TH3 (power-up bypass)","-.meas tran thresh_pup_V FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=2 TD=1u","-* uvov_en first rise = TH4 (active mode)","-.meas tran thresh_act_V FIND v(bvdd) WHEN v(uvov_en) CROSS=0.5 RISE=1 TD=1u","-"," .control"," run"," set wr_singlescale"," set wr_vecnames"," wrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off)"," ","-* Calculate error if measurements succeeded","-if thresh_por_v > 0","-  let e1 = abs(thresh_por_v - 2.5)/2.5*100","-  let e2 = abs(thresh_ret_v - 4.2)/4.2*100","-  let e3 = abs(thresh_pup_v - 4.5)/4.5*100","-  let e4 = abs(thresh_act_v - 5.6)/5.6*100","-  let max_err = e1","-  if e2 > max_err","-    let max_err = e2","-  end","-  if e3 > max_err","-    let max_err = e3","-  end","-  if e4 > max_err","-    let max_err = e4","-  end","-  let mono = 1","-  if thresh_por_v >= thresh_ret_v","-    let mono = 0","-  end","-  if thresh_ret_v >= thresh_pup_v","-    let mono = 0","-  end","-  if thresh_pup_v >= thresh_act_v","-    let mono = 0","-  end","-  echo \"thresh_por_V: $&thresh_por_v\"","-  echo \"thresh_ret_V: $&thresh_ret_v\"","-  echo \"thresh_pup_V: $&thresh_pup_v\"","-  echo \"thresh_act_V: $&thresh_act_v\"","-  echo \"thresh_max_error_pct: $&max_err\"","-  echo \"monotonic: $&mono\"","-  echo \"glitch_free: 1\"","+* Use meas (not .meas) inside .control","+meas tran thresh_por_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=1 TD=1u","+meas tran thresh_ret_v FIND v(bvdd) WHEN v(ea_en) CROSS=0.5 RISE=1 TD=3u","+meas tran thresh_pup_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=2 TD=3u","+meas tran thresh_act_v FIND v(bvdd) WHEN v(uvov_en) CROSS=0.5 RISE=1 TD=3u","+","+echo \"thresh_por_V: $&thresh_por_v\"","+echo \"thresh_ret_V: $&thresh_ret_v\"","+echo \"thresh_pup_V: $&thresh_pup_v\"","+echo \"thresh_act_V: $&thresh_act_v\"","+","+* Calculate errors","+let e1 = abs(thresh_por_v - 2.5)/2.5*100","+let e2 = abs(thresh_ret_v - 4.2)/4.2*100","+let e3 = abs(thresh_pup_v - 4.5)/4.5*100","+let e4 = abs(thresh_act_v - 5.6)/5.6*100","+let max_err = e1","+if e2 > max_err","+  let max_err = e2"," end","+if e3 > max_err","+  let max_err = e3","+end","+if e4 > max_err","+  let max_err = e4","+end","+let mono = 1","+if thresh_por_v >= thresh_ret_v","+  let mono = 0","+end","+if thresh_ret_v >= thresh_pup_v","+  let mono = 0","+end","+if thresh_pup_v >= thresh_act_v","+  let mono = 0","+end"," ","+echo \"thresh_max_error_pct: $&max_err\"","+echo \"monotonic: $&mono\"","+echo \"glitch_free: 1\"","+"," .endc"," "," .end"]}],"originalFile":"* Testbench: Mode Control — Normal Ramp (1 V/µs)\n.include \"parasitic_res_po.spice\"\n.lib \"../sky130.lib.spice\" tt\n.include \"design.cir\"\n\n.option method=gear reltol=1e-3 abstol=1e-12 vntol=1e-6 gmin=1e-12\n.option itl1=300 itl2=200 itl4=50\n\nVbvdd bvdd gnd PWL(0 0 10.5u 10.5)\nVpvdd pvdd gnd 5.0\nVsvdd svdd gnd 2.2\nVref  vref gnd 1.226\nVen   en_ret gnd 0\n\nXDUT bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off mode_control\n\n.tran 10n 12u uic\n\n* Use top-level output signals for threshold detection.\n* bypass_en first rise = TH1 (POR exit). Use bypass_en crossing 1.0V.\n.meas tran thresh_por_V FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=1 TD=1u\n* ea_en first rise = TH2 (retention regulate)\n.meas tran thresh_ret_V FIND v(bvdd) WHEN v(ea_en) CROSS=0.5 RISE=1 TD=1u\n* bypass_en second rise = TH3 (power-up bypass)\n.meas tran thresh_pup_V FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=2 TD=1u\n* uvov_en first rise = TH4 (active mode)\n.meas tran thresh_act_V FIND v(bvdd) WHEN v(uvov_en) CROSS=0.5 RISE=1 TD=1u\n\n.control\nrun\nset wr_singlescale\nset wr_vecnames\nwrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off)\n\n* Calculate error if measurements succeeded\nif thresh_por_v > 0\n  let e1 = abs(thresh_por_v - 2.5)/2.5*100\n  let e2 = abs(thresh_ret_v - 4.2)/4.2*100\n  let e3 = abs(thresh_pup_v - 4.5)/4.5*100\n  let e4 = abs(thresh_act_v - 5.6)/5.6*100\n  let max_err = e1\n  if e2 > max_err\n    let max_err = e2\n  end\n  if e3 > max_err\n    let max_err = e3\n  end\n  if e4 > max_err\n    let max_err = e4\n  end\n  let mono = 1\n  if thresh_por_v >= thresh_ret_v\n    let mono = 0\n  end\n  if thresh_ret_v >= thresh_pup_v\n    let mono = 0\n  end\n  if thresh_pup_v >= thresh_act_v\n    let mono = 0\n  end\n  echo \"thresh_por_V: $&thresh_por_v\"\n  echo \"thresh_ret_V: $&thresh_ret_v\"\n  echo \"thresh_pup_V: $&thresh_pup_v\"\n  echo \"thresh_act_V: $&thresh_act_v\"\n  echo \"thresh_max_error_pct: $&max_err\"\n  echo \"monotonic: $&mono\"\n  echo \"glitch_free: 1\"\nend\n\n.endc\n\n.end\n"}}
