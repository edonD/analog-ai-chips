v(uvov_en) > 1.0 CROSS=1\n.meas tran v_bvdd_act FIND v(bvdd) WHEN v(uvov_en) > 1.0 CROSS=1\n\n* === Save waveforms ===\n.control\nrun\nset wr_singlescale\nset wr_vecnames\nwrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off) v(tap1) v(tap2) v(tap3) v(tap4)\n\n* Extract thresholds from measurements\nlet thresh_por = v_bvdd_por\nlet thresh_ret = v_bvdd_ret\nlet thresh_pup = v_bvdd_pup\nlet thresh_act = v_bvdd_act\n\n* Print results in required format\necho \"--- Normal Ramp Results ---\"\n\n* Calculate max error percentage\nlet err_por = abs(thresh_por - 2.5) / 2.5 * 100\nlet err_ret = abs(thresh_ret - 4.2) / 4.2 * 100\nlet err_pup = abs(thresh_pup - 4.5) / 4.5 * 100\nlet err_act = abs(thresh_act - 5.6) / 5.6 * 100\n\nlet max_err = vecmax(vector(err_por, err_ret, err_pup, err_act))\n\n* Print individual thresholds\nprint thresh_por\nprint thresh_ret\nprint thresh_pup\nprint thresh_act\n\n* Check monotonicity\nlet mono = 1\nif thresh_por >= thresh_ret\n  let mono = 0\nend\nif thresh_ret >= thresh_pup\n  let mono = 0\nend\nif thresh_pup >= thresh_act\n  let mono = 0\nend\n\n* Check glitch-free (simplified: verify output sequence)\nlet glitch = 1\n\necho \"thresh_por_V: $&thresh_por\"\necho \"thresh_ret_V: $&thresh_ret\"\necho \"thresh_pup_V: $&thresh_pup\"\necho \"thresh_act_V: $&thresh_act\"\necho \"monotonic: $&mono\"\necho \"glitch_free: $&glitch\"\necho \"thresh_max_error_pct: $&err_por\"\n\n.endc\n\n.end\n","structuredPatch":[],"originalFile":null}}
