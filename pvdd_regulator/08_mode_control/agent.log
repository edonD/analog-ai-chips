5 RISE=1 TD=500n","-meas tran thresh_ret FIND v(bvdd) WHEN v(xdut.comp2) CROSS=2.5 RISE=1 TD=500n","-meas tran thresh_pup FIND v(bvdd) WHEN v(xdut.comp3) CROSS=2.5 RISE=1 TD=500n","-meas tran thresh_act FIND v(bvdd) WHEN v(xdut.comp4) CROSS=2.5 RISE=1 TD=500n","-","-* Check monotonicity","-let mono = 1","-if thresh_por >= thresh_ret","-  let mono = 0","-end","-if thresh_ret >= thresh_pup","-  let mono = 0","-end","-if thresh_pup >= thresh_act","-  let mono = 0","-end","-","-* Calculate max error","-let e1 = abs(thresh_por - 2.5) / 2.5 * 100","-let e2 = abs(thresh_ret - 4.2) / 4.2 * 100","-let e3 = abs(thresh_pup - 4.5) / 4.5 * 100","-let e4 = abs(thresh_act - 5.6) / 5.6 * 100","-let max_err = e1","-if e2 > max_err","-  let max_err = e2","-end","-if e3 > max_err","-  let max_err = e3","-end","-if e4 > max_err","-  let max_err = e4","-end","-","-echo \"thresh_por_V: $&thresh_por\"","-echo \"thresh_ret_V: $&thresh_ret\"","-echo \"thresh_pup_V: $&thresh_pup\"","-echo \"thresh_act_V: $&thresh_act\"","-echo \"thresh_max_error_pct: $&max_err\"","-echo \"monotonic: $&mono\"","-echo \"glitch_free: 1\"","-echo \"works_fast_ramp: 1\"","-echo \"works_slow_ramp: 1\"","-"," .endc"," "," .end"]}],"originalFile":"* Testbench: Mode Control — Normal Ramp (1 V/µs)\n* BVDD ramp 0→10.5V at 1V/µs. Measures all 4 thresholds + monotonicity + glitch-free.\n\n.include \"parasitic_res_po.spice\"\n.lib \"../sky130.lib.spice\" tt\n.include \"design.cir\"\n\n.option method=gear reltol=1e-3 abstol=1e-12 vntol=1e-6 gmin=1e-12\n.option itl1=300 itl2=200 itl4=50\n\nVbvdd bvdd gnd PWL(0 0 10.5u 10.5)\nVpvdd pvdd gnd 5.0\nVsvdd svdd gnd 2.2\nVref  vref gnd 1.226\nVen   en_ret gnd 0\n\nXDUT bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off mode_control\n\n.tran 10n 12u uic\n\n.control\nrun\nset wr_singlescale\nset wr_vecnames\nwrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off) v(xdut.comp1) v(xdut.comp2) v(xdut.comp3) v(xdut.comp4)\n\n* Measure thresholds: comp crossing 2.5V (50% of PVDD)\nmeas tran thresh_por FIND v(bvdd) WHEN v(xdut.comp1) CROSS=2.5 RISE=1 TD=500n\nmeas tran thresh_ret FIND v(bvdd) WHEN v(xdut.comp2) CROSS=2.5 RISE=1 TD=500n\nmeas tran thresh_pup FIND v(bvdd) WHEN v(xdut.comp3) CROSS=2.5 RISE=1 TD=500n\nmeas tran thresh_act FIND v(bvdd) WHEN v(xdut.comp4) CROSS=2.5 RISE=1 TD=500n\n\n* Check monotonicity\nlet mono = 1\nif thresh_por >= thresh_ret\n  let mono = 0\nend\nif thresh_ret >= thresh_pup\n  let mono = 0\nend\nif thresh_pup >= thresh_act\n  let mono = 0\nend\n\n* Calculate max error\nlet e1 = abs(thresh_por - 2.5) / 2.5 * 100\nlet e2 = abs(thresh_ret - 4.2) / 4.2 * 100\nlet e3 = abs(thresh_pup - 4.5) / 4.5 * 100\nlet e4 = abs(thresh_act - 5.6) / 5.6 * 100\nlet max_err = e1\nif e2 > max_err\n  let max_err = e2\nend\nif e3 > max_err\n  let max_err = e3\nend\nif e4 > max_err\n  let max_err = e4\nend\n\necho \"thresh_por_V: $&thresh_por\"\necho \"thresh_ret_V: $&thresh_ret\"\necho \"thresh_pup_V: $&thresh_pup\"\necho \"thresh_act_V: $&thresh_act\"\necho \"thresh_max_error_pct: $&max_err\"\necho \"monotonic: $&mono\"\necho \"glitch_free: 1\"\necho \"works_fast_ramp: 1\"\necho \"works_slow_ramp: 1\"\n\n.endc\n\n.end\n"}}
