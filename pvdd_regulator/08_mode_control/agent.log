,"-* Actually use fixed threshold relative to BVDD at key points","+echo \"=== Comparator Firing Points ===\"","+echo \"comp1_fires_at: $&v_c1_r\"","+echo \"comp2_fires_at: $&v_c2_r\"","+echo \"comp3_fires_at: $&v_c3_r\"","+echo \"comp4_fires_at: $&v_c4_r\""," ","-* Detect comp1 going HIGH: when c1o rises above BVDD/2","-* Since c1o rises when tap1 > vref, find when c1o crosses BVDD/2","-* Use meas with simple threshold on output signals","+* Check output transitions","+meas tran v_po_f FIND v(bvdd) WHEN v(pass_off) CROSS=1.0 FALL=1 TD=500n","+meas tran v_by_r FIND v(bvdd) WHEN v(bypass_en) CROSS=1.0 RISE=1 TD=500n","+meas tran v_ea_r FIND v(bvdd) WHEN v(ea_en) CROSS=1.0 RISE=1 TD=500n","+meas tran v_uv_r FIND v(bvdd) WHEN v(uvov_en) CROSS=1.0 RISE=1 TD=500n","+echo \"pass_off_falls: $&v_po_f\"","+echo \"bypass_en_rises: $&v_by_r\"","+echo \"ea_en_rises: $&v_ea_r\"","+echo \"uvov_en_rises: $&v_uv_r\""," ","-* pass_off should fall at TH1","-meas tran t_por WHEN v(pass_off) CROSS=1.5 FALL=1 TD=500n","-meas tran v_por_bvdd FIND v(bvdd) WHEN v(pass_off) CROSS=1.5 FALL=1 TD=500n","+* Calculate threshold errors if measurements succeeded","+if v_c1_r > 0","+  let err1 = abs(v_c1_r - 2.5)/2.5*100","+  let err2 = abs(v_c2_r - 4.2)/4.2*100","+  let err3 = abs(v_c3_r - 4.5)/4.5*100","+  let err4 = abs(v_c4_r - 5.6)/5.6*100","+  echo \"thresh_por_V: $&v_c1_r\"","+  echo \"thresh_ret_V: $&v_c2_r\"","+  echo \"thresh_pup_V: $&v_c3_r\"","+  echo \"thresh_act_V: $&v_c4_r\"","+end"," ","-* bypass_en should rise at TH1 (mode 2 = retention bypass)","-meas tran v_bp1 FIND v(bvdd) WHEN v(bypass_en) CROSS=1.5 RISE=1 TD=500n","-","-* ea_en should rise at TH2 (mode 3 = retention regulate)","-meas tran v_ea1 FIND v(bvdd) WHEN v(ea_en) CROSS=1.5 RISE=1 TD=500n","-","-* uvov_en should rise at TH4 (mode 5 = active)","-meas tran v_uv1 FIND v(bvdd) WHEN v(uvov_en) CROSS=1.5 RISE=1 TD=500n","-","-echo \"thresh_por_V: $&v_por_bvdd\"","-echo \"thresh_ret_V: $&v_ea1\"","-echo \"thresh_act_V: $&v_uv1\"","-","-* Print comp crossing info","-meas tran v_c1 FIND v(bvdd) WHEN v(xdut.comp1) CROSS=2.0 RISE=1 TD=100n","-meas tran v_c2 FIND v(bvdd) WHEN v(xdut.comp2) CROSS=2.0 RISE=1 TD=100n","-meas tran v_c3 FIND v(bvdd) WHEN v(xdut.comp3) CROSS=2.0 RISE=1 TD=100n","-meas tran v_c4 FIND v(bvdd) WHEN v(xdut.comp4) CROSS=2.0 RISE=1 TD=100n","-echo \"comp1_fires_at: $&v_c1\"","-echo \"comp2_fires_at: $&v_c2\"","-echo \"comp3_fires_at: $&v_c3\"","-echo \"comp4_fires_at: $&v_c4\"","-"," .endc"," "," .end"]}],"originalFile":"* Testbench: Mode Control — Normal Ramp (1 V/µs)\n.include \"parasitic_res_po.spice\"\n.lib \"../sky130.lib.spice\" tt\n.include \"design.cir\"\n\n.option method=gear reltol=1e-3 abstol=1e-12 vntol=1e-6 gmin=1e-12\n.option itl1=300 itl2=200 itl4=50\n\nVbvdd bvdd gnd PWL(0 0 10.5u 10.5)\nVpvdd pvdd gnd 5.0\nVsvdd svdd gnd 2.2\nVref  vref gnd 1.226\nVen   en_ret gnd 0\n\nXDUT bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off mode_control\n\n.tran 10n 12u uic\n\n.control\nrun\nset wr_singlescale\nset wr_vecnames\nwrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off) v(xdut.comp1) v(xdut.comp2) v(xdut.comp3) v(xdut.comp4) v(xdut.c1o) v(xdut.c2o) v(xdut.c3o) v(xdut.c4o)\n\n* Measure thresholds: use comp outputs (0→BVDD transition)\n* comp1 first rise to BVDD/2 → POR exit\nmeas tran v_por FIND v(bvdd) WHEN v(xdut.comp1) CROSS='v(bvdd)/2' RISE=1 TD=500n\n\n* Use output signal crossings instead (more reliable)\n* pass_off falls from ~BVDD to ~0: detect when pass_off < 0.5*bvdd\n* Actually use fixed threshold relative to BVDD at key points\n\n* Detect comp1 going HIGH: when c1o rises above BVDD/2\n* Since c1o rises when tap1 > vref, find when c1o crosses BVDD/2\n* Use meas with simple threshold on output signals\n\n* pass_off should fall at TH1\nmeas tran t_por WHEN v(pass_off) CROSS=1.5 FALL=1 TD=500n\nmeas tran v_por_bvdd FIND v(bvdd) WHEN v(pass_off) CROSS=1.5 FALL=1 TD=500n\n\n* bypass_en should rise at TH1 (mode 2 = retention bypass)\nmeas tran v_bp1 FIND v(bvdd) WHEN v(bypass_en) CROSS=1.5 RISE=1 TD=500n\n\n* ea_en should rise at TH2 (mode 3 = retention regulate)\nmeas tran v_ea1 FIND v(bvdd) WHEN v(ea_en) CROSS=1.5 RISE=1 TD=500n\n\n* uvov_en should rise at TH4 (mode 5 = active)\nmeas tran v_uv1 FIND v(bvdd) WHEN v(uvov_en) CROSS=1.5 RISE=1 TD=500n\n\necho \"thresh_por_V: $&v_por_bvdd\"\necho \"thresh_ret_V: $&v_ea1\"\necho \"thresh_act_V: $&v_uv1\"\n\n* Print comp crossing info\nmeas tran v_c1 FIND v(bvdd) WHEN v(xdut.comp1) CROSS=2.0 RISE=1 TD=100n\nmeas tran v_c2 FIND v(bvdd) WHEN v(xdut.comp2) CROSS=2.0 RISE=1 TD=100n\nmeas tran v_c3 FIND v(bvdd) WHEN v(xdut.comp3) CROSS=2.0 RISE=1 TD=100n\nmeas tran v_c4 FIND v(bvdd) WHEN v(xdut.comp4) CROSS=2.0 RISE=1 TD=100n\necho \"comp1_fires_at: $&v_c1\"\necho \"comp2_fires_at: $&v_c2\"\necho \"comp3_fires_at: $&v_c3\"\necho \"comp4_fires_at: $&v_c4\"\n\n.endc\n\n.end\n"}}
