r topology:","-*   PMOS diff pair: M_p1 gate=tap (mirror input), M_p2 gate=vref (output)","-*   NMOS mirror load: M_n3 diode on p1 side, M_n4 mirrors to p2 side","-*   When tap > vref: |Vgs_p1| < |Vgs_p2| → I_p1 < I_p2 → c_out rises HIGH","-*   At startup (BVDD≈0): no current → c_out ≈ 0 → comp = 0 (POR state) ✓","-*   Buffer: 2 inverters (non-inverting) → comp = c_out polarity","+* Comparator: NMOS diff pair, M_n1 gate=tap (+), M_n2 gate=vref (-)","+*   PMOS mirror: M_p3 diode on n1 side, M_p4 on n2 side","+*   When tap > vref: I_n1 > I_n2, mirror forces I_p4=I_n1 > I_n2 → c_o rises → HIGH","+*   c_o → 2 inverters → comp = c_o (non-inverting)","+*   Startup: c_o ≈ 0 when no current → comp = 0 (POR) ✓"," *"," .subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off"," "," * =============================================","-* CONVERGENCE AIDS","+* RESISTOR LADDER"," * =============================================","-C_tap1 tap1 gnd 100f","-C_tap2 tap2 gnd 100f","-C_tap3 tap3 gnd 100f","-C_tap4 tap4 gnd 100f","-","-* =============================================","-* RESISTOR LADDER: BVDD to GND","-* ============================================="," .param rtop_l = 241"," .param r12_l  = 94"," .param r23_l  = 9.2"]},{"oldStart":37,"oldLines":27,"newStart":27,"newLines":30,"lines":[" XR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l"," XRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l"," ","+* Convergence caps on taps","+C_tap1 tap1 gnd 100f","+C_tap2 tap2 gnd 100f","+C_tap3 tap3 gnd 100f","+C_tap4 tap4 gnd 100f","+"," * =============================================","-* BIAS GENERATOR","+* BIAS GENERATOR: ~2µA at BVDD=7V"," * ============================================="," XRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400"," XMnbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-* P-type bias","-XMpb_n pbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-XMpb_p 