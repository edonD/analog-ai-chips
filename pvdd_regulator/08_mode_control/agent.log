c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM4iv1n c4ob c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM4iv2p comp4 c4ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM4iv2n comp4 c4ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4pt c4tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","+XM4p1 c4on vref  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4p2 c4o  tap4  c4tail c4tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM4n3 c4on c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM4n4 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM4fb1 c4on c4o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XM4fb2 c4o  c4on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XM4ivp comp4 c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XM4ivn comp4 c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * ============================================="," * LOGIC DECODING"]},{"oldStart":131,"oldLines":43,"newStart":129,"newLines":35,"lines":[" XMinv4p comp4b comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMinv4n comp4b comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," ","-* --- pass_off = NOT(comp1) = comp1b buffered ---","-* Pull-up resistor ensures pass_off HIGH when BVDD very low (POR bootstrap)","+* --- pass_off = NOT(comp1) = comp1b ---"," XRpo_pu bvdd pass_off gnd sky130_fd_pr__res_xhigh_po w=1 l=50"," XMpo_bufp pass_off comp1b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * --- bypass_en = comp1·comp2b + comp3·comp4b ---","-* AOI gate: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)","-* NMOS pull-down: two series pairs in parallel","+* AOI: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)"," XMby_n1a by_s1     comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n1b bypass_enb comp2b by_s1 by_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n2a by_s2     comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMby_n2b bypass_enb comp4b by_s2 by_s2 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-* PMOS pull-up: (comp1||comp3) series (comp2b||comp4b)"," XMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-* Output inverter"," XMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * --- ea_en = comp2·comp3b + comp4 ---","-* AOI gate: ea_enb = NOT(comp2·comp3b + comp4)"," XMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-* PMOS: (comp2||comp3b) series comp4"," XMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-* Output inverter"," XMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"," XMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * --- ref_sel = comp1·comp3b ---","-* NAND + INV"," XMrs_n1 rs_s1    comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," XMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6"]}],"originalFile":"* Block 08: Mode Control\n* PVDD 5V LDO Regulator — SkyWater SKY130A\n*\n* Architecture: Shared resistor ladder + 4 HV comparators with hysteresis + CMOS logic\n*\n* Resistor ladder: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND\n*   tap1 = highest voltage (trips at lowest BVDD = TH1 = 2.5V)\n*   tap4 = lowest voltage (trips at highest BVDD = TH4 = 5.6V)\n*\n* UNITS: MOSFETs use SI (meters), Resistors use µm (per PDK model convention)\n* HV device model valid range: L=20-100µm, W=20-100µm\n*\n.subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off\n\n* =============================================\n* CONVERGENCE AIDS\n* =============================================\nC_tap1 tap1 gnd 50f\nC_tap2 tap2 gnd 50f\nC_tap3 tap3 gnd 50f\nC_tap4 tap4 gnd 50f\nC_c1o  c1o  gnd 20f\nC_c2o  c2o  gnd 20f\nC_c3o  c3o  gnd 20f\nC_c4o  c4o  gnd 20f\n\n* =============================================\n* RESISTOR LADDER: BVDD to GND (w,l in µm)\n* =============================================\n* Ratios for threshold targets:\n*   TH1=2.5V: (R12+R23+R34+Rbot)/Rtot = 1.226/2.5 = 0.4904\n*   TH2=4.2V: (R23+R34+Rbot)/Rtot     = 1.226/4.2 = 0.29190\n*   TH3=4.5V: (R34+Rbot)/Rtot         = 1.226/4.5 = 0.27244\n*   TH4=5.6V: Rbot/Rtot               = 1.226/5.6 = 0.21893\n*\n.param rtop_l = 241\n.param r12_l  = 94\n.param r23_l  = 9.2\n.param r34_l  = 25\n.param rbot_l = 103\n\nXRtop bvdd tap1 gnd sky130_fd_pr__res_xhigh_po w=1 l=rtop_l\nXR12  tap1 tap2 gnd sky130_fd_pr__res_xhigh_po w=1 l=r12_l\nXR23  tap2 tap3 gnd sky130_fd_pr__res_xhigh_po w=1 l=r23_l\nXR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l\nXRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l\n\n* =============================================\n* BIAS GENERATOR: shared current reference ~2µA at BVDD=7V\n* =============================================\n* 3MΩ resistor (l=1400µm) + diode-connected NMOS\nXRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400\nXMbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\n\n* =============================================\n* COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)\n* =============================================\n* PMOS current mirror load\nXM1p3 c1on c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM1p4 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\n* NMOS diff pair: tap1 (+), vref (-)\nXM1n1 c1on tap1 c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM1n2 c1o  vref c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n* Tail current (mirrored from bias)\nXM1t c1tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\n* Positive feedback: weak cross-coupled PMOS for hysteresis\nXM1fb1 c1on c1o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6\nXM1fb2 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6\n* Output buffer: two inverters\nXM1iv1p c1ob c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM1iv1n c1ob c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM1iv2p comp1 c1ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM1iv2n comp1 c1ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 2: tap2 vs vref — TH2 = 4.2V\n* =============================================\nXM2p3 c2on c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2p4 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2n1 c2on tap2 c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6\nXM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6\nXM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6\nXM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2