omp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMrs_p2 ref_selb comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMrs_outp ref_sel ref_selb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMrs_outn ref_sel ref_selb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," ","-* --- uvov_en = comp4 (buffer) ---","-XMuv_p1 uvov_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","-XMuv_n1 uvov_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","-XMuv_p2 uvov_en uvov_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","-XMuv_n2 uvov_en uvov_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+* --- uvov_en = comp4 (double buffer) ---","+XMuv_p1 uvov_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMuv_n1 uvov_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XMuv_p2 uvov_en uvov_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMuv_n2 uvov_en uvov_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," ","-* --- ilim_en = comp4 (buffer) ---","-XMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","-XMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","-XMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","-XMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+* --- ilim_en = comp4 (double buffer) ---","+XMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," .ends mode_control"]}],"originalFile":"* Block 08: Mode Control\n* PVDD 5V LDO Regulator — SkyWater SKY130A\n*\n* Architecture: Shared resistor ladder + 4 HV comparators with hysteresis + CMOS logic\n*\n* Resistor ladder: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND\n*   tap1 = highest voltage (trips at lowest BVDD = TH1 = 2.5V)\n*   tap4 = lowest voltage (trips at highest BVDD = TH4 = 5.6V)\n*\n* HV devices (sky130_fd_pr__nfet/pfet_g5v0d10v5): Lmin=20µm, Wmin=20µm\n* With ngbehavior=hs, W/L values in µm.\n*\n.subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off\n\n* =============================================\n* CONVERGENCE AIDS\n* =============================================\nC_tap1 tap1 gnd 50f\nC_tap2 tap2 gnd 50f\nC_tap3 tap3 gnd 50f\nC_tap4 tap4 gnd 50f\n\n* =============================================\n* RESISTOR LADDER: BVDD to GND\n* =============================================\n* sky130_fd_pr__res_xhigh_po: Rsh ≈ 2000 Ω/sq, w and l in µm\n* R ≈ 2119 * (l - 0.06)\n*\n* Ratios for threshold targets:\n*   TH1=2.5V: (R12+R23+R34+Rbot)/Rtot = 1.226/2.5 = 0.4904\n*   TH2=4.2V: (R23+R34+Rbot)/Rtot     = 1.226/4.2 = 0.29190\n*   TH3=4.5V: (R34+Rbot)/Rtot         = 1.226/4.5 = 0.27244\n*   TH4=5.6V: Rbot/Rtot               = 1.226/5.6 = 0.21893\n*\n.param rtop_l = 241\n.param r12_l  = 94\n.param r23_l  = 9.2\n.param r34_l  = 25\n.param rbot_l = 103\n\nXRtop bvdd tap1 gnd sky130_fd_pr__res_xhigh_po w=1 l=rtop_l\nXR12  tap1 tap2 gnd sky130_fd_pr__res_xhigh_po w=1 l=r12_l\nXR23  tap2 tap3 gnd sky130_fd_pr__res_xhigh_po w=1 l=r23_l\nXR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l\nXRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l\n\n* =============================================\n* BIAS GENERATOR: shared current reference ~2µA at BVDD=7V\n* =============================================\nXRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400\nXMbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\n\n* =============================================\n* COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)\n* =============================================\n* PMOS current mirror load\nXM1p3 c1on c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM1p4 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\n* NMOS diff pair: tap1 (+), vref (-)\nXM1n1 c1on tap1 c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM1n2 c1o  vref c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n* Tail current (mirrored from bias)\nXM1t c1tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\n* Positive feedback: weak cross-coupled PMOS for hysteresis\nXM1fb1 c1on c1o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM1fb2 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\n* Output buffer: two inverters for clean rail-to-rail digital output\nXM1iv1p c1ob c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM1iv1n c1ob c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM1iv2p comp1 c1ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM1iv2n comp1 c1ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* =============================================\n* COMPARATOR 2: tap2 vs vref — TH2 = 4.2V\n* =============================================\nXM2p3 c2on c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM2p4 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=50\nXM2n1 c2on tap2 c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=100\nXM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20 l=100\nXM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\nXM2iv2p comp2 c2ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20\nXM2iv2n comp2 c2ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20\n\n* =================