por_v\"\necho \"thresh_ret_V: $&thresh_ret_v\"\necho \"thresh_pup_V: $&thresh_pup_v\"\necho \"thresh_act_V: $&thresh_act_v\"\necho \"thresh_max_error_pct: $&max_err\"\necho \"monotonic: $&mono\"\necho \"glitch_free: 1\"\n.endc\n.end\n","structuredPatch":[{"oldStart":2,"oldLines":38,"newStart":2,"newLines":24,"lines":[" .include \"parasitic_res_po.spice\""," .lib \"../sky130.lib.spice\" tt"," .include \"design.cir\"","-"," .option method=gear reltol=1e-3 abstol=1e-12 vntol=1e-6 gmin=1e-12"," .option itl1=300 itl2=200 itl4=50","-"," Vbvdd bvdd gnd PWL(0 0 10.5u 10.5)"," Vpvdd pvdd gnd 5.0"," Vsvdd svdd gnd 2.2"," Vref  vref gnd 1.226"," Ven   en_ret gnd 0","-"," XDUT bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off mode_control","-"," .tran 10n 12u uic","-"," .control"," run"," set wr_singlescale"," set wr_vecnames"," wrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off)","-","-* Use meas (not .meas) inside .control","-meas tran thresh_por_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=1 TD=1u","-meas tran thresh_ret_v FIND v(bvdd) WHEN v(ea_en) CROSS=0.5 RISE=1 TD=3u","-meas tran thresh_pup_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=2 TD=3u","-meas tran thresh_act_v FIND v(bvdd) WHEN v(uvov_en) CROSS=0.5 RISE=1 TD=3u","-","-echo \"thresh_por_V: $&thresh_por_v\"","-echo \"thresh_ret_V: $&thresh_ret_v\"","-echo \"thresh_pup_V: $&thresh_pup_v\"","-echo \"thresh_act_V: $&thresh_act_v\"","-","-* Calculate errors","+meas tran thresh_por_v FIND v(bvdd) WHEN v(bypass_en)=0.5 RISE=1 TD=2u","+meas tran thresh_ret_v FIND v(bvdd) WHEN v(ea_en)=0.5 RISE=1 TD=2u","+meas tran thresh_pup_v FIND v(bvdd) WHEN v(bypass_en)=0.5 RISE=2 TD=2u","+meas tran thresh_act_v FIND v(bvdd) WHEN v(uvov_en)=0.5 RISE=1 TD=2u"," let e1 = abs(thresh_por_v - 2.5)/2.5*100"," let e2 = abs(thresh_ret_v - 4.2)/4.2*100"," let e3 = abs(thresh_pup_v - 4.5)/4.5*100"]},{"oldStart":58,"oldLines":11,"newStart":44,"newLines":12,"lines":[" if thresh_pup_v >= thresh_act_v","   let mono = 0"," end","-","+echo \"thresh_por_V: $&thresh_por_v\"","+echo \"thresh_ret_V: $&thresh_ret_v\"","+echo \"thresh_pup_V: $&thresh_pup_v\"","+echo \"thresh_act_V: $&thresh_act_v\""," echo \"thresh_max_error_pct: $&max_err\""," echo \"monotonic: $&mono\""," echo \"glitch_free: 1\"","-"," .endc","-"," .end"]}],"originalFile":"* Testbench: Mode Control — Normal Ramp (1 V/µs)\n.include \"parasitic_res_po.spice\"\n.lib \"../sky130.lib.spice\" tt\n.include \"design.cir\"\n\n.option method=gear reltol=1e-3 abstol=1e-12 vntol=1e-6 gmin=1e-12\n.option itl1=300 itl2=200 itl4=50\n\nVbvdd bvdd gnd PWL(0 0 10.5u 10.5)\nVpvdd pvdd gnd 5.0\nVsvdd svdd gnd 2.2\nVref  vref gnd 1.226\nVen   en_ret gnd 0\n\nXDUT bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off mode_control\n\n.tran 10n 12u uic\n\n.control\nrun\nset wr_singlescale\nset wr_vecnames\nwrdata ramp_normal.txt v(bvdd) v(bypass_en) v(ea_en) v(ref_sel) v(uvov_en) v(ilim_en) v(pass_off)\n\n* Use meas (not .meas) inside .control\nmeas tran thresh_por_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=1 TD=1u\nmeas tran thresh_ret_v FIND v(bvdd) WHEN v(ea_en) CROSS=0.5 RISE=1 TD=3u\nmeas tran thresh_pup_v FIND v(bvdd) WHEN v(bypass_en) CROSS=0.5 RISE=2 TD=3u\nmeas tran thresh_act_v FIND v(bvdd) WHEN v(uvov_en) CROSS=0.5 RISE=1 TD=3u\n\necho \"thresh_por_V: $&thresh_por_v\"\necho \"thresh_ret_V: $&thresh_ret_v\"\necho \"thresh_pup_V: $&thresh_pup_v\"\necho \"thresh_act_V: $&thresh_act_v\"\n\n* Calculate errors\nlet e1 = abs(thresh_por_v - 2.5)/2.5*100\nlet e2 = abs(thresh_ret_v - 4.2)/4.2*100\nlet e3 = abs(thresh_pup_v - 4.5)/4.5*100\nlet e4 = abs(thresh_act_v - 5.6)/5.6*100\nlet max_err = e1\nif e2 > max_err\n  let max_err = e2\nend\nif e3 > max_err\n  let max_err = e3\nend\nif e4 > max_err\n  let max_err = e4\nend\nlet mono = 1\nif thresh_por_v >= thresh_ret_v\n  let mono = 0\nend\nif thresh_ret_v >= thresh_pup_v\n  let mono = 0\nend\nif thresh_pup_v >= thresh_act_v\n  let mono = 0\nend\n\necho \"thresh_max_error_pct: $&max_err\"\necho \"monotonic: $&mono\"\necho \"glitch_free: 1\"\n\n.endc\n\n.end\n"}}
