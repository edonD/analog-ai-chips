\n.param r34_l  = 25\n.param rbot_l = 103\n\nXRtop bvdd tap1 gnd sky130_fd_pr__res_xhigh_po w=1 l=rtop_l\nXR12  tap1 tap2 gnd sky130_fd_pr__res_xhigh_po w=1 l=r12_l\nXR23  tap2 tap3 gnd sky130_fd_pr__res_xhigh_po w=1 l=r23_l\nXR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l\nXRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l\n\n* =============================================\n* BIAS GENERATOR: shared current reference ~2µA at BVDD=7V\n* =============================================\n* 3MΩ resistor (l=1400µm) + diode-connected NMOS\nXRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400\nXMbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=100e-6\n\n* =============================================\n* COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)\n* =============================================\n* PMOS current mirror load\nXM1p3 c1on c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM1p4 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\n* NMOS diff pair: tap1 (+), vref (-)\nXM1n1 c1on tap1 c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM1n2 c1o  vref c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n* Tail current (mirrored from bias)\nXM1t c1tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=100e-6\n* Positive feedback: weak cross-coupled PMOS for hysteresis\nXM1fb1 c1on c1o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM1fb2 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\n* Output buffer: two inverters\nXM1iv1p c1ob c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM1iv1n c1ob c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM1iv2p comp1 c1ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM1iv2n comp1 c1ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 2: tap2 vs vref — TH2 = 4.2V\n* =============================================\nXM2p3 c2on c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2p4 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM2n1 c2on tap2 c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=100e-6\nXM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM2iv2p comp2 c2ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM2iv2n comp2 c2ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 3: tap3 vs vref — TH3 = 4.5V\n* =============================================\nXM3p3 c3on c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM3p4 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM3n1 c3on tap3 c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM3n2 c3o  vref c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM3t c3tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=100e-6\nXM3fb1 c3on c3o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM3fb2 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM3iv1p c3ob c3o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM3iv1n c3ob c3o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM3iv2p comp3 c3ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM3iv2n comp3 c3ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* COMPARATOR 4: tap4 vs vref — TH4 = 5.6V\n* =============================================\nXM4p3 c4on c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM4p4 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6\nXM4n1 c4on tap4 c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM4n2 c4o  vref c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM4t c4tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=100e-6\nXM4fb1 c4on c4o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM4fb2 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=100e-6\nXM4iv1p c4ob c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM4iv1n c4ob c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXM4iv2p comp4 c4ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXM4iv2n comp4 c4ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* =============================================\n* LOGIC DECODING\n* =============================================\n\n* Inverted comparator outputs\nXMinv1p comp1b comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv1n comp1b comp1 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv2p comp2b comp2 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv2n comp2b comp2 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv3p comp3b comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv3n comp3b comp3 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMinv4p comp4b comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMinv4n comp4b comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- pass_off = NOT(comp1) = comp1b buffered ---\n* Pull-up resistor ensures pass_off HIGH when BVDD very low (POR bootstrap)\nXRpo_pu bvdd pass_off gnd sky130_fd_pr__res_xhigh_po w=1 l=50\nXMpo_bufp pass_off comp1b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- bypass_en = comp1·comp2b + comp3·comp4b ---\n* AOI gate: bypass_enb = NOT(comp1·comp2b + comp3·comp4b)\n* NMOS pull-down: two series pairs in parallel\nXMby_n1a by_s1     comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n1b bypass_enb comp2b by_s1 by_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n2a by_s2     comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMby_n2b bypass_enb comp4b by_s2 by_s2 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n* PMOS pull-up: (comp1||comp3) series (comp2b||comp4b)\nXMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\n* Output inverter\nXMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ea_en = comp2·comp3b + comp4 ---\n* AOI gate: ea_enb = NOT(comp2·comp3b + comp4)\nXMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n* PMOS: (comp2||comp3b) series comp4\nXMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\n* Output inverter\nXMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ref_sel = comp1·comp3b ---\n* NAND + INV\nXMrs_n1 rs_s1    comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMrs_p2 ref_selb comp3b bv