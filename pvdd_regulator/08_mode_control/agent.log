d  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n* --- ilim_en = comp4 (double buffer) ---\nXMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\nXMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6\nXMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6\n\n.ends mode_control\n","structuredPatch":[{"oldStart":1,"oldLines":15,"newStart":1,"newLines":12,"lines":[" * Block 08: Mode Control"," * PVDD 5V LDO Regulator — SkyWater SKY130A"," *","-* Architecture: Shared resistor ladder + 4 HV comparators with hysteresis + CMOS logic","+* Architecture: Shared resistor ladder + 4 HV comparators + CMOS logic"," *","-* Resistor ladder: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND","-*   tap1 = highest voltage (trips at lowest BVDD = TH1 = 2.5V)","-*   tap4 = lowest voltage (trips at highest BVDD = TH4 = 5.6V)","+* Key: PMOS diff pair comparators (work when inputs near GND/vref)","+* UNITS: MOSFETs = SI (meters), Resistors = µm (PDK convention)","+* HV model valid: L=[20,100)µm, W=[20,100)µm"," *","-* UNITS: MOSFETs use SI (meters), Resistors use µm (per PDK model convention)","-* HV device model valid range: L=20-100µm, W=20-100µm","-*"," .subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off"," "," * ============================================="]},{"oldStart":19,"oldLines":19,"newStart":16,"newLines":12,"lines":[" C_tap2 tap2 gnd 50f"," C_tap3 tap3 gnd 50f"," C_tap4 tap4 gnd 50f","-C_c1o  c1o  gnd 20f","-C_c2o  c2o  gnd 20f","-C_c3o  c3o  gnd 20f","-C_c4o  c4o  gnd 20f"," "," * ============================================="," * RESISTOR LADDER: BVDD to GND (w,l in µm)"," * =============================================","-* Ratios for threshold targets:","-*   TH1=2.5V: (R12+R23+R34+Rbot)/Rtot = 1.226/2.5 = 0.4904","-*   TH2=4.2V: (R23+R34+Rbot)/Rtot     = 1.226/4.2 = 0.29190","-*   TH3=4.5V: (R34+Rbot)/Rtot         = 1.226/4.5 = 0.27244","-*   TH4=5.6V: Rbot/Rtot               = 1.226/5.6 = 0.21893","+* Tap arrangement: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND","+* tap1 = highest voltage (first to cross vref as BVDD rises)"," *"," .param rtop_l = 241"," .param r12_l  = 94"]},{"oldStart":46,"oldLines":76,"newStart":36,"newLines":84,"lines":[" XRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l"," "," * =============================================","-* BIAS GENERATOR: shared current reference ~2µA at BVDD=7V","+* BIAS GENERATOR"," * =============================================","-* 3MΩ resistor (l=1400µm) + diode-connected NMOS","+* N-type bias: resistor from BVDD + diode-connected NMOS"," XRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400","-XMbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XMnbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6"," ","+* P-type bias: NMOS drains PMOS diode → sets pbias voltage","+XMpb_n pbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XMpb_p pbias pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","+"," * ============================================="," * COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)"," * =============================================","-* PMOS current mirror load","-XM1p3 c1on c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM1p4 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-* NMOS diff pair: tap1 (+), vref (-)","-XM1n1 c1on tap1 c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM1n2 c1o  vref c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-* Tail current (mirrored from bias)","-XM1t c1tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-* Positive feedback: weak cross-coupled PMOS for hysteresis","-XM1fb1 c1on c1o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6","-XM1fb2 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6","-* Output buffer: two inverters","-XM1iv1p c1ob c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM1iv1n c1ob c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM1iv2p comp1 c1ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM1iv2n comp1 c1ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+* PMOS diff pair (sources=tail, gates=inputs, drains=outputs)","+* When tap1 > vref: |Vgs_p1| < |Vgs_p2| → less current thru M_p1 → mirror pulls c1o LOW","+* After two inverters: comp1 = LOW when tap1 > vref... WRONG!","+* Fix: swap the mirror/output connections","+* M_p1 gate=vref (reference, + side → mirror input)","+* M_p2 gate=tap1 (signal, - side → output)","+* When tap1 > vref: I_p2 < I_p1 → mirror sinks more than M_p2 supplies → c1o drops → LOW","+* After 2 inverters: comp1 = LOW. Still wrong!","+*","+* Solution: use single inverter buffer (odd number of inversions)","+* c1o goes LOW when tap1 > vref → c1ob (inv1) goes HIGH → comp1 = HIGH ✓ (if buffer = 1 inv)","+*","+* PMOS tail current source (mirrors pbias)","+XM1pt c1tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","+* PMOS diff pair","+XM1p1 c1on vref  c1tail c1tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM1p2 c1o  tap1  c1tail c1tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+* NMOS current mirror load","+XM1n3 c1on c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM1n4 c1o  c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+* Positive feedback: weak cross-coupled NMOS for hysteresis","+XM1fb1 c1on c1o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XM1fb2 c1o  c1on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+* Output buffer: single inverter (c1o LOW when tap>vref → comp1 HIGH)","+XM1ivp comp1 c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XM1ivn comp1 c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * ============================================="," * COMPARATOR 2: tap2 vs vref — TH2 = 4.2V"," * =============================================","-XM2p3 c2on c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM2p4 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM2n1 c2on tap2 c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","-XM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6","-XM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=99e-6","-XM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","-XM2iv2p comp2 c2ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","-XM2iv2n comp2 c2ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6","+XM2pt c2tail pbias bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","+XM2p1 c2on vref  c2tail c2tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM2p2 c2o  tap2  c2tail c2tail sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=20e-6","+XM2n3 c2on c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM2n4 c2o  c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=50e-6","+XM2fb1 c2on c2o  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XM2fb2 c2o  c2on gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=99e-6","+XM2ivp comp2 c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40e-6 l=20e-6","+XM2ivn comp2 c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20e-6 l=20e-6"," "," * ============================================="," * COMPARATOR 3: tap3 vs vref — TH3 = 4.5V"," * =============================================","-XM3p3 c3on c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM3p4 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=20e-6 l=50e-6","-XM3n1 c3on tap3 c3tail gnd sky130_fd_pr