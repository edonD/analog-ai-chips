_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMbp2b bp_int  comp4b bp_mid2 bp_mid2 sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-","-* NMOS pull-down network (parallel pairs in series for OR-AND):","-* Term A pull-down: comp1 and comp2b in series","-XMbn1a bn_mid1 comp1  bp_int gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMbn1b bn_mid1 comp2b gnd    gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-* Term B pull-down: comp3 and comp4b in series","-XMbn2a bn_mid2 comp3  bp_int gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMbn2b bn_mid2 comp4b gnd    gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-","-* Wait - the above doesn't implement the right function.","-* Let me use a simpler approach: two NAND gates + NOR gate.","-","-* Actually, let me simplify. Use a direct CMOS implementation:","-* bypass_en = (comp1 AND comp2b) OR (comp3 AND comp4b)","-*","-* AOI (AND-OR-INVERT) gate output = NOT(bypass_en)","-* NMOS network: two series pairs in parallel pulling down","-*   Path 1: comp1 series comp2b","-*   Path 2: comp3 series comp4b","-* PMOS network: two parallel pairs in series pulling up","-*   Group 1: comp1 parallel comp3","-*   Group 2: comp2b parallel comp4b","-","-* NMOS pull-down (pulls bypass_enb LOW when bypass_en should be HIGH)","-XMby_n1a by_s1  comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMby_n1b bypass_enb comp2b by_s1 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMby_n2a by_s2  comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMby_n2b bypass_enb comp4b by_s2 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-","-* PMOS pull-up (complement: pulls bypass_enb HIGH when bypass_en should be LOW)","-* PU = (comp1b+comp3b) · (comp2+comp4)","-* Group 1: comp1 and comp3 in series → both OFF (gates HIGH when comp active)","-* Actually for AOI PMOS: series of parallel groups","-* Group A: comp1 || comp3 (either gates LOW → PMOS ON)","-* Group B: comp2b || comp4b (either gates LOW → PMOS ON)","-* Series: Group A — bypass_enb — Group B","-XMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-","-* Output inverter: bypass_en = NOT(bypass_enb)","-XMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1","-","-* --- ea_en = comp2·NOT(comp3) + comp4 ---","-* AOI: ea_enb = NOT(comp2·comp3b + comp4)","-* NMOS: path1 = comp2 series comp3b; path2 = comp4 alone; parallel","-XMea_n1a ea_s1   comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMea_n1b ea_enb  comp3b ea_s1 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMea_n2  ea_enb  comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-* PMOS: complement of (comp2·comp3b + comp4) = (comp2b+comp3)·comp4b","-* Group A: comp2 || comp3b in series with comp4","-XMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","-XMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1","+* --- ea_en = comp2·comp3b + comp4 ---","+* AOI gate: ea_enb = NOT(comp2·comp3b + comp4)","+XMea_n1a ea_s1  comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMea_n1b ea_enb comp3b ea_s1 ea_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMea_n2  ea_enb comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+* PMOS: (comp2b||comp3) series comp4b","+XMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20"," * Output inverter","-XMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1","+XMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20"," ","-* --- ref_sel = comp1 · NOT(comp3) ---","-* NAND then invert: ref_selb = NOT(comp1 · comp3b) = NAND(comp1, comp3b)","-* NMOS: comp1 series comp3b","-XMrs_n1 rs_s1   comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-XMrs_n2 ref_selb comp3b rs_s1 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1","-* PMOS: comp1 parallel comp3b (either OFF → pull up)","-XMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMrs_p2 ref_selb comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-* Invert to get ref_sel","-XMrs_outp ref_sel ref_selb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMrs_outn ref_sel ref_selb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1","+* --- ref_sel = comp1·comp3b ---","+* NAND gate: ref_selb = NOT(comp1·comp3b) = NAND(comp1, comp3b)","+XMrs_n1 rs_s1    comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMrs_n2 ref_selb comp3b rs_s1 rs_s1 sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMrs_p1 ref_selb comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMrs_p2 ref_selb comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+* Inverter","+XMrs_outp ref_sel ref_selb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMrs_outn ref_sel ref_selb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20"," ","-* --- uvov_en = comp4 ---","-* Buffer","-XMuv_p uvov_en comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMuv_n uvov_en comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1","+* --- uvov_en = comp4 (buffer) ---","+XMuv_p1 uvov_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMuv_n1 uvov_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMuv_p2 uvov_en uvov_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMuv_n2 uvov_en uvov_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20"," ","-* --- ilim_en = comp4 ---","-* Buffer","-XMil_p ilim_en comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1","-XMil_n ilim_en comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1","+* --- ilim_en = comp4 (buffer) ---","+XMil_p1 ilim_enb comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMil_n1 ilim_enb comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20","+XMil_p2 ilim_en ilim_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=40 l=20","+XMil_n2 ilim_en ilim_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=20 l=20"," "," .ends mode_control"]}],"originalFile":"* Block 08: Mode Control\n* PVDD 5V LDO Regulator — SkyWater SKY130A\n*\n* Architecture: Shared resistor ladder + 4 HV comparators with hysteresis + CMOS logic\n*\n* Resistor ladder: BVDD → Rtop → tap1 → R12 → tap2 → R23 → tap3 → R34 → tap4 → Rbot → GND\n*   tap1 = highest voltage (trips at lowest BVDD = TH1 = 2.5V)\n*   tap4 = lowest voltage (trips at highest BVDD = TH4 = 5.6V)\n*\n* Each comparator: NMOS diff pair + PMOS mirror + cross-coupled PMOS positive feedback\n* Hysteresis via weak cross-coupled PMOS pair overlaid on the mirror load.\n*\n* Logic decoding (monotonic thermometer code → control outputs):\n*   pass_off  = NOT(comp1)\n*   bypass_en = comp1·NOT(comp2) + comp3·NOT(comp4)\n*   ea_en     = comp2·NOT(comp3) + comp4\n*   ref_sel   = comp1·NOT(comp3)\n*   uvov_en   = comp4\n*   ilim_en   = comp4\n*\n* Subcircuit signature per specification:\n.subckt mode_control bvdd pvdd svdd gnd vref en_ret bypass_en ea_en ref_sel uvov_en ilim_en pass_off\n\n* =============================================\n* CONVERGENCE AIDS\n* =============================================\n* Small caps on high-impedance nodes for convergence\nC_tap1 tap1 gnd 50f\nC_tap2 tap2 gnd 50f\nC_tap3 tap3 gnd 50f\nC_tap4 tap4 gnd 50f\n\n* =============================================\n* RESISTOR LADDER: BVDD to GND\n* =============================================\n* sky130_fd_pr__res_xhigh_po: Rsh ≈ 2000 Ω/sq, w=1µm\n* R ≈ 2000 * (l - 0.06) / (1 - 0.056) ≈ 2119 * (l - 0.06)\n*\n* Ratios for threshold targets (tap = vref when BVDD = THx):\n*   TH1=2.5V: (R12+R23+R34+Rbot)/Rtot = 1.226/2.5 = 0.4904\n*   TH2=4.2V: (R23+R34+Rbot)/Rtot     = 1.226/4.2 = 0.29190\n*   TH3=4.5V: (R34+Rbot)/Rtot         = 1.226/4.5 = 0.27244\n*   TH4=5.6V: Rbot/Rtot               = 1.226/5.6 = 0.21893\n*\n.param rtop_l = 241\n.param r12_l  = 94\n.param r23_l  = 9.2\n.param r34_l  = 25\n.param rbot_l = 103\n\nXRtop bvdd tap1 gnd sky130_fd_pr__res_xhigh_po w=1 l=rtop_l\nXR12  tap1 tap2 gnd sky130_fd_pr__res_xhigh_po w=1 l=r12_l\nXR23  tap2 tap3 gnd sky130_fd_pr__res_xhigh_po w=1 l=r23_l\nXR34  tap3 tap4 gnd sky130_fd_pr__res_xhigh_po w=1 l=r34_l\nXRbot tap4 gnd  gnd sky130_fd_pr__res_xhigh_po w=1 l=rbot_l\n\n* =============================================\n* BIAS GENERATOR: shared current reference\n* =============================================\n* Resistor from BVDD sets ~2µA through diode-connected NMOS\n* All comparator tails mirror this current\nXRbias bvdd nbias gnd sky130_fd_pr__res_xhigh_po w=1 l=1400\nXMbias nbias nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=2 l=4\n\n* =============================================\n* COMPARATOR 1: tap1 vs vref — TH1 = 2.5V (POR exit)\n* =============================================\n* PMOS current mirror load\nXM1p3 c1on c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM1p4 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\n* NMOS diff pair: tap1 (+), vref (-)\nXM1n1 c1on tap1 c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM1n2 c1o  vref c1tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\n* Tail current (mirrored from bias)\nXM1t c1tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=2 l=4\n* Positive feedback: weak cross-coupled PMOS for hysteresis\nXM1fb1 c1on c1o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM1fb2 c1o  c1on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\n* Output buffer: two inverters for clean rail-to-rail digital output\nXM1iv1p c1ob c1o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM1iv1n c1ob c1o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXM1iv2p comp1 c1ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM1iv2n comp1 c1ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* =============================================\n* COMPARATOR 2: tap2 vs vref — TH2 = 4.2V (retention regulate)\n* =============================================\nXM2p3 c2on c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM2p4 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM2n1 c2on tap2 c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM2n2 c2o  vref c2tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM2t c2tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=2 l=4\nXM2fb1 c2on c2o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM2fb2 c2o  c2on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM2iv1p c2ob c2o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM2iv1n c2ob c2o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXM2iv2p comp2 c2ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM2iv2n comp2 c2ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* =============================================\n* COMPARATOR 3: tap3 vs vref — TH3 = 4.5V (power-up bypass)\n* =============================================\nXM3p3 c3on c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM3p4 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM3n1 c3on tap3 c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM3n2 c3o  vref c3tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM3t c3tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=2 l=4\nXM3fb1 c3on c3o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM3fb2 c3o  c3on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM3iv1p c3ob c3o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM3iv1n c3ob c3o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXM3iv2p comp3 c3ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM3iv2n comp3 c3ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* =============================================\n* COMPARATOR 4: tap4 vs vref — TH4 = 5.6V (active mode)\n* =============================================\nXM4p3 c4on c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM4p4 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=2\nXM4n1 c4on tap4 c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM4n2 c4o  vref c4tail gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXM4t c4tail nbias gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=2 l=4\nXM4fb1 c4on c4o  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM4fb2 c4o  c4on bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=1 l=4\nXM4iv1p c4ob c4o bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM4iv1n c4ob c4o gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXM4iv2p comp4 c4ob bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXM4iv2n comp4 c4ob gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* =============================================\n* LOGIC DECODING\n* =============================================\n* All logic uses HV CMOS gates (sky130 g5v0d10v5)\n* Inverted comparator outputs (already have comp1..comp4, need NOT versions)\n\n* NOT gates for inverted comparator signals\nXMinv1p comp1b comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMinv1n comp1b comp1 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXMinv2p comp2b comp2 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMinv2n comp2b comp2 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXMinv3p comp3b comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMinv3n comp3b comp3 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\nXMinv4p comp4b comp4 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMinv4n comp4b comp4 gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* --- pass_off = NOT(comp1) ---\n* pass_off is HIGH during POR (comp1=0), LOW otherwise\n* Use comp1b directly with a buffer\nXMpo_bufp pass_off comp1b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMpo_bufn pass_off comp1b gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n* Pull-up resistor to ensure pass_off is HIGH when BVDD is very low (bootstrap)\nXRpo_pu bvdd pass_off gnd sky130_fd_pr__res_xhigh_po w=1 l=50\n\n* --- bypass_en = comp1·NOT(comp2) + comp3·NOT(comp4) ---\n* Implement as AOI21: OR of two AND terms, using CMOS\n* Term A = comp1 · comp2b (series NMOS: comp1 and comp2b)\n* Term B = comp3 · comp4b (series NMOS: comp3 and comp4b)\n* bypass_en_b = NOT(A + B) using NOR-like structure, then invert\n\n* PMOS pull-up network (series pairs in parallel for OR-AND):\n* For NOR of (A,B): PMOS in series for each AND term, paralleled\n* Path 1: comp1 and comp2b in series (PMOS)\nXMbp1a bp_mid1 comp1  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMbp1b bp_int  comp2b bp_mid1 bp_mid1 sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\n* Path 2: comp3 and comp4b in series (PMOS)\nXMbp2a bp_mid2 comp3  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMbp2b bp_int  comp4b bp_mid2 bp_mid2 sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\n\n* NMOS pull-down network (parallel pairs in series for OR-AND):\n* Term A pull-down: comp1 and comp2b in series\nXMbn1a bn_mid1 comp1  bp_int gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMbn1b bn_mid1 comp2b gnd    gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\n* Term B pull-down: comp3 and comp4b in series\nXMbn2a bn_mid2 comp3  bp_int gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMbn2b bn_mid2 comp4b gnd    gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\n\n* Wait - the above doesn't implement the right function.\n* Let me use a simpler approach: two NAND gates + NOR gate.\n\n* Actually, let me simplify. Use a direct CMOS implementation:\n* bypass_en = (comp1 AND comp2b) OR (comp3 AND comp4b)\n*\n* AOI (AND-OR-INVERT) gate output = NOT(bypass_en)\n* NMOS network: two series pairs in parallel pulling down\n*   Path 1: comp1 series comp2b\n*   Path 2: comp3 series comp4b\n* PMOS network: two parallel pairs in series pulling up\n*   Group 1: comp1 parallel comp3\n*   Group 2: comp2b parallel comp4b\n\n* NMOS pull-down (pulls bypass_enb LOW when bypass_en should be HIGH)\nXMby_n1a by_s1  comp1  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMby_n1b bypass_enb comp2b by_s1 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMby_n2a by_s2  comp3  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMby_n2b bypass_enb comp4b by_s2 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\n\n* PMOS pull-up (complement: pulls bypass_enb HIGH when bypass_en should be LOW)\n* PU = (comp1b+comp3b) · (comp2+comp4)\n* Group 1: comp1 and comp3 in series → both OFF (gates HIGH when comp active)\n* Actually for AOI PMOS: series of parallel groups\n* Group A: comp1 || comp3 (either gates LOW → PMOS ON)\n* Group B: comp2b || comp4b (either gates LOW → PMOS ON)\n* Series: Group A — bypass_enb — Group B\nXMby_p1a by_pmid comp1 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMby_p1b by_pmid comp3 bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMby_p2a bypass_enb comp2b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMby_p2b bypass_enb comp4b by_pmid by_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\n\n* Output inverter: bypass_en = NOT(bypass_enb)\nXMby_outp bypass_en bypass_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMby_outn bypass_en bypass_enb gnd  gnd  sky130_fd_pr__nfet_g5v0d10v5 w=2 l=1\n\n* --- ea_en = comp2·NOT(comp3) + comp4 ---\n* AOI: ea_enb = NOT(comp2·comp3b + comp4)\n* NMOS: path1 = comp2 series comp3b; path2 = comp4 alone; parallel\nXMea_n1a ea_s1   comp2  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMea_n1b ea_enb  comp3b ea_s1 gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\nXMea_n2  ea_enb  comp4  gnd gnd sky130_fd_pr__nfet_g5v0d10v5 w=4 l=1\n* PMOS: complement of (comp2·comp3b + comp4) = (comp2b+comp3)·comp4b\n* Group A: comp2 || comp3b in series with comp4\nXMea_p1a ea_pmid comp2  bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMea_p1b ea_pmid comp3b bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\nXMea_p2  ea_enb  comp4  ea_pmid ea_pmid sky130_fd_pr__pfet_g5v0d10v5 w=8 l=1\n* Output inverter\nXMea_outp ea_en ea_enb bvdd bvdd sky130_fd_pr__pfet_g5v0d10v5 w=4 l=1\nXMea_outn ea_en ea_enb gnd  gnd  sky130_fd_pr__nfet_g